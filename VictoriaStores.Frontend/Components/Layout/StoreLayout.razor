                                    <div class="w-12 h-12 rounded-full bg-surface-container-low flex items-center justify-center mx-auto mb-3 text-gray-300"> 
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                                        </svg> 
                                    </div> 
                                    <p class="text-sm font-semibold text-outline">Categories loading...</p> 
                                </div> 
                            } 
                        </div> 
                    </div> 
                }
            </div>

            <nav class="flex items-center flex-1 ml-6 overflow-x-auto gap-1">
                <a href="/" class="px-3.5 py-4 text-[13.5px] font-bold text-on-surface-variant hover:text-primary transition-colors whitespace-nowrap relative group">
                    Home
                    <span class="absolute bottom-0 left-0 w-full h-[3px] bg-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-t-full"></span>
                </a>
                <a href="/store" class="px-3.5 py-4 text-[13.5px] font-bold text-on-surface-variant hover:text-primary transition-colors whitespace-nowrap relative group">
                    All Products
                    <span class="absolute bottom-0 left-0 w-full h-[3px] bg-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-t-full"></span>
                </a>
                @foreach (var cat in _navCategories.Take(4))
                {
                    <a href="/category/@cat.Slug" class="px-3.5 py-4 text-[13.5px] font-bold text-on-surface-variant hover:text-primary transition-colors whitespace-nowrap relative group">
                        @cat.Name
                        <span class="absolute bottom-0 left-0 w-full h-[3px] bg-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-t-full"></span>
                    </a>
                }
            </nav>

            
        </div>
    </div>

</header>

@if (isMobileDrawerOpen)
{
    <div class="fixed inset-0 bg-black/60 z-50 backdrop-blur-[2px]" @onclick="ToggleMobileDrawer"></div>
    <div class="fixed inset-y-0 left-0 max-w-[310px] w-full bg-surface-container-lowest z-50 shadow-2xl flex flex-col drawer-enter">
        <div class="bg-gradient-to-r from-[#0c1e47] to-[#1A56DB] px-5 py-4 flex items-center justify-between flex-shrink-0 shadow-md">
            <a href="/" @onclick="ToggleMobileDrawer" class="flex items-center gap-2.5">
                <div class="w-9 h-9 rounded-xl bg-surface-container-lowest/20 text-white font-black text-base flex items-center justify-center shadow-inner">VJ</div>
                <div>
                    <p class="font-serif font-bold text-white text-sm leading-none">Victoria James</p>
                    <p class="text-white/60 text-[10px] font-bold tracking-widest uppercase mt-0.5">Store</p>
                </div>
            </a>
