@inherits LayoutComponentBase
@inject NavigationManager NavManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using VictoriaStores.Frontend.Models

<style>
    a,a:hover,a:visited,a:active,a:focus{text-decoration:none!important}
    @@keyframes megaSlide{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}
    .mega-enter{animation:megaSlide .2s cubic-bezier(.16,1,.3,1) forwards}
    @@keyframes drawerIn{from{transform:translateX(-100%)}to{transform:translateX(0)}}
    .drawer-enter{animation:drawerIn .26s cubic-bezier(.16,1,.3,1) forwards}
    @@keyframes vjping{0%{transform:scale(1);opacity:.5}75%,100%{transform:scale(2.2);opacity:0}}
    .vj-ping{animation:vjping 2.2s cubic-bezier(0,0,.2,1) infinite}
    @@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
    .marquee-track{animation:marquee 28s linear infinite}
    .marquee-track:hover{animation-play-state:paused}
    .nav-link-vj{position:relative;padding-bottom:2px}
    .nav-link-vj::after{content:'';position:absolute;bottom:0;left:0;width:0;height:2px;background:#1A56DB;border-radius:1px;transition:width .22s ease}
    .nav-link-vj:hover::after{width:100%}
    .search-wrap:focus-within{box-shadow:0 0 0 3px rgba(26,86,219,.18)}
    .cat-card{transition:transform .18s ease,box-shadow .18s ease}
    .cat-card:hover{transform:translateY(-3px);box-shadow:0 12px 28px rgba(26,86,219,.14)}
    .footer-divider{background:linear-gradient(90deg,transparent,rgba(255,255,255,.08),transparent)}
    .drawer-scroll::-webkit-scrollbar{width:4px}
    .drawer-scroll::-webkit-scrollbar-thumb{background:#e2e8f0;border-radius:4px}
</style>

<div class="font-body text-on-surface bg-surface-container-low min-h-screen flex flex-col">

@if (showAnnouncement)
{
    <div class="relative overflow-hidden bg-gradient-to-r from-[#0f2d6b] via-[#1A56DB] to-primary-fixed text-white text-[11.5px] font-bold py-2 select-none">
        <div class="marquee-track flex gap-0 whitespace-nowrap">
            @for (int i = 0; i < 2; i++)
            {
                <span class="flex items-center gap-8 pr-8">
                    <span>🚚 &nbsp;Free delivery on orders above ₦20,000</span>
                    <span class="opacity-40">·</span>
                    <span>📞 &nbsp;Call / WhatsApp: <strong>08162809886</strong></span>
                    <span class="opacity-40">·</span>
                    <span>🏦 &nbsp;Bank Transfer Accepted</span>
                    <span class="opacity-40">·</span>
                    <span>⚡ &nbsp;Fast delivery across Nigeria</span>
                    <span class="opacity-40">·</span>
                    <span>🔒 &nbsp;Secure &amp; trusted shopping</span>
                    <span class="opacity-40">·</span>
                </span>
            }
        </div>
        <button @onclick="DismissAnnouncement" class="absolute right-3 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded-full text-white/60 hover:text-white hover:bg-surface-container-lowest/20 transition-all z-10 text-xs flex-shrink-0" aria-label="Dismiss">✕</button>
    </div>
}

<header class="sticky top-0 z-40 w-full backdrop-blur-xl bg-surface-container-lowest/95 border-b border-outline-variant/15 shadow-[0_4px_20px_-10px_rgba(0,0,0,0.05)]">

    <div class="py-3 px-3 sm:px-6">
        <div class="max-w-7xl mx-auto flex items-center justify-between gap-3 lg:gap-6">
            
            <div class="flex items-center gap-3 sm:gap-4 flex-shrink-0">
                <button class="lg:hidden p-2.5 text-outline hover:text-primary hover:bg-primary-container/80 rounded-xl transition-all focus:outline-none focus:ring-2 focus:ring-primary/20" @onclick="ToggleMobileDrawer" aria-label="Open menu">
                    <span class="material-symbols-outlined text-[20px]">menu</span>
                </button>
                <a href="/" class="flex items-center gap-3 flex-shrink-0 group">
                    <div class="relative flex-shrink-0">
                        <div class="w-10 h-10 sm:w-11 sm:h-11 rounded-2xl bg-gradient-to-br from-primary via-[#1e4fd8] to-primary-fixed flex items-center justify-center shadow-md shadow-primary/20 group-hover:shadow-lg group-hover:shadow-primary/30 group-hover:-translate-y-0.5 transition-all duration-300 ring-1 ring-white/20 inset-0">
                            <span class="font-black text-white text-sm sm:text-base tracking-tight drop-shadow-sm">VJ</span>
                        </div>
                        <span class="absolute -bottom-1 -right-1 w-3.5 h-3.5 bg-tertiary rounded-full border-2 border-white shadow-sm"></span>
                    </div>
                    <div class="hidden sm:block leading-tight">
                        <p class="font-serif font-bold text-on-surface text-[16px] tracking-tight">Victoria James</p>
                        <p class="text-[9px] font-black tracking-[0.2em] text-primary uppercase mt-0.5 opacity-80">Store</p>
                    </div>
                </a>
            </div>

            <div class="hidden lg:flex flex-1 max-w-2xl">
                <div class="flex w-full rounded-2xl ring-1 ring-gray-200 overflow-hidden bg-surface-container-lowest hover:ring-primary/30 hover:shadow-md transition-all duration-300 focus-within:ring-2 focus-within:ring-primary focus-within:shadow-md">
                    <select @bind="searchCategory" class="bg-surface-container-low/50 border-r border-outline-variant/15 text-[13px] px-4 text-on-surface-variant focus:outline-none h-[48px] w-40 cursor-pointer flex-shrink-0 font-bold hover:bg-surface-container/80 transition-colors appearance-none">
                        <option value="All">All Categories</option>
                        @foreach (var cat in _navCategories)
                        {
                            <option value="@cat.Slug">@cat.Name</option>
                        }
                    </select>
                    <input type="search" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearchKey" placeholder="Search for products, brands and more…" class="flex-1 h-[48px] px-5 text-[14px] text-on-surface placeholder-gray-400 focus:outline-none bg-transparent font-medium" />
                    <button @onclick="PerformSearch" class="h-[48px] px-7 bg-primary text-white hover:bg-primary-dark transition-all flex-shrink-0 flex items-center gap-2.5 font-bold text-sm shadow-inner active:scale-95">
                        <span class="material-symbols-outlined text-[20px]">search</span>
                        Search
                    </button>
                </div>
            </div>

            <div class="flex items-center gap-1.5 sm:gap-3 ml-auto lg:ml-0">
                <a href="https://wa.me/2348162809886" target="_blank" rel="noopener noreferrer" class="hidden sm:flex flex-col items-center justify-center gap-1 w-14 h-14 text-green-600 hover:text-green-700 hover:bg-green-50/80 rounded-2xl transition-all duration-200 group">
                    <svg class="w-5 h-5 group-hover:scale-110 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    <span class="text-[9px] font-extrabold tracking-wider uppercase">Chat</span>
                </a>

                <AuthorizeView>
                    <Authorized>
                        <a href="/account" class="flex flex-col items-center justify-center gap-1 w-14 h-14 text-outline hover:text-primary hover:bg-primary-container/80 rounded-2xl transition-all duration-200 group">
                            <span class="material-symbols-outlined text-[20px]">person</span>
                            <span class="hidden sm:block text-[9px] font-extrabold tracking-wider uppercase">Profile</span>
                        </a>
                        <button @onclick="Logout" class="flex flex-col items-center justify-center gap-1 w-14 h-14 text-outline-variant hover:text-red-500 hover:bg-red-50/80 rounded-2xl transition-all duration-200 group">
                            <span class="material-symbols-outlined text-[20px]">logout</span>
                            <span class="hidden sm:block text-[9px] font-extrabold tracking-wider uppercase">Logout</span>
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="hidden sm:flex flex-col items-center justify-center gap-1 w-14 h-14 text-outline hover:text-primary hover:bg-primary-container/80 rounded-2xl transition-all duration-200 group">
                            <span class="material-symbols-outlined text-[20px]">login</span>
                            <span class="text-[9px] font-extrabold tracking-wider uppercase">Sign In</span>
                        </a>
                    </NotAuthorized>
                </AuthorizeView>

                <a href="/cart" class="relative flex flex-col items-center justify-center gap-1 w-14 h-14 text-outline hover:text-primary hover:bg-primary-container/80 rounded-2xl transition-all duration-200 group ml-1">
                    <div class="relative">
                        <span class="material-symbols-outlined text-[20px]">shopping_bag</span>
                        <span class="cart-badge absolute -top-2 -right-2.5 bg-tertiary text-white text-[10px] font-black rounded-full h-4.5 w-4.5 flex items-center justify-center hidden shadow-sm ring-2 ring-white">0</span>
                    </div>
                    <span class="hidden sm:block text-[9px] font-extrabold tracking-wider uppercase">Cart</span>
                </a>
            </div>
        </div>
    </div>

    <div class="lg:hidden px-4 py-3 border-t border-outline-variant/15 bg-surface-container-low/50">
        <div class="relative w-full max-w-md mx-auto">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-outline-variant pointer-events-none">
                <span class="material-symbols-outlined text-[20px]">search</span>
            </span>
            <input type="search" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearchKey" placeholder="Search products…"
                   class="h-11 w-full pl-11 pr-14 rounded-xl border border-outline-variant/30 text-[14px] font-medium placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary bg-surface-container-lowest shadow-sm transition-all"/>
            <button @onclick="PerformSearch" class="absolute right-1.5 top-1/2 -translate-y-1/2 h-8 px-4 bg-primary text-white text-xs font-bold rounded-lg hover:bg-primary-dark transition-colors shadow-sm active:scale-95">Go</button>
        </div>
    </div>

    <div class="hidden lg:block border-t border-outline-variant/15">
        <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
            
            <div class="relative group/mega">
                <button @onclick="ToggleMegaMenu"
                        class="flex items-center gap-3 bg-primary text-white text-[13.5px] font-bold px-6 py-4 hover:bg-primary-dark transition-all focus:outline-none relative overflow-hidden group">
                    <div class="absolute inset-0 bg-surface-container-lowest/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"></div>
                    <span class="material-symbols-outlined text-[20px]">menu</span>
                    <span class="relative z-10">All Categories</span>
                    <span class="material-symbols-outlined text-[20px]">expand_more</span>
                </button>

                @if (isMegaMenuOpen)
                {
                    <div class="fixed inset-0 z-40 bg-gray-900/10 backdrop-blur-[2px]" @onclick="() => isMegaMenuOpen=false"></div>
                    
                    <div class="absolute top-[102%] left-0 w-[500px] bg-surface-container-lowest rounded-2xl shadow-2xl z-50 overflow-hidden ring-1 ring-gray-100 transform origin-top animate-fade-in">
                        
                        <div class="bg-gradient-to-r from-gray-50 to-white border-b border-outline-variant/15 px-6 py-4 flex items-center justify-between">
                            <span class="text-on-surface font-extrabold text-[11px] tracking-[0.15em] uppercase">Browse Collections</span>
                            <a href="/store" @onclick="() => isMegaMenuOpen=false" class="text-primary hover:text-primary-dark text-xs font-bold transition-colors inline-flex items-center gap-1 group/link">
                                View Full Store 
                                <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                            </a>
                        </div>

                        <div class="p-3 grid grid-cols-2 gap-2">
                            @foreach (var cat in _navCategories)
                            {
                                <a href="/category/@cat.Slug" @onclick="() => isMegaMenuOpen=false"
                                   class="flex items-center gap-3.5 px-4 py-3.5 rounded-xl hover:bg-surface-container-low transition-all duration-200 group/item border border-transparent hover:border-outline-variant/15">
                                    <div class="w-10 h-10 rounded-lg bg-surface-container-lowest border border-outline-variant/15 shadow-sm flex items-center justify-center text-lg flex-shrink-0 group-hover/item:shadow-md group-hover/item:scale-105 group-hover/item:border-primary/20 transition-all duration-300">
                                        @GetCategoryEmoji(cat.Name)
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-[13px] font-bold text-on-surface group-hover/item:text-primary truncate transition-colors">@cat.Name</p>
                                    </div>
                                    <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                                </a>
                            }
                            
                            @if (!_navCategories.Any())
                            {
                                <div class="col-span-2 px-6 py-12 text-center">
                                    <div class="w-12 h-12 rounded-full bg-surface-container-low flex items-center justify-center mx-auto mb-3 text-gray-300">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                                    </div>
                                    <p class="text-sm font-semibold text-outline">Categories loading...</p>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <nav class="flex items-center flex-1 ml-6 overflow-x-auto gap-1">
                <a href="/" class="px-3.5 py-4 text-[13.5px] font-bold text-on-surface-variant hover:text-primary transition-colors whitespace-nowrap relative group">
                    Home
                    <span class="absolute bottom-0 left-0 w-full h-[3px] bg-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-t-full"></span>
                </a>
                <a href="/store" class="px-3.5 py-4 text-[13.5px] font-bold text-on-surface-variant hover:text-primary transition-colors whitespace-nowrap relative group">
                    All Products
                    <span class="absolute bottom-0 left-0 w-full h-[3px] bg-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-t-full"></span>
                </a>
                @foreach (var cat in _navCategories.Take(4))
                {
                    <a href="/category/@cat.Slug" class="px-3.5 py-4 text-[13.5px] font-bold text-on-surface-variant hover:text-primary transition-colors whitespace-nowrap relative group">
                        @cat.Name
                        <span class="absolute bottom-0 left-0 w-full h-[3px] bg-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-t-full"></span>
                    </a>
                }
            </nav>

            <a href="/deals" class="flex items-center gap-2 text-tertiary font-extrabold text-[13px] hover:text-tertiary-dark transition-all ml-4 flex-shrink-0 py-3.5 px-3 rounded-xl hover:bg-orange-50 group">
                <span class="relative flex h-2.5 w-2.5">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-tertiary opacity-60"></span>
                    <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-tertiary group-hover:scale-110 transition-transform"></span>
                </span>
                <span class="tracking-wide">Hot Deals</span>
            </a>
        </div>
    </div>

</header>

