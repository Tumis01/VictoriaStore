                <li><a href="/store" @onclick="ToggleMobileDrawer" class="flex items-center gap-3.5 px-3.5 py-3 rounded-xl hover:bg-primary-container hover:text-primary font-semibold text-on-surface-variant text-[13.5px] transition-colors"><span class="w-7 text-center text-base">🛍️</span> All Products</a></li>
                <li><a href="/deals" @onclick="ToggleMobileDrawer" class="flex items-center gap-3.5 px-3.5 py-3 rounded-xl hover:bg-orange-50 hover:text-tertiary font-bold text-tertiary text-[13.5px] transition-colors"><span class="w-7 text-center text-base">🔥</span> Hot Deals</a></li>

                <AuthorizeView>
                    <NotAuthorized>
                        <li class="px-3.5 pt-5 pb-2"><p class="text-[10px] font-extrabold uppercase tracking-widest text-outline-variant">My Account</p></li>
                        <li><a href="/login" @onclick="ToggleMobileDrawer" class="flex items-center gap-3.5 px-3.5 py-3 rounded-xl hover:bg-primary-container hover:text-primary font-semibold text-on-surface-variant text-[13.5px] transition-colors"><span class="w-7 text-center text-base">🔐</span> Sign In</a></li>
                        <li><a href="/register" @onclick="ToggleMobileDrawer" class="flex items-center gap-3.5 px-3.5 py-3 rounded-xl hover:bg-primary-container hover:text-primary font-semibold text-on-surface-variant text-[13.5px] transition-colors"><span class="w-7 text-center text-base">📝</span> Register</a></li>
                    </NotAuthorized>
                    <Authorized>
                        <li class="px-3.5 pt-5 pb-2"><p class="text-[10px] font-extrabold uppercase tracking-widest text-outline-variant">My Account</p></li>
                        <li><a href="/account" @onclick="ToggleMobileDrawer" class="flex items-center gap-3.5 px-3.5 py-3 rounded-xl hover:bg-primary-container hover:text-primary font-semibold text-on-surface-variant text-[13.5px] transition-colors"><span class="w-7 text-center text-base">👤</span> My Account</a></li>
                        <li><a href="/cart" @onclick="ToggleMobileDrawer" class="flex items-center gap-3.5 px-3.5 py-3 rounded-xl hover:bg-primary-container hover:text-primary font-semibold text-on-surface-variant text-[13.5px] transition-colors"><span class="w-7 text-center text-base">🛒</span> My Cart</a></li>
                        <li><button @onclick="Logout" class="w-full flex items-center gap-3.5 px-3.5 py-3 rounded-xl hover:bg-red-50 hover:text-red-600 font-semibold text-on-surface-variant text-[13.5px] transition-colors text-left"><span class="w-7 text-center text-base">🚪</span> Logout</button></li>
                    </Authorized>
                </AuthorizeView>

                @if (_navCategories.Any())
                {
                    <li class="px-3.5 pt-5 pb-2"><p class="text-[10px] font-extrabold uppercase tracking-widest text-outline-variant">Categories</p></li>
                    @foreach (var cat in _navCategories)
                    {
                        <li>
                            <a href="/category/@cat.Slug" @onclick="ToggleMobileDrawer"
                               class="flex items-center gap-3.5 px-3.5 py-3 rounded-xl hover:bg-primary-container hover:text-primary font-semibold text-on-surface-variant text-[13.5px] transition-colors">
                                <span class="w-8 h-8 rounded-lg bg-primary-container flex items-center justify-center text-base flex-shrink-0">@GetCategoryEmoji(cat.Name)</span>
                                @cat.Name
                            </a>
