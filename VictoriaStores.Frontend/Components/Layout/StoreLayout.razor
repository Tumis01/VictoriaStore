@inherits LayoutComponentBase
@inject NavigationManager NavManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using VictoriaStores.Frontend.Models

<style>
    a,a:hover,a:visited,a:active,a:focus{text-decoration:none!important}
    @@keyframes megaSlide{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}
    .mega-enter{animation:megaSlide .2s cubic-bezier(.16,1,.3,1) forwards}
    @@keyframes drawerIn{from{transform:translateX(-100%)}to{transform:translateX(0)}}
    .drawer-enter{animation:drawerIn .26s cubic-bezier(.16,1,.3,1) forwards}
    @@keyframes vjping{0%{transform:scale(1);opacity:.5}75%,100%{transform:scale(2.2);opacity:0}}
    .vj-ping{animation:vjping 2.2s cubic-bezier(0,0,.2,1) infinite}
    @@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
    .marquee-track{animation:marquee 28s linear infinite}
    .marquee-track:hover{animation-play-state:paused}
    .nav-link-vj{position:relative;padding-bottom:2px}
    .nav-link-vj::after{content:'';position:absolute;bottom:0;left:0;width:0;height:2px;background:#1A56DB;border-radius:1px;transition:width .22s ease}
    .nav-link-vj:hover::after{width:100%}
    .search-wrap:focus-within{box-shadow:0 0 0 3px rgba(26,86,219,.18)}
    .cat-card{transition:transform .18s ease,box-shadow .18s ease}
    .cat-card:hover{transform:translateY(-3px);box-shadow:0 12px 28px rgba(26,86,219,.14)}
    .footer-divider{background:linear-gradient(90deg,transparent,rgba(255,255,255,.08),transparent)}
    .drawer-scroll::-webkit-scrollbar{width:4px}
    .drawer-scroll::-webkit-scrollbar-thumb{background:#e2e8f0;border-radius:4px}
</style>

<div class="font-body text-on-surface bg-surface-container-low min-h-screen flex flex-col">

@if (showAnnouncement)
{
    <div class="relative overflow-hidden bg-gradient-to-r from-[#0f2d6b] via-[#1A56DB] to-primary-fixed text-white text-[11.5px] font-bold py-2 select-none shadow-sm z-50">
        <div class="marquee-track flex gap-0 whitespace-nowrap">
            @for (int i = 0; i < 2; i++)
            {
                <span class="flex items-center gap-8 pr-8">
                    <span>🚚 &nbsp;Free delivery on orders above ₦20,000</span>
                    <span class="opacity-40">·</span>
                    <span>📞 &nbsp;Call / WhatsApp: <strong>08162809886</strong></span>
                    <span class="opacity-40">·</span>
                    <span>🏦 &nbsp;Bank Transfer Accepted</span>
                    <span class="opacity-40">·</span>
                    <span>⚡ &nbsp;Fast delivery across Nigeria</span>
                    <span class="opacity-40">·</span>
                    <span>🔒 &nbsp;Secure &amp; trusted shopping</span>
                    <span class="opacity-40">·</span>
                </span>
            }
        </div>
        <button @onclick="DismissAnnouncement" class="absolute right-3 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded-full text-white/60 hover:text-white hover:bg-surface-container-lowest/20 transition-all z-10 text-xs flex-shrink-0" aria-label="Dismiss">✕</button>
    </div>
}

<header class="sticky top-0 z-40 w-full backdrop-blur-xl bg-surface-container-lowest/95 shadow-sm">
    <div class="py-3 px-3 sm:px-6">
        <div class="max-w-7xl mx-auto flex items-center justify-between gap-3 lg:gap-6">
            
            <div class="flex items-center gap-3 sm:gap-4 flex-shrink-0">
                <button class="lg:hidden p-2.5 text-outline hover:text-primary hover:bg-primary-container/80 rounded-xl transition-all focus:outline-none" @onclick="ToggleMobileDrawer" aria-label="Open menu">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                <a href="/" class="flex items-center gap-3 flex-shrink-0 group">
                    <div class="relative flex-shrink-0">
                        <div class="w-10 h-10 sm:w-11 sm:h-11 rounded-2xl bg-gradient-to-br from-primary via-[#1e4fd8] to-primary-fixed flex items-center justify-center shadow-md shadow-primary/20 group-hover:shadow-lg group-hover:-translate-y-0.5 transition-all duration-300 inset-0">
                            <span class="font-black text-white text-sm sm:text-base tracking-tight drop-shadow-sm">VJ</span>
                        </div>
                        <span class="absolute -bottom-1 -right-1 w-3.5 h-3.5 bg-tertiary rounded-full border-2 border-white shadow-sm"></span>
                    </div>
                    <div class="hidden sm:block leading-tight">
                        <p class="font-serif font-bold text-on-surface text-[16px] tracking-tight">Victoria James</p>
                        <p class="text-[9px] font-black tracking-[0.2em] text-primary uppercase mt-0.5 opacity-80">Store</p>
                    </div>
                </a>
            </div>

