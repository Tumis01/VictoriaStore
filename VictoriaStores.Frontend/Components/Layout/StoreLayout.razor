@inherits LayoutComponentBase
@inject NavigationManager NavManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject HttpClient Http
@using Microsoft.AspNetCore.Components.Authorization
@using VictoriaStores.Frontend.Models

<style>
    a,a:hover,a:visited,a:active,a:focus{text-decoration:none!important}
    @@keyframes megaSlide{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
    .mega-enter{animation:megaSlide .18s ease-out forwards}
    @@keyframes drawerIn{from{transform:translateX(-100%)}to{transform:translateX(0)}}
    .drawer-enter{animation:drawerIn .22s ease-out forwards}
    @@keyframes vjping{0%{transform:scale(1);opacity:.4}75%,100%{transform:scale(1.8);opacity:0}}
    .vj-ping{animation:vjping 2s cubic-bezier(0,0,.2,1) infinite}
</style>

<div class="font-sans text-gray-900 bg-gray-50 min-h-screen flex flex-col">

@if (showAnnouncement)
{
    <div class="relative bg-brand overflow-hidden">
        <div class="absolute inset-0 pointer-events-none" style="background-image:radial-gradient(circle at 2px 2px,rgba(255,255,255,.08) 1px,transparent 0);background-size:20px 20px"></div>
        <div class="relative z-10 flex items-center justify-center py-2 px-10 text-white text-[12px] font-semibold">
            🇳🇬&nbsp; Free WhatsApp support &nbsp;·&nbsp; Call&nbsp;08162809886 &nbsp;·&nbsp; Fast delivery across Nigeria
        </div>
        <button @onclick="DismissAnnouncement" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 w-6 h-6 flex items-center justify-center text-white/60 hover:text-white hover:bg-white/20 rounded-full transition-all text-sm" aria-label="Dismiss">✕</button>
    </div>
}

<header class="sticky top-0 z-40 w-full shadow-sm">
    <div class="hidden md:flex justify-between items-center bg-gray-900 text-gray-400 text-xs py-1.5 px-6">
        <div class="flex gap-5">
            <a href="/about"   class="hover:text-white transition-colors">About Us</a>
            <a href="/contact" class="hover:text-white transition-colors">Contact</a>
            <a href="/track"   class="hover:text-white transition-colors">Order Tracking</a>
        </div>
        <span>Welcome to Victoria James Store</span>
    </div>

    <div class="bg-white border-b border-gray-100 py-3.5 px-4 sm:px-6 flex items-center gap-4 lg:gap-8">
        <div class="flex items-center gap-3">
            <button class="lg:hidden p-1.5 text-gray-600 hover:text-brand rounded-lg hover:bg-gray-50 transition-colors" @onclick="ToggleMobileDrawer" aria-label="Open menu">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>
            <a href="/" class="flex items-center gap-2.5 flex-shrink-0 group">
                <div class="bg-brand rounded-xl w-10 h-10 text-white font-black text-xl flex items-center justify-center shadow-sm group-hover:bg-brand-dark transition-colors">VJ</div>
                <div class="hidden sm:block leading-tight">
                    <p class="font-serif font-bold text-gray-900 text-[15px]">Victoria James</p>
                    <p class="text-brand text-xs font-bold">Store</p>
                </div>
            </a>
        </div>

        <div class="hidden lg:flex flex-1 max-w-xl">
            <div class="flex w-full rounded-xl border border-gray-300 overflow-hidden focus-within:border-brand focus-within:ring-2 focus-within:ring-brand/20 transition-all">
                <select @bind="searchCategory" class="bg-gray-50 border-r border-gray-200 text-sm px-3 text-gray-600 focus:outline-none h-11 w-32 cursor-pointer flex-shrink-0">
                    <option value="All">All</option>
                    @foreach (var cat in _navCategories)
                    {
                        <option value="@cat.Slug">@cat.Name</option>
                    }
                </select>
                <input type="search" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearchKey" placeholder="Search for products..." class="flex-1 h-11 px-4 text-sm text-gray-900 placeholder-gray-400 focus:outline-none bg-white" />
                <button @onclick="PerformSearch" class="h-11 px-5 bg-brand text-white hover:bg-brand-dark transition-colors flex-shrink-0 flex items-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </button>
            </div>
        </div>

        <div class="flex items-center gap-4 sm:gap-5 ml-auto lg:ml-0">
            <a href="https://wa.me/2348162809886" target="_blank" rel="noopener noreferrer" class="hidden sm:flex flex-col items-center text-green-500 hover:text-green-600 transition-colors">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                <span class="text-[10px] font-bold mt-0.5">WhatsApp</span>
            </a>
            <AuthorizeView>
                <Authorized>
                    <a href="/account" class="flex flex-col items-center text-gray-600 hover:text-brand transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        <span class="text-[10px] font-bold mt-0.5">Account</span>
                    </a>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="flex flex-col items-center text-gray-600 hover:text-brand transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
                        <span class="text-[10px] font-bold mt-0.5">Sign In</span>
                    </a>
                </NotAuthorized>
            </AuthorizeView>
            <a href="/cart" class="relative flex flex-col items-center text-gray-600 hover:text-brand transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                <span class="text-[10px] font-bold mt-0.5">Cart</span>
                <span class="cart-badge absolute -top-1 -right-2 bg-accent text-white text-[10px] font-extrabold rounded-full h-4 w-4 flex items-center justify-center hidden">0</span>
            </a>
        </div>
    </div>

    <div class="lg:hidden px-4 py-2.5 bg-white border-b border-gray-100">
        <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </span>
            <input type="search" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearchKey" placeholder="Search products..." class="h-11 w-full pl-10 pr-4 rounded-xl border border-gray-200 text-sm placeholder-gray-400 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 bg-gray-50"/>
        </div>
    </div>

    <div class="hidden lg:block bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
            <div class="relative">
                <button @onclick="ToggleMegaMenu" class="flex items-center gap-2 bg-brand text-white text-sm font-bold px-5 py-3.5 hover:bg-brand-dark transition-colors focus:outline-none">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
                    All Categories
                    <svg class="w-4 h-4 transition-transform duration-200 @(isMegaMenuOpen?"rotate-180":"")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                </button>
                @if (isMegaMenuOpen)
                {
                    <div class="fixed inset-0 z-40" @onclick="() => isMegaMenuOpen=false"></div>
                    <div class="absolute top-full left-0 w-[540px] bg-white border border-gray-200 shadow-2xl rounded-b-2xl z-50 flex overflow-hidden mega-enter">
                        <ul class="w-1/2 border-r border-gray-100 py-2">
                            @foreach (var cat in _navCategories)
                            {
                                <li>
                                    <a href="/category/@cat.Slug" @onclick="() => isMegaMenuOpen=false" class="flex items-center justify-between px-6 py-3.5 group hover:bg-brand-light transition-colors">
                                        <div class="flex items-center gap-3">
                                            <span class="text-xl select-none">@GetCategoryEmoji(cat.Name)</span>
                                            <span class="text-sm font-semibold text-gray-800 group-hover:text-brand">@cat.Name</span>
                                        </div>
                                        <svg class="w-4 h-4 text-gray-300 group-hover:text-brand transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                                    </a>
                                </li>
                            }
                            @if (!_navCategories.Any())
                            {
                                <li class="px-6 py-8 text-center text-sm text-gray-400">No categories yet</li>
                            }
                        </ul>
                        <div class="w-1/2 bg-brand-light/40 p-6 flex flex-col justify-between">
                            <div>
                                <p class="text-xs font-extrabold uppercase tracking-widest text-brand mb-3">Featured</p>
                                <div class="bg-gradient-to-br from-brand to-blue-600 rounded-2xl aspect-[4/3] flex items-center justify-center mb-4">
                                    <span class="text-6xl select-none">🛍️</span>
                                </div>
                                <p class="font-bold text-gray-900 text-sm">Explore Our Full Collection</p>
                                <p class="text-xs text-gray-500 mt-1">Quality products for every need</p>
                            </div>
                            <a href="/store" @onclick="() => isMegaMenuOpen=false" class="mt-4 inline-flex items-center justify-center gap-2 h-10 px-5 bg-accent text-white text-sm font-bold rounded-xl hover:bg-accent-dark transition-colors">View All Products →</a>
                        </div>
                    </div>
                }
            </div>

            <nav class="flex items-center flex-1 ml-2 overflow-x-auto">
                <a href="/" class="px-3 py-3.5 text-sm font-semibold whitespace-nowrap hover:text-brand text-gray-700 transition-colors">Home</a>
                @foreach (var cat in _navCategories)
                {
                    <a href="/category/@cat.Slug" class="px-3 py-3.5 text-sm font-semibold whitespace-nowrap hover:text-brand text-gray-700 transition-colors">@cat.Name</a>
                }
            </nav>

            <a href="/deals" class="text-accent font-bold text-sm flex items-center gap-1.5 hover:text-accent-dark transition-colors ml-4 flex-shrink-0 py-3.5">🔥 Trending</a>
        </div>
    </div>
</header>

@if (isMobileDrawerOpen)
{
    <div class="fixed inset-0 bg-black/50 z-50 backdrop-blur-sm" @onclick="ToggleMobileDrawer"></div>
    <div class="fixed inset-y-0 left-0 max-w-[300px] w-full bg-white z-50 shadow-2xl flex flex-col drawer-enter">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <a href="/" @onclick="ToggleMobileDrawer" class="flex items-center gap-2.5">
                <div class="bg-brand rounded-xl w-9 h-9 text-white font-black text-lg flex items-center justify-center">VJ</div>
                <div><p class="font-serif font-bold text-gray-900 text-sm">Victoria James</p><p class="text-brand text-xs font-bold">Store</p></div>
            </a>
            <button @onclick="ToggleMobileDrawer" class="p-2 text-gray-400 hover:text-gray-700 hover:bg-gray-100 rounded-xl transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="flex-1 overflow-y-auto py-3">
            <div class="px-4 pb-3">
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    </span>
                    <input type="search" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearchKey" placeholder="Search products..." class="h-10 w-full pl-9 pr-4 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-brand bg-gray-50"/>
                </div>
            </div>
            <ul class="px-3 space-y-0.5">
                <li><a href="/" @onclick="ToggleMobileDrawer" class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-brand-light hover:text-brand font-semibold text-gray-700 text-sm transition-colors"><span class="text-lg w-7 text-center">🏠</span> Home</a></li>
                <li><a href="/store" @onclick="ToggleMobileDrawer" class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-brand-light hover:text-brand font-semibold text-gray-700 text-sm transition-colors"><span class="text-lg w-7 text-center">🛍️</span> All Products</a></li>
                @if (_navCategories.Any())
                {
                    <li class="px-3 pt-4 pb-1.5"><p class="text-[10px] font-extrabold uppercase tracking-widest text-gray-400">Categories</p></li>
                    @foreach (var cat in _navCategories)
                    {
                        <li><a href="/category/@cat.Slug" @onclick="ToggleMobileDrawer" class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-brand-light hover:text-brand font-semibold text-gray-700 text-sm transition-colors"><span class="text-lg w-7 text-center">@GetCategoryEmoji(cat.Name)</span>@cat.Name</a></li>
                    }
                }
                <li class="px-3 pt-4 pb-1.5"><p class="text-[10px] font-extrabold uppercase tracking-widest text-gray-400">Help</p></li>
                <li><a href="/track" @onclick="ToggleMobileDrawer" class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-brand-light hover:text-brand font-semibold text-gray-700 text-sm transition-colors"><span class="text-lg w-7 text-center">📦</span> Track Order</a></li>
                <li><a href="/contact" @onclick="ToggleMobileDrawer" class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-brand-light hover:text-brand font-semibold text-gray-700 text-sm transition-colors"><span class="text-lg w-7 text-center">📞</span> Contact Us</a></li>
            </ul>
        </div>
        <div class="border-t border-gray-100 p-4 bg-gray-50">
            <a href="https://wa.me/2348162809886" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2.5 w-full h-12 bg-green-500 text-white font-bold rounded-xl hover:bg-green-600 transition-colors shadow-sm">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp Support
            </a>
            <p class="text-center text-xs text-gray-400 mt-2.5">Mon–Sat · 8am–8pm</p>
        </div>
    </div>
}

<main class="flex-1">@Body</main>

<footer class="bg-gray-900 text-gray-400 pt-14 pb-6 mt-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
            <div>
                <div class="flex items-center gap-2.5 mb-4">
                    <div class="bg-brand rounded-xl w-9 h-9 text-white font-black text-sm flex items-center justify-center">VJ</div>
                    <span class="font-serif font-bold text-white text-base">Victoria James</span>
                </div>
                <p class="text-sm leading-relaxed mb-6">Quality products delivered to your doorstep across Nigeria.</p>
                <a href="https://wa.me/2348162809886" target="_blank" class="inline-flex items-center gap-2 text-sm font-bold text-white bg-green-600 hover:bg-green-500 px-4 py-2.5 rounded-xl transition-colors">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Chat on WhatsApp
                </a>
            </div>
            <div>
                <h3 class="text-xs font-extrabold uppercase tracking-widest text-gray-500 mb-5">Quick Links</h3>
                <ul class="space-y-3 text-sm font-semibold">
                    <li><a href="/"      class="hover:text-white transition-colors">Home</a></li>
                    <li><a href="/store" class="hover:text-white transition-colors">All Products</a></li>
                    @foreach (var cat in _navCategories.Take(4))
                    {
                        <li><a href="/category/@cat.Slug" class="hover:text-white transition-colors">@cat.Name</a></li>
                    }
                    <li><a href="/about" class="hover:text-white transition-colors">About Us</a></li>
                </ul>
            </div>
            <div>
                <h3 class="text-xs font-extrabold uppercase tracking-widest text-gray-500 mb-5">Customer Service</h3>
                <ul class="space-y-3 text-sm font-semibold">
                    <li><a href="/track"   class="hover:text-white transition-colors">Order Tracking</a></li>
                    <li><a href="/contact" class="hover:text-white transition-colors">Contact Us</a></li>
                    <li><a href="/returns" class="hover:text-white transition-colors">Returns Policy</a></li>
                </ul>
            </div>
            <div>
                <h3 class="text-xs font-extrabold uppercase tracking-widest text-gray-500 mb-5">Contact Info</h3>
                <ul class="space-y-3 text-sm">
