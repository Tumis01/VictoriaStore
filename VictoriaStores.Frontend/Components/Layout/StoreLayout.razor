<ToastContainer />

@code {
    private bool showAnnouncement = true;
    private bool isMegaMenuOpen   = false;
    private bool isMobileDrawerOpen = false;
    private string searchQuery    = "";
    private string searchCategory = "All";
    private List<CategoryDto> _navCategories = new();

    protected override async Task OnInitializedAsync()
    {
        var dismissed = await LocalStorage.GetItemAsync<bool>("hideAnnouncement");
        showAnnouncement = !dismissed;
        await LoadNavCategoriesAsync();
    }

    private async Task LoadNavCategoriesAsync()
    {
        try { _navCategories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/category") ?? new(); }
        catch (Exception ex) { Console.WriteLine($"[StoreLayout] Nav categories failed: {ex.Message}"); _navCategories = new(); }
    }

    private static string GetCategoryEmoji(string name) => name switch
    {
        var n when n.Contains("Kitchen",   StringComparison.OrdinalIgnoreCase) => "🍳",
        var n when n.Contains("Fashion",   StringComparison.OrdinalIgnoreCase) => "👗",
        var n when n.Contains("Gift",      StringComparison.OrdinalIgnoreCase) => "🎁",
        var n when n.Contains("Accessor",  StringComparison.OrdinalIgnoreCase) => "💍",
        var n when n.Contains("Household", StringComparison.OrdinalIgnoreCase) => "🏠",
        _ => "🛍️"
    };

    private async Task DismissAnnouncement()
    {
        showAnnouncement = false;
        await LocalStorage.SetItemAsync("hideAnnouncement", true);
    }

    private void ToggleMegaMenu()     => isMegaMenuOpen     = !isMegaMenuOpen;
    private void ToggleMobileDrawer() => isMobileDrawerOpen = !isMobileDrawerOpen;
    private void HandleSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") PerformSearch(); }

    private void PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) return;
        var url = $"/search?q={Uri.EscapeDataString(searchQuery.Trim())}";
        if (searchCategory != "All") url += $"&cat={Uri.EscapeDataString(searchCategory)}";
        NavManager.NavigateTo(url);
        isMobileDrawerOpen = false;
        isMegaMenuOpen = false;
    }
}
