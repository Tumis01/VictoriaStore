                    <a href="/store" @onclick="ToggleMobileDrawer" class="group flex items-center gap-4 px-4 py-3 rounded-xl hover:bg-gray-50 hover:text-primary font-semibold text-on-surface-variant text-[14px] transition-all duration-200 hover:translate-x-1">
                        <svg class="w-5 h-5 opacity-70 group-hover:opacity-100 group-hover:scale-110 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                        All Products
                    </a>
                </li>

                @if (_navCategories.Any())
                {
                    <li class="px-4 pt-6 pb-2"><p class="text-[10px] font-extrabold uppercase tracking-widest text-outline-variant">Categories</p></li>
                    @foreach (var cat in _navCategories)
                    {
                        <li>
