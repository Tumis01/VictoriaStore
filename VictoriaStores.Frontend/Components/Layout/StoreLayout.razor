<ToastContainer />

@code {
    private bool showAnnouncement = true;
    private bool isMegaMenuOpen = false;
    private bool isMobileDrawerOpen = false;
    private string searchQuery = "";
    private string searchCategory = "All";

    protected override async Task OnInitializedAsync()
    {
        var dismissed = await LocalStorage.GetItemAsync<bool>("hideAnnouncement");
        showAnnouncement = !dismissed;
    }

    private async Task DismissAnnouncement()
    {
        showAnnouncement = false;
        await LocalStorage.SetItemAsync("hideAnnouncement", true);
    }

    private void ToggleMegaMenu()
    {
        isMegaMenuOpen = !isMegaMenuOpen;
    }

    private void HandleFocusOut(FocusEventArgs e)
    {
        Task.Delay(150).ContinueWith(_ => {
            if (isMegaMenuOpen) {
                isMegaMenuOpen = false;
                InvokeAsync(StateHasChanged);
            }
        });
    }

    private void ToggleMobileDrawer()
    {
        isMobileDrawerOpen = !isMobileDrawerOpen;
    }

    private void HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            PerformSearch();
        }
    }

    private void PerformSearch()
    {
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var url = $"/search?q={Uri.EscapeDataString(searchQuery)}";
            if (searchCategory != "All")
            {
                url += $"&cat={searchCategory}";
            }
            NavManager.NavigateTo(url);
            isMobileDrawerOpen = false;
        }
    }
}