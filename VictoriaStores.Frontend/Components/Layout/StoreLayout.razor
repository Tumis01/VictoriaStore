                    }
                }
                <li class="px-3.5 pt-5 pb-2"><p class="text-[10px] font-extrabold uppercase tracking-widest text-outline-variant">Help &amp; Support</p></li>
                <li><a href="/track" @onclick="ToggleMobileDrawer" class="flex items-center gap-3.5 px-3.5 py-3 rounded-xl hover:bg-primary-container hover:text-primary font-semibold text-on-surface-variant text-[13.5px] transition-colors"><span class="w-7 text-center text-base">📦</span> Track Order</a></li>
                <li><a href="/contact" @onclick="ToggleMobileDrawer" class="flex items-center gap-3.5 px-3.5 py-3 rounded-xl hover:bg-primary-container hover:text-primary font-semibold text-on-surface-variant text-[13.5px] transition-colors"><span class="w-7 text-center text-base">📬</span> Contact Us</a></li>
                <li><a href="/about" @onclick="ToggleMobileDrawer" class="flex items-center gap-3.5 px-3.5 py-3 rounded-xl hover:bg-primary-container hover:text-primary font-semibold text-on-surface-variant text-[13.5px] transition-colors"><span class="w-7 text-center text-base">ℹ️</span> About Us</a></li>
            </ul>
        </div>

