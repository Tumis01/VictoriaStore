@inherits LayoutComponentBase
@inject NavigationManager NavManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using Microsoft.AspNetCore.Components.Authorization

<div class="font-sans text-gray-900 bg-gray-50 min-h-screen flex flex-col">
    @if (showAnnouncement)
    {
        <div class="bg-brand text-white text-[12px] font-semibold py-1.5 px-4 flex justify-center items-center relative animate-fade-in">
            <p>Free WhatsApp support · Call 08162809886 · Fast delivery across Nigeria 🇳🇬</p>
            <button @onclick="DismissAnnouncement" class="absolute right-4 top-1/2 -translate-y-1/2 hover:text-gray-200">✕</button>
        </div>
    }

    <header class="sticky top-0 z-40 shadow-sm w-full">
        <div class="hidden md:flex justify-between items-center bg-gray-900 text-gray-400 text-xs py-1.5 px-6">
            <div class="flex gap-4">
                <a href="/about" class="hover:text-white transition-colors">About Us</a>
                <a href="/contact" class="hover:text-white transition-colors">Contact</a>
                <a href="/track" class="hover:text-white transition-colors">Order Tracking</a>
            </div>
            <div>Welcome to Victoria James Store</div>
        </div>

        <div class="bg-white border-b border-gray-100 py-4 px-4 sm:px-6 flex justify-between items-center gap-4 lg:gap-8">
            <a href="/" class="flex items-center gap-2 flex-shrink-0">
                <div class="bg-brand rounded-lg w-10 h-10 text-white font-black text-xl flex items-center justify-center">VJ</div>
                <div class="hidden sm:block">
                    <div class="font-serif font-bold text-gray-900 leading-tight">Victoria James</div>
                    <div class="text-brand text-sm font-semibold leading-tight">Store</div>
                </div>
            </a>

            <div class="hidden lg:flex flex-1 max-w-xl relative">
                <select class="absolute left-0 top-0 h-11 bg-gray-50 border border-r-0 border-gray-300 rounded-l-lg text-sm px-3 text-gray-600 focus:outline-none">
                    <option>All</option>
                    <option>Household</option>
                    <option>Kitchen</option>
                    <option>Fashion</option>
                </select>
                <input type="search" placeholder="Search for products..." class="h-11 w-full pl-28 pr-12 rounded-lg border border-gray-300 text-sm focus:outline-none focus:border-brand" />
                <button class="absolute right-0 top-0 h-11 px-4 bg-brand text-white rounded-r-lg hover:bg-brand-dark transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </div>

            <div class="flex items-center gap-4 sm:gap-6">
                <a href="https://wa.me/2348162809886" target="_blank" class="hidden sm:flex text-green-500 hover:text-green-600 transition-colors">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.183-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.765-5.77zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-3.825 3.113-6.937 6.937-6.937 3.825 0 6.938 3.112 6.938 6.937 0 3.825-3.113 6.938-6.938 6.938z" /></svg>
                </a>
                
                <AuthorizeView>
                    <Authorized>
                        <a href="/account" class="text-gray-600 hover:text-brand transition-colors flex flex-col items-center">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            <span class="text-[10px] font-bold mt-0.5">Account</span>
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="text-gray-600 hover:text-brand transition-colors flex flex-col items-center">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path></svg>
                            <span class="text-[10px] font-bold mt-0.5">Sign In</span>
                        </a>
                    </NotAuthorized>
                </AuthorizeView>

                <a href="/cart" class="text-gray-600 hover:text-brand transition-colors flex flex-col items-center relative">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    <span class="text-[10px] font-bold mt-0.5">Cart</span>
                    <span class="absolute -top-1 -right-2 bg-accent text-white text-[10px] font-bold rounded-full h-4 w-4 flex items-center justify-center">0</span>
                </a>
            </div>
        </div>

        <div class="hidden lg:block bg-white border-b border-gray-200">
            <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
                <div class="flex items-center gap-6 text-sm font-bold text-gray-700">
                    <button class="flex items-center gap-2 bg-brand text-white px-5 py-3 hover:bg-brand-dark transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                        All Categories
                    </button>
                    <a href="/" class="hover:text-brand transition-colors">Home</a>
                    <a href="/category/household" class="hover:text-brand transition-colors">Household Items</a>
                    <a href="/category/kitchen" class="hover:text-brand transition-colors">Kitchen Utensils</a>
                    <a href="/category/fashion" class="hover:text-brand transition-colors">Fashion & Giftpacks</a>
                    <a href="/category/accessories" class="hover:text-brand transition-colors">Accessories</a>
                </div>
                <a href="/deals" class="text-accent font-bold text-sm flex items-center gap-1 hover:text-accent-dark">
                    <span>🔥</span> Trending Today
                </a>
            </div>
        </div>
    </header>

    <main class="flex-1">
        @Body
    </main>

    <footer class="bg-white border-t border-gray-200 pt-16 pb-6 mt-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <div class="bg-brand rounded-lg w-8 h-8 text-white font-black text-sm flex items-center justify-center">VJ</div>
                        <div class="font-serif font-bold text-gray-900">Victoria James</div>
                    </div>
                    <p class="text-sm text-gray-500 mb-6 leading-relaxed">Quality products delivered to your doorstep across Nigeria.</p>
                    <a href="https://wa.me/2348162809886" class="inline-flex items-center gap-2 text-sm font-bold text-green-600 bg-green-50 px-4 py-2 rounded-lg hover:bg-green-100 transition-colors">
                        Chat on WhatsApp
                    </a>
                </div>

                <div>
                    <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-4">Quick Links</h3>
                    <ul class="space-y-3 text-sm text-gray-600 font-semibold">
                        <li><a href="/" class="hover:text-brand transition-colors">Home</a></li>
                        <li><a href="/store" class="hover:text-brand transition-colors">All Products</a></li>
                        <li><a href="/about" class="hover:text-brand transition-colors">About Us</a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-4">Customer Service</h3>
                    <ul class="space-y-3 text-sm text-gray-600 font-semibold">
                        <li><a href="/how-to-order" class="hover:text-brand transition-colors">How to Order</a></li>
                        <li><a href="/track" class="hover:text-brand transition-colors">Order Tracking</a></li>
                        <li><a href="/returns" class="hover:text-brand transition-colors">Returns Policy</a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-4">Contact Info</h3>
                    <ul class="space-y-3 text-sm text-gray-600">
                        <li class="flex items-center gap-2"><span class="text-green-500 font-bold">WhatsApp:</span> 0816 280 9886</li>
                        <li><span class="font-bold text-gray-900">Hours:</span> Mon–Sat 8am–8pm</li>
                        <li class="mt-4 inline-flex items-center gap-2 bg-gray-50 px-3 py-2 rounded-lg border border-gray-200">
                            <span class="text-brand font-bold text-lg">🏦</span>
                            <span class="font-semibold text-xs text-gray-700">We accept Bank Transfer</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="border-t border-gray-100 pt-6 flex flex-col md:flex-row items-center justify-between gap-4 text-xs font-semibold text-gray-400">
                <p>© 2026 Victoria James Store. All rights reserved.</p>
                <p>Made in Nigeria 🇳🇬</p>
            </div>
        </div>
    </footer>

    <a href="https://wa.me/2348162809886" target="_blank" class="fixed bottom-6 right-6 z-50 group">
        <div class="absolute inset-0 bg-green-400 rounded-full animate-ping opacity-30"></div>
        <div class="relative w-14 h-14 bg-green-500 hover:bg-green-600 text-white rounded-full shadow-lg hover:shadow-xl flex items-center justify-center transition-all duration-200">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.183-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.765-5.77zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-3.825 3.113-6.937 6.937-6.937 3.825 0 6.938 3.112 6.938 6.937 0 3.825-3.113 6.938-6.938 6.938z" /></svg>
        </div>
    </a>
</div>

@code {
    private bool showAnnouncement = true;

    protected override async Task OnInitializedAsync()
    {
        // Check if user dismissed the bar previously
        var dismissed = await LocalStorage.GetItemAsync<bool>("hideAnnouncement");
        showAnnouncement = !dismissed;
    }

    private async Task DismissAnnouncement()
    {
        showAnnouncement = false;
        await LocalStorage.SetItemAsync("hideAnnouncement", true);
    }
}