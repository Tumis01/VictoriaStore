                    <svg class="w-6 h-6 group-hover:scale-110 group-hover:-translate-y-0.5 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    <span class="cart-badge absolute -top-2 -right-2.5 bg-tertiary group-hover:scale-110 transition-transform duration-300 text-white text-[10px] font-black rounded-full h-4.5 w-4.5 flex items-center justify-center shadow-sm">0</span>
                </div>
                <span class="hidden sm:block text-[9px] font-extrabold tracking-wider uppercase transition-colors duration-200">Cart</span>
            </a>
        </NotAuthorized>
    </AuthorizeView>

    <AuthorizeView>
        <Authorized>
            <a href="/account" class="flex flex-col items-center justify-center gap-1 w-14 h-14 text-outline hover:text-primary hover:bg-gray-50 active:scale-[0.96] rounded-2xl transition-all duration-200 group">
                <svg class="w-6 h-6 group-hover:scale-110 group-hover:-translate-y-0.5 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                <span class="hidden sm:block text-[9px] font-extrabold tracking-wider uppercase transition-colors duration-200">Profile</span>
            </a>
            <button @onclick="Logout" class="flex flex-col items-center justify-center gap-1 w-14 h-14 text-outline-variant hover:text-red-500 hover:bg-red-50 active:scale-[0.96] rounded-2xl transition-all duration-200 group">
                <svg class="w-6 h-6 group-hover:scale-110 group-hover:-translate-y-0.5 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                <span class="hidden sm:block text-[9px] font-extrabold tracking-wider uppercase transition-colors duration-200">Logout</span>
            </button>
        </Authorized>
        <NotAuthorized>
            <a href="/login" class="hidden sm:flex flex-col items-center justify-center gap-1 w-14 h-14 text-outline hover:text-primary hover:bg-gray-50 active:scale-[0.96] rounded-2xl transition-all duration-200 group">
                <svg class="w-6 h-6 group-hover:scale-110 group-hover:-translate-y-0.5 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path></svg>
                <span class="text-[9px] font-extrabold tracking-wider uppercase transition-colors duration-200">Sign In</span>
            </a>
        </NotAuthorized>
    </AuthorizeView>
</div>
        </div>
    </div>

    <div class="lg:hidden px-4 py-3 bg-surface-container-lowest shadow-sm">
        <div class="relative w-full max-w-md mx-auto">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-outline-variant pointer-events-none">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </span>
            <input type="search" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearchKey" placeholder="Search products…"
                   class="h-11 w-full pl-11 pr-14 rounded-xl text-[14px] font-medium placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/30 bg-surface-container-low shadow-inner transition-all"/>
            <button @onclick="PerformSearch" class="absolute right-1.5 top-1/2 -translate-y-1/2 h-8 px-4 bg-primary text-white text-xs font-bold rounded-lg hover:bg-primary-dark transition-colors shadow-sm active:scale-95">Search</button>
        </div>
    </div>

    <div class="hidden lg:block bg-surface-container-lowest shadow-sm z-30 relative">
        <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
            
            <div class="relative group/mega">
                <button @onclick="ToggleMegaMenu" 
                        class="flex items-center gap-3 bg-primary text-white text-[13.5px] font-bold px-6 py-4 rounded-xl border-none outline-none focus:outline-none focus:ring-2 focus:ring-primary/50 focus:ring-offset-2 hover:bg-primary-dark active:scale-[0.98] transition-all duration-200 relative overflow-hidden group">
        
                    <div class="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"></div>
        
                    <svg class="w-5 h-5 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg> 
        
                    <span class="relative z-10">All Categories</span> 
        
                    <svg class="w-5 h-5 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button> 

                @if (isMegaMenuOpen) { 
                    <div class="fixed inset-0 z-40 bg-gray-900/10 backdrop-blur-[2px]" @onclick="() => isMegaMenuOpen=false"></div> 
                    <div class="absolute top-[110%] left-0 w-[500px] bg-surface-container-lowest rounded-2xl shadow-2xl z-50 overflow-hidden transform origin-top animate-fade-in"> 
                        <div class="bg-gradient-to-r from-gray-50 to-white px-6 py-4 flex items-center justify-between shadow-sm"> 
                            <span class="text-on-surface font-extrabold text-[11px] tracking-[0.15em] uppercase">Browse Collections</span> 
                            <a href="/store" @onclick="() => isMegaMenuOpen=false" class="text-primary hover:text-primary-dark text-xs font-bold transition-colors inline-flex items-center gap-1 group/link"> 
                                View Full Store 
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                </svg> 
                            </a> 
                        </div> 
                        <div class="p-3 grid grid-cols-2 gap-2"> 
                            @foreach (var cat in _navCategories) { 
                                <a href="/category/@cat.Slug" @onclick="() => isMegaMenuOpen=false" class="flex items-center gap-3.5 px-4 py-3.5 rounded-xl hover:bg-surface-container-low hover:shadow-sm transition-all duration-200 group/item"> 
                                    <div class="w-10 h-10 rounded-lg bg-surface-container-lowest shadow-sm flex items-center justify-center text-primary flex-shrink-0 group-hover/item:shadow-md group-hover/item:scale-105 group-hover/item:bg-primary-light/20 transition-all duration-300"> 
                                        @GetCategorySvg(cat.Name) 
                                    </div> 
                                    <div class="flex-1 min-w-0"> 
                                        <p class="text-[13px] font-bold text-on-surface group-hover/item:text-primary truncate transition-colors">@cat.Name</p> 
                                    </div> 
                                    <svg class="w-5 h-5 text-outline-variant group-hover/item:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg> 
                                </a> 
                            } 
