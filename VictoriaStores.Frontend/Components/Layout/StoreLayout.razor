                <input type="search" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearchKey" placeholder="Search products…"
                       class="h-11 w-full pl-10 pr-4 rounded-2xl border border-outline-variant/30 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 bg-surface-container-low"/>
