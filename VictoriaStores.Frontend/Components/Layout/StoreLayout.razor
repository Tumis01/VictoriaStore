@code {
    private bool showAnnouncement = true;
    private bool isMegaMenuOpen   = false;
    private bool isMobileDrawerOpen = false;
    private string searchQuery    = "";
    private string searchCategory = "All";
    private List<CategoryDto> _navCategories = new();

    protected override async Task OnInitializedAsync()
    {
        var dismissed = await LocalStorage.GetItemAsync<bool>("hideAnnouncement");
        showAnnouncement = !dismissed;
        await LoadNavCategoriesAsync();
    }

    private async Task LoadNavCategoriesAsync()
    {
        try { _navCategories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/category") ?? new(); }
        catch (Exception ex) { Console.WriteLine($"[StoreLayout] Nav categories failed: {ex.Message}"); _navCategories = new(); }
    }

    private MarkupString GetCategorySvg(string name)
    {
        var lower = name.ToLower();
        
        // Kitchen / Utensils (Cooking Pot Icon)
        if (lower.Contains("kitchen") || lower.Contains("cook"))
            return (MarkupString)"<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4\"></path></svg>";
        
        // Fashion / Clothing (Shopping Bag)
        if (lower.Contains("fashion") || lower.Contains("wear"))
            return (MarkupString)"<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z\"></path></svg>";
        
        // Giftpacks (Gift Box)
        if (lower.Contains("gift"))
            return (MarkupString)"<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7\"></path></svg>";
        
        // Accessories (Tag)
        if (lower.Contains("accessor"))
            return (MarkupString)"<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z\"></path></svg>"; 
        // Household (House)
        if (lower.Contains("house") || lower.Contains("home"))
            return (MarkupString)"<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6\"></path></svg>";
        
        // Default Generic Category (Collection squares)
        return (MarkupString)"<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z\"></path></svg>";
    }

    private async Task DismissAnnouncement()
    {
        showAnnouncement = false;
        await LocalStorage.SetItemAsync("hideAnnouncement", true);
    }

    private void ToggleMegaMenu()     => isMegaMenuOpen     = !isMegaMenuOpen;
    private void ToggleMobileDrawer() => isMobileDrawerOpen = !isMobileDrawerOpen;
    private void HandleSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") PerformSearch(); }

    private void PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) return;
        var url = $"/search?q={Uri.EscapeDataString(searchQuery.Trim())}";
        if (searchCategory != "All") url += $"&cat={Uri.EscapeDataString(searchCategory)}";
        NavManager.NavigateTo(url);
        isMobileDrawerOpen = false;
        isMegaMenuOpen = false;
    }
    
    private async Task Logout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        isMobileDrawerOpen = false;
        NavManager.NavigateTo("/login", forceLoad: true);
    }
}