                        {
                            <option value="@cat.Slug">@cat.Name</option>
                        }
                    </select>
        
                    <div class="w-[1px] h-8 my-auto bg-gray-200"></div>
        
                    <input type="search" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearchKey" placeholder="Search for products, brands and more…" class="flex-1 h-[48px] px-5 text-[14px] text-on-surface placeholder-gray-400 border-none outline-none focus:outline-none focus:ring-0 bg-transparent font-medium" />
        
                    <button @onclick="PerformSearch" class="border-none outline-none focus:outline-none focus:ring-0 h-[48px] px-7 bg-primary text-white hover:bg-primary-dark transition-colors flex-shrink-0 flex items-center gap-2.5 font-bold text-sm active:bg-primary-dark active:scale-[0.98]">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
    Search
</button>
                </div>
            </div>

            <div class="flex items-center gap-1.5 sm:gap-3 ml-auto lg:ml-0">
    <a href="https://wa.me/2348162809886" target="_blank" rel="noopener noreferrer" class="hidden sm:flex flex-col items-center justify-center gap-1 w-14 h-14 text-green-600 hover:text-green-700 hover:bg-green-50 active:scale-[0.96] rounded-2xl transition-all duration-200 group">
        <svg class="w-6 h-6 group-hover:scale-110 group-hover:-translate-y-0.5 transition-all duration-300" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span class="text-[9px] font-extrabold tracking-wider uppercase transition-colors duration-200">Chat</span>
    </a>

    <AuthorizeView>
        <Authorized>
            <a href="/cart" class="relative flex flex-col items-center justify-center gap-1 w-14 h-14 text-outline hover:text-primary hover:bg-gray-50 active:scale-[0.96] rounded-2xl transition-all duration-200 group ml-1">
                <div class="relative">
                    <svg class="w-6 h-6 group-hover:scale-110 group-hover:-translate-y-0.5 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
