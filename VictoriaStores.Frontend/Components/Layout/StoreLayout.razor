@inherits LayoutComponentBase
@inject VictoriaStores.Frontend.Services.CartService CartService

<div class="bg-gray-900 text-white py-2 hidden sm:block">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center text-xs font-medium">
        <div class="flex items-center gap-4">
            <span>Free WhatsApp support</span>
            <span class="text-gray-500">|</span>
            <span>Call 08162809886</span>
            <span class="text-gray-500">|</span>
            <span>Fast delivery across Nigeria 🇳🇬</span>
        </div>
        <div class="flex items-center gap-4">
            <a href="/track" class="hover:text-brand-light transition-colors">Order Tracking</a>
            <span class="text-gray-500">|</span>
            <a href="/admin/login" class="text-brand-light font-bold hover:text-white transition-colors">Admin Login</a>
        </div>
    </div>
</div>

<header class="bg-white border-b border-gray-100 sticky top-0 z-40 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="flex items-center justify-between gap-8">
            
            <a href="/" class="flex items-center gap-3 flex-shrink-0">
                <div class="w-10 h-10 rounded-lg bg-brand flex items-center justify-center text-white font-black text-xl shadow-md">VJ</div>
                <div class="hidden sm:block">
                    <div class="font-bold text-gray-900 tracking-wide text-lg font-serif leading-none">Victoria James</div>
                    <div class="text-brand text-sm font-semibold tracking-wider">Store</div>
                </div>
            </a>

            <div class="hidden md:flex flex-1 max-w-2xl relative">
                <select class="absolute left-0 top-0 h-11 bg-gray-50 border border-gray-300 rounded-l-lg px-4 text-sm font-medium text-gray-700 focus:outline-none focus:ring-2 focus:ring-brand border-r-0 z-10">
                    <option>All Categories</option>
                    <option>Household Items</option>
                    <option>Kitchen Utensils</option>
                    <option>Fashion</option>
                </select>
                <input type="text" placeholder="Search for products..." class="h-11 w-full pl-44 pr-12 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent" />
                <button class="absolute right-0 top-0 h-11 w-12 bg-brand text-white rounded-r-lg hover:bg-brand-dark flex items-center justify-center transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </div>

            <div class="flex items-center gap-5 flex-shrink-0">
                <a href="/login" class="hidden sm:flex items-center gap-2 text-gray-700 hover:text-brand transition-colors font-semibold text-sm">
                    <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                    Sign In
                </a>
                <a href="/cart" class="relative text-gray-700 hover:text-brand transition-colors flex items-center gap-2">
                    <div class="relative">
                        <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        <span class="absolute -top-2 -right-2 bg-accent text-white text-[10px] font-bold h-4 w-4 flex items-center justify-center rounded-full">@cartItemCount</span>
                    </div>
                    <span class="font-semibold text-sm hidden sm:block">Cart</span>
                </a>
            </div>
        </div>
    </div>
</header>

<nav class="bg-white border-b border-gray-200 hidden lg:block shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <ul class="flex items-center gap-8 text-sm font-bold text-gray-700">
            <li>
                <button class="bg-brand text-white px-6 py-3 flex items-center gap-2 hover:bg-brand-dark transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                    Browse Categories
                </button>
            </li>
            <li><a href="/" class="text-brand hover:text-brand-dark">Home</a></li>
            <li><a href="/category/household" class="hover:text-brand transition-colors">Household Items</a></li>
            <li><a href="/category/kitchen" class="hover:text-brand transition-colors">Kitchen Utensils</a></li>
            <li><a href="/category/fashion" class="hover:text-brand transition-colors">Fashion & Giftpacks</a></li>
            <li><a href="/category/accessories" class="hover:text-brand transition-colors">Accessories</a></li>
            <li class="ml-auto text-accent flex items-center gap-1">
                <span>🔥</span> Trending Deals
            </li>
        </ul>
    </div>
</nav>

<main class="min-h-screen bg-gray-50 pb-12">
    @Body
</main>

@code {
    private int cartItemCount = 0;

    protected override void OnInitialized()
    {
        CartService.OnCartChanged += UpdateCartCount;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadCartCount();
            StateHasChanged();
        }
    }

    private async void UpdateCartCount()
    {
        await LoadCartCount();
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadCartCount()
    {
        var cart = await CartService.GetCartAsync();
        cartItemCount = cart.Sum(i => i.Quantity);
    }

    public void Dispose()
    {
        CartService.OnCartChanged -= UpdateCartCount;
    }
}