            <a href="/" @onclick="ToggleMobileDrawer" class="flex items-center gap-2.5">
                <div class="w-9 h-9 rounded-xl bg-surface-container-lowest/20 border border-white/30 text-white font-black text-base flex items-center justify-center">VJ</div>
                <div>
                    <p class="font-serif font-bold text-white text-sm leading-none">Victoria James</p>
                    <p class="text-white/60 text-[10px] font-bold tracking-widest uppercase mt-0.5">Store</p>
