@inherits LayoutComponentBase
@inject NavigationManager NavManager

<AuthorizeView Roles="SuperAdmin">
    <Authorized>
        <div class="flex h-screen bg-gray-50 font-sans text-gray-900 overflow-hidden">
            
            @if (isSidebarOpen)
            {
                <div class="fixed inset-0 bg-black/50 z-40 md:hidden" @onclick="ToggleSidebar"></div>
            }

            <aside class="@(isSidebarOpen ? "translate-x-0" : "-translate-x-full") md:translate-x-0 fixed md:static inset-y-0 left-0 z-50 flex w-64 flex-col bg-gray-900 text-white shadow-xl transition-transform duration-300 h-full flex-shrink-0">
                
                <div class="p-6">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg bg-brand flex items-center justify-center text-white font-black text-xl shadow-lg">
                            VJ
                        </div>
                        <div>
                            <div class="font-bold text-white tracking-wide text-lg font-serif">Victoria James</div>
                            <div class="text-brand text-xs font-semibold tracking-wider uppercase">Admin Panel</div>
                        </div>
                    </div>
                    <div class="border-b border-gray-800 mt-6"></div>
                </div>
                
                <nav class="flex-1 space-y-1 overflow-y-auto px-3 pb-6 custom-scrollbar">
                    <p class="text-gray-500 text-xs font-bold uppercase tracking-widest px-3 mt-2 mb-3">Main</p>
                    
                    <NavLink href="/admin" Match="NavLinkMatch.All" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white transition-colors duration-150 text-sm font-medium group" ActiveClass="bg-brand/20 text-white font-semibold">
                        <svg class="w-5 h-5 text-gray-500 group-[.bg-brand\/20]:text-brand group-hover:text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                        Dashboard
                    </NavLink>
                    
                    <NavLink href="/admin/orders" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white transition-colors duration-150 text-sm font-medium group" ActiveClass="bg-brand/20 text-white font-semibold">
                        <svg class="w-5 h-5 text-gray-500 group-[.bg-brand\/20]:text-brand group-hover:text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        Orders
                    </NavLink>

                    <NavLink href="/admin/products" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white transition-colors duration-150 text-sm font-medium group" ActiveClass="bg-brand/20 text-white font-semibold">
                        <svg class="w-5 h-5 text-gray-500 group-[.bg-brand\/20]:text-brand group-hover:text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                        Products
                    </NavLink>

                    <NavLink href="/admin/categories" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white transition-colors duration-150 text-sm font-medium group" ActiveClass="bg-brand/20 text-white font-semibold">
                        <svg class="w-5 h-5 text-gray-500 group-[.bg-brand\/20]:text-brand group-hover:text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
                        Categories
                    </NavLink>

                    <NavLink href="/admin/customers" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white transition-colors duration-150 text-sm font-medium group" ActiveClass="bg-brand/20 text-white font-semibold">
                        <svg class="w-5 h-5 text-gray-500 group-[.bg-brand\/20]:text-brand group-hover:text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                        Customers
                    </NavLink>

                    <p class="text-gray-500 text-xs font-bold uppercase tracking-widest px-3 mt-8 mb-3">Settings</p>
                    
                    <NavLink href="/admin/settings" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white transition-colors duration-150 text-sm font-medium group" ActiveClass="bg-brand/20 text-white font-semibold">
                        <svg class="w-5 h-5 text-gray-500 group-[.bg-brand\/20]:text-brand group-hover:text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        Store Settings
                    </NavLink>
                </nav>
                
                <div class="border-t border-gray-800 p-4">
                    <button @onclick="Logout" class="flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-red-400 transition-colors hover:bg-gray-800 hover:text-red-300">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                        <span class="font-medium text-sm">Logout</span>
                    </button>
                </div>
            </aside>

            <div class="flex flex-1 flex-col overflow-hidden w-full">
                
                <header class="flex h-16 items-center justify-between border-b bg-white px-4 sm:px-8 shadow-sm z-30">
                    <div class="flex items-center gap-4">
                        <button @onclick="ToggleSidebar" class="md:hidden text-gray-500 hover:text-brand focus:outline-none">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                        </button>
                    </div>
                    
                    <div class="flex items-center space-x-5">
                        <button class="text-gray-400 hover:text-brand transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </button>
                        
                        <div class="relative">
                            <button @onclick="ToggleNotifications" @onclick:stopPropagation="true" class="text-gray-400 hover:text-brand transition-colors relative focus:outline-none">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                                <span class="absolute -top-1 -right-1 flex h-3 w-3 items-center justify-center rounded-full bg-accent text-[8px] text-white font-bold ring-2 ring-white">3</span>
                            </button>

                            @if (showNotifications)
                            {
                                <div class="absolute right-0 mt-3 w-80 bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden z-50 animate-fade-in" @onclick:stopPropagation="true">
                                    <div class="px-4 py-3 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
                                        <h3 class="font-bold text-gray-900 text-sm">Notifications</h3>
                                        <button class="text-xs font-semibold text-brand hover:underline">Mark all read</button>
                                    </div>
                                    <div class="max-h-72 overflow-y-auto">
                                        <div class="p-4 border-b border-gray-50 hover:bg-gray-50 cursor-pointer block bg-brand-light/20">
                                            <div class="flex items-start gap-3">
                                                <div class="bg-brand text-white rounded-full p-1.5 mt-0.5">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                                                </div>
                                                <div>
                                                    <p class="text-sm font-bold text-gray-900">New Order #VJ-0098</p>
                                                    <p class="text-xs text-gray-500 mt-0.5">Chioma placed an order for ₦45,000.</p>
                                                    <p class="text-[10px] text-gray-400 font-semibold mt-1">10 minutes ago</p>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Other static items can be added here -->
                                        <div class="p-4 border-b border-gray-50 hover:bg-gray-50 cursor-pointer block">
                                            <div class="flex items-start gap-3">
                                                <div class="bg-green-500 text-white rounded-full p-1.5 mt-0.5">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                                </div>
                                                <div>
                                                    <p class="text-sm font-bold text-gray-900">Payment Confirmed</p>
                                                    <p class="text-xs text-gray-500 mt-0.5">Payment for #VJ-0097 was successful.</p>
                                                    <p class="text-[10px] text-gray-400 font-semibold mt-1">2 hours ago</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="px-4 py-3 border-t border-gray-100 text-center">
                                        <button class="text-xs font-bold text-gray-600 hover:text-brand transition-colors">View all notifications</button>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="h-6 w-px bg-gray-200"></div>

                        <div class="flex items-center space-x-3 cursor-pointer group">
                            <div class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-light text-sm font-bold text-brand-dark ring-2 ring-transparent group-hover:ring-brand-light transition-all">
                                VJ
                            </div>
                            <div class="hidden sm:block text-left">
                                <div class="text-sm font-bold text-gray-700 leading-none">Victoria James</div>
                                <div class="text-[11px] font-medium text-gray-500 mt-1">Super Admin</div>
                            </div>
                        </div>
                    </div>
                </header>

                <main class="flex-1 overflow-y-auto bg-gray-50 p-4 sm:p-8" @onclick="() => showNotifications = false">
                    @Body
                </main>
                
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="flex min-h-screen items-center justify-center bg-gray-50 px-4 py-12 sm:px-6 lg:px-8">
            <div class="w-full max-w-md space-y-8 text-center bg-white p-10 rounded-2xl shadow-xl border border-gray-100">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-red-100">
                    <svg class="h-8 w-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                </div>
                <h2 class="mt-4 text-3xl font-bold text-gray-900 font-serif">Access Denied</h2>
                <p class="text-sm text-gray-500">
                    You must be logged in as an Administrator to view this console.
                </p>
                <div class="pt-4">
                    <a href="/admin/login" class="inline-flex w-full items-center justify-center rounded-lg bg-brand px-4 py-3 text-sm font-bold text-white shadow-sm hover:bg-brand-dark transition-colors">
                        Go to Login
                    </a>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

<ToastContainer />

@code {
    @inject AuthenticationStateProvider AuthStateProvider
    private bool isSidebarOpen = false;
    private bool showNotifications = false;

    private void ToggleSidebar()
    {
        isSidebarOpen = !isSidebarOpen;
    }

    private void ToggleNotifications()
    {
        showNotifications = !showNotifications;
    }

    protected override void OnInitialized()
    {
        NavManager.LocationChanged += (s, e) =>
        {
            if (isSidebarOpen)
            {
                isSidebarOpen = false;
                InvokeAsync(StateHasChanged);
            }
        };
    }

    private async Task Logout()
    {
        var authProvider = (JwtAuthenticationStateProvider)AuthStateProvider;
        await authProvider.MarkUserAsLoggedOut();
        NavManager.NavigateTo("/admin/login", forceLoad: true);
    }
}