@inherits LayoutComponentBase
@inject NavigationManager NavManager
@using Microsoft.AspNetCore.Components.Authorization

<style>
    a,a:hover,a:visited,a:active,a:focus{text-decoration:none!important}
    .nav-item.active { background:rgba(26,86,219,.15); color:#fff; }
    .nav-item.active svg { color:#1A56DB; }
    @@keyframes slideIn{from{transform:translateX(-100%)}to{transform:translateX(0)}}
    .sidebar-enter{animation:slideIn .22s ease-out forwards}
</style>

<div class="min-h-screen bg-gray-100 font-sans flex">

    <!-- ══════════ DESKTOP SIDEBAR ══════════════════════════════════ -->
    <aside class="hidden lg:flex flex-col w-64 bg-gray-900 fixed inset-y-0 left-0 z-30 overflow-y-auto">

        <!-- Logo -->
        <div class="flex items-center gap-3 px-5 py-5 border-b border-gray-800">
            <div class="bg-brand rounded-xl w-10 h-10 text-white font-black text-xl flex items-center justify-center flex-shrink-0">VJ</div>
            <div class="leading-tight">
                <p class="font-serif font-bold text-white text-[15px]">Victoria James</p>
                <p class="text-brand text-xs font-bold">Admin Panel</p>
            </div>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-4 space-y-0.5">
            <p class="text-[10px] font-extrabold uppercase tracking-widest text-gray-500 px-3 mb-2 mt-1">Main</p>

            <NavItem Href="/admin/dashboard" Icon="dashboard" Label="Dashboard">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            </NavItem>

            <NavItem Href="/admin/orders" Label="Orders">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
            </NavItem>

            <NavItem Href="/admin/products" Label="Products">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            </NavItem>

            <NavItem Href="/admin/categories" Label="Categories">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            </NavItem>

            <NavItem Href="/admin/customers" Label="Customers">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </NavItem>

            <p class="text-[10px] font-extrabold uppercase tracking-widest text-gray-500 px-3 mb-2 mt-5">Store</p>

            <NavItem Href="/admin/settings" Label="Store Settings">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </NavItem>

            <NavItem Href="/admin/notifications" Label="Notifications">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
            </NavItem>

            <NavItem Href="/admin/reports" Label="Reports">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </NavItem>

            <p class="text-[10px] font-extrabold uppercase tracking-widest text-gray-500 px-3 mb-2 mt-5">Account</p>

            <NavItem Href="/admin/profile" Label="My Profile">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </NavItem>
        </nav>

        <!-- Admin footer -->
        <div class="border-t border-gray-800 px-4 py-4">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 bg-brand rounded-full flex items-center justify-center text-white font-extrabold text-sm flex-shrink-0">VJ</div>
                <div class="min-w-0">
                    <p class="text-white text-sm font-bold truncate">Victoria James</p>
                    <p class="text-gray-500 text-xs">Super Admin</p>
                </div>
            </div>
            <a href="/admin/logout"
               class="flex items-center gap-2 text-gray-500 hover:text-red-400 text-xs font-semibold transition-colors w-full py-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                Sign Out
            </a>
        </div>
    </aside>

    <!-- ══════════ MOBILE SIDEBAR ═══════════════════════════════════ -->
    @if (isMobileNavOpen)
    {
        <div class="fixed inset-0 bg-black/50 z-40 lg:hidden" @onclick="() => isMobileNavOpen = false"></div>
        <aside class="fixed inset-y-0 left-0 w-64 bg-gray-900 z-50 flex flex-col sidebar-enter lg:hidden overflow-y-auto">
            <div class="flex items-center justify-between px-5 py-5 border-b border-gray-800">
                <div class="flex items-center gap-3">
                    <div class="bg-brand rounded-xl w-9 h-9 text-white font-black text-lg flex items-center justify-center">VJ</div>
                    <div><p class="font-serif font-bold text-white text-sm">Victoria James</p><p class="text-brand text-xs font-bold">Admin Panel</p></div>
                </div>
                <button @onclick="() => isMobileNavOpen = false" class="p-1.5 text-gray-400 hover:text-white rounded-lg hover:bg-gray-800 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
                @MobileNavItem("/admin/dashboard",    "Dashboard",      "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6")
                @MobileNavItem("/admin/orders",       "Orders",         "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01")
                @MobileNavItem("/admin/products",     "Products",       "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4")
                @MobileNavItem("/admin/categories",   "Categories",     "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10")
                @MobileNavItem("/admin/customers",    "Customers",      "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z")
                @MobileNavItem("/admin/settings",     "Settings",       "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z")
            </nav>
        </aside>
    }

    <!-- ══════════ MAIN CONTENT ═════════════════════════════════════ -->
    <div class="flex-1 flex flex-col lg:ml-64 min-w-0">

        <!-- Top Bar -->
        <header class="bg-white border-b border-gray-200 px-4 sm:px-6 py-0 h-16 flex items-center justify-between sticky top-0 z-20 shadow-sm">
            <div class="flex items-center gap-4">
                <!-- Mobile hamburger -->
                <button class="lg:hidden p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors"
                        @onclick="() => isMobileNavOpen = true" aria-label="Open sidebar">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
                <!-- Page heading is supplied by each child page via the layout cascade -->
                <div>
                    <p class="font-bold text-gray-900 text-base leading-tight">Admin Panel</p>
                    <p class="text-xs text-gray-400">Victoria James Store</p>
                </div>
            </div>

            <div class="flex items-center gap-3">
                <!-- View store link -->
                <a href="/" target="_blank"
                   class="hidden sm:inline-flex items-center gap-1.5 text-xs font-semibold text-gray-500
                          hover:text-brand transition-colors border border-gray-200 px-3 py-1.5 rounded-lg
                          hover:border-brand bg-white">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    View Store
                </a>

                <!-- Notification bell -->
                <button class="relative p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-xl transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                    <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full ring-2 ring-white"></span>
                </button>

                <!-- Admin avatar -->
                <a href="/admin/profile"
                   class="flex items-center gap-2.5 group">
                    <div class="w-8 h-8 bg-brand rounded-full flex items-center justify-center text-white font-extrabold text-xs">VJ</div>
                    <div class="hidden sm:block leading-tight">
                        <p class="text-sm font-bold text-gray-800 group-hover:text-brand transition-colors">Victoria James</p>
                        <p class="text-xs text-gray-400">Super Admin</p>
                    </div>
                </a>
            </div>
        </header>

        <!-- Page content -->
        <main class="flex-1 p-4 sm:p-6 lg:p-8 min-w-0">
            @Body
        </main>
    </div>
</div>

@code {
    private bool isMobileNavOpen = false;

    // Helper render fragment for desktop nav items
    private RenderFragment NavItem(string href, string label, RenderFragment icon) => __builder =>
    {
        var isActive = NavManager.Uri.Contains(href, StringComparison.OrdinalIgnoreCase);
        <a href="@href" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors
                               @(isActive ? "bg-brand/15 text-white" : "text-gray-400 hover:bg-gray-800 hover:text-white")">
            <span class="@(isActive ? "text-brand" : "text-gray-500")">@icon</span>
            @label
        </a>
    };

    private RenderFragment MobileNavItem(string href, string label, string svgPath) => __builder =>
    {
        var isActive = NavManager.Uri.Contains(href, StringComparison.OrdinalIgnoreCase);
        <a href="@href" @onclick="() => isMobileNavOpen = false"
           class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors
                  @(isActive ? "bg-brand/15 text-white" : "text-gray-400 hover:bg-gray-800 hover:text-white")">
            <svg class="w-5 h-5 @(isActive ? "text-brand" : "text-gray-500")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@svgPath"/>
            </svg>
            @label
        </a>
    };
}
