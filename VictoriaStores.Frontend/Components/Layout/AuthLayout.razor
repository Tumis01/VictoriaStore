@inherits LayoutComponentBase

<div class="min-h-screen bg-surface-container-lowest sm:bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md text-center mb-6 animate-fade-in">
        <a href="/" class="inline-block group">
            <h1 class="font-serif text-3xl md:text-4xl font-extrabold text-primary tracking-tight group-hover:opacity-80 transition-opacity">
                Victoria James
            </h1>
            <span class="block text-xs font-bold text-outline tracking-widest uppercase mt-1">Store</span>
