<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Victoria James Store — Your trusted Nigerian store for affordable household items, kitchen utensils, fashion, accessories, and beauty products. Fast nationwide delivery." />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["VictoriaStores.Frontend.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />

    <!-- Google Fonts: Plus Jakarta Sans (body), Newsreader (headings) & Material Symbols -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)" />

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "inverse-primary": "#b5c4ff",
                        "secondary-container": "#b1c2ff",
                        "on-background": "#141b2b",
                        "on-tertiary": "#ffffff",
                        "on-surface-variant": "#434654",
                        "background": "#f9f9ff",
                        "surface-tint": "#1353d8",
                        "primary-container": "#1a56db",
                        "inverse-on-surface": "#edf0ff",
                        "on-primary-fixed": "#00174d",
                        "on-primary-fixed-variant": "#003dab",
                        "on-secondary-fixed-variant": "#334479",
                        "surface-container-high": "#e1e8fd",
                        "tertiary": "#F97316",
                        "surface-bright": "#f9f9ff",
                        "on-error-container": "#93000a",
                        "on-primary": "#ffffff",
                        "primary-fixed": "#dbe1ff",
                        "surface-variant": "#dce2f7",
                        "primary-fixed-dim": "#b5c4ff",
                        "on-secondary-fixed": "#01174b",
                        "on-secondary": "#ffffff",
                        "on-surface": "#141b2b",
                        "on-secondary-container": "#3d4e84",
                        "on-primary-container": "#d4dcff",
                        "outline": "#737686",
                        "surface": "#f9f9ff",
                        "error": "#ba1a1a",
                        "secondary-fixed": "#dbe1ff",
                        "primary": "#003fb1",
                        "secondary-fixed-dim": "#b5c4ff",
                        "inverse-surface": "#293040",
                        "secondary": "#4b5c92",
                        "surface-container-highest": "#dce2f7",
                        "tertiary-fixed": "#ffdbca",
                        "on-tertiary-fixed": "#341100",
                        "outline-variant": "#c3c5d7",
                        "tertiary-fixed-dim": "#ffb690",
                        "on-tertiary-fixed-variant": "#783200",
                        "on-tertiary-container": "#ffd4bf",
                        "surface-container": "#e9edff",
                        "on-error": "#ffffff",
                        "tertiary-container": "#EA580C",
                        "error-container": "#ffdad6",
                        "surface-container-low": "#f1f3ff",
                        "surface-dim": "#d3daef",
                        "surface-container-lowest": "#ffffff"
                    },
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'system-ui', 'sans-serif'],
                        serif: ['Newsreader', 'Georgia', 'serif'],
                        headline: ['Newsreader', 'serif'],
                        body: ['"Plus Jakarta Sans"', 'sans-serif'],
                        label: ['"Plus Jakarta Sans"', 'sans-serif']
                    }
                }
            },
            corePlugins: {
                preflight: false,
            }
        }
    </script>
    

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f9f9ff; color: #141b2b; }
        h1, h2, h3, h4, h5, h6, .font-serif { font-family: 'Newsreader', serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .material-symbols-outlined.fill { font-variation-settings: 'FILL' 1; }
    </style>
</head>
<body class="bg-surface text-on-surface antialiased min-h-screen flex flex-col font-body">
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    window.renderDashboardChart = (canvasId, labels, data) => {
        const ctx = document.getElementById(canvasId);
        if (!ctx) return;
        
        if (window.dashboardChart) {
            window.dashboardChart.destroy();
        }
        
        window.dashboardChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Revenue (₦)',
                    data: data,
                    borderColor: '#1A56DB',
                    backgroundColor: 'rgba(26, 86, 219, 0.1)',
                    fill: true,
                    tension: 0.4,
                    borderWidth: 2,
                    pointRadius: 3,
                    pointBackgroundColor: '#1A56DB'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    };
</script>
</body>
</html>