@page "/admin/customers"
@layout Layout.AdminLayout
@inject HttpClient Http
@inject NavigationManager NavManager
@using System.Net.Http.Json
@using System.Linq
@using VictoriaStores.Frontend.Models

<PageTitle>Customers - Victoria Admin</PageTitle>

<div class="flex flex-col gap-4 mb-6 lg:flex-row lg:items-center lg:justify-between">
    <div>
        <h1 class="text-2xl font-bold text-on-surface font-serif">Customers</h1>
        <p class="text-sm text-outline mt-0.5">Manage your registered customers and view their order history.</p>
    </div>
    <button class="h-10 px-4 bg-surface-container-lowest text-on-surface-variant font-semibold text-sm rounded-lg hover:bg-surface-container-low transition-colors shadow-sm flex items-center gap-2 w-full sm:w-auto justify-center">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
        Export CSV
    </button>
</div>

<div class="bg-surface-container-lowest rounded-t-xl border border-outline-variant/30 border-b-0 p-4 flex gap-4 items-center shadow-sm">
    <div class="relative w-full sm:w-96">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">search</span>
        <input type="text" @bind="SearchTerm" @bind:event="oninput" placeholder="Search by name, email, or phone..." class="h-10 w-full pl-10 pr-4 rounded-lg border border-outline-variant/50 text-sm focus:outline-none focus:ring-2 focus:ring-primary transition-colors" />
    </div>
</div>

<div class="bg-surface-container-lowest rounded-b-xl border border-outline-variant/30 shadow-sm overflow-hidden mb-8 flex flex-col">
    <div class="overflow-x-auto flex-1">
        <table class="min-w-full text-sm text-left">
            <thead class="bg-surface-container-low border-b border-outline-variant/30">
                <tr>
                    <th class="px-5 py-3 text-xs font-bold text-outline uppercase tracking-wider w-16">S/N</th>
                    <th class="px-5 py-3 text-xs font-bold text-outline uppercase tracking-wider">Customer Info</th>
                    <th class="px-5 py-3 text-xs font-bold text-outline uppercase tracking-wider text-center">Orders</th>
                    <th class="px-5 py-3 text-xs font-bold text-outline uppercase tracking-wider text-right">Total Spent</th>
                    <th class="px-5 py-3 text-xs font-bold text-outline uppercase tracking-wider">Joined Date</th>
                    <th class="px-5 py-3 text-xs font-bold text-outline uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (isLoading)
                {
                    <tr>
                        <td colspan="6" class="px-5 py-12 text-center">
                            <svg class="animate-spin h-8 w-8 text-primary mx-auto" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        </td>
                    </tr>
                }
                else if (!FilteredCustomers.Any())
                {
                    <tr><td colspan="6" class="px-5 py-12 text-center text-outline">No customers found.</td></tr>
                }
                else
                {
                    int index = (currentPage - 1) * pageSize + 1;
                    @foreach (var customer in PaginatedCustomers)
                    {
                        var isExpanded = expandedCustomerId == customer.Id;

                        <tr class="hover:bg-surface-container-low transition-colors cursor-pointer group @(isExpanded ? "bg-primary-light/20" : "bg-surface-container-lowest")" @onclick="() => ToggleRow(customer.Id)">
                            <td class="px-5 py-4 text-sm font-semibold text-outline-variant">@(index++)</td>
                            <td class="px-5 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="h-10 w-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold text-sm">
                                        @GetInitials(customer.Name)
                                    </div>
                                    <div>
                                        <div class="font-bold text-on-surface group-hover:text-primary transition-colors">@customer.Name</div>
                                        <div class="text-xs text-outline flex flex-wrap gap-2 mt-0.5">
                                            <span>@customer.Phone</span>
                                            <span class="text-gray-300">|</span>
                                            <span>@customer.Email</span>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-5 py-4 text-center font-bold text-on-surface-variant">@customer.OrdersCount</td>
                            <td class="px-5 py-4 text-right font-extrabold text-primary">₦@customer.TotalSpent.ToString("N0")</td>
                            <td class="px-5 py-4 text-on-surface-variant">@customer.JoinedDate.ToString("dd MMM yyyy")</td>
                            <td class="px-5 py-4 text-right">
                                <button type="button" class="text-outline-variant group-hover:text-primary transition-colors transform duration-200 @(isExpanded ? "rotate-180" : "")">
                                    <span class="material-symbols-outlined text-[20px]">expand_more</span>
                                </button>
                            </td>
                        </tr>

                        @if (isExpanded)
                        {
                            <tr class="bg-surface-container-low/50 border-b border-outline-variant/30">
                                <td colspan="6" class="px-4 sm:px-8 py-6">
                                    <div class="grid grid-cols-1 xl:grid-cols-[340px,minmax(0,1fr)] gap-6">
                                        <div class="rounded-2xl bg-surface-container-lowest border border-outline-variant/20 p-5 shadow-sm">
                                            <h4 class="text-xs font-bold text-outline uppercase tracking-widest mb-4">Customer Orders</h4>

                                            @if (customer.RecentOrders.Any())
                                            {
                                                <div class="space-y-4">
                                                    <select class="h-11 w-full rounded-xl border border-outline-variant/40 px-4 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                                                            value="@GetSelectedOrderValue(customer.Id)"
                                                            @onchange="(e) => OnOrderChanged(customer.Id, e.Value?.ToString())">
                                                        <option value="">Select an order</option>
                                                        @foreach (var order in customer.RecentOrders.OrderByDescending(o => o.CreatedAt))
                                                        {
                                                            <option value="@order.Id">@order.OrderNumber - @order.CreatedAt.ToString("dd MMM yyyy")</option>
                                                        }
                                                    </select>

                                                    <button type="button"
                                                            @onclick="() => ViewCustomerOrder(customer.Id)"
                                                            disabled="@(!selectedOrderIds.ContainsKey(customer.Id) || selectedOrderIds[customer.Id] == null || isLoadingOrderDetails)"
                                                            class="h-11 w-full rounded-xl bg-primary text-white font-semibold shadow-sm hover:bg-primary-dark transition-colors disabled:bg-gray-400">
                                                        @(isLoadingOrderDetails && loadingCustomerId == customer.Id ? "Loading..." : "View Order Details")
                                                    </button>

                                                    @if (!string.IsNullOrWhiteSpace(orderError) && loadingCustomerId == customer.Id)
                                                    {
                                                        <div class="rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3">
                                                            @orderError
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <p class="text-sm text-outline italic">No orders found for this customer.</p>
                                            }
                                        </div>

                                        <div class="rounded-2xl bg-surface-container-lowest border border-outline-variant/20 p-5 shadow-sm">
                                            @if (selectedOrderDetails != null && selectedOrderCustomerId == customer.Id)
                                            {
                                                <div class="flex flex-col gap-5">
                                                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                                                        <div>
                                                            <h4 class="text-xl font-bold text-on-surface">Order #@selectedOrderDetails.OrderNumber</h4>
                                                            <p class="text-sm text-outline mt-1">@selectedOrderDetails.CreatedAt.ToString("dd MMM yyyy hh:mm tt")</p>
                                                        </div>
                                                        <div class="flex items-center gap-3">
                                                            <span class="@GetStatusBadgeClass(selectedOrderDetails.Status) px-3 py-1 rounded-full text-xs font-bold">@selectedOrderDetails.Status</span>
                                                            <button type="button" @onclick='() => NavManager.NavigateTo($"/admin/orders/{selectedOrderDetails.Id}")' class="h-10 px-4 rounded-xl bg-surface-container-low text-on-surface font-semibold hover:bg-surface-container transition-colors shadow-sm">
                                                                Open Full Page
                                                            </button>
                                                        </div>
                                                    </div>

                                                    <div class="space-y-3">
                                                        @foreach (var item in selectedOrderDetails.Items)
                                                        {
                                                            <div class="flex items-center justify-between gap-4 rounded-xl bg-surface-container-low p-4">
                                                                <div class="min-w-0">
                                                                    <p class="font-semibold text-on-surface truncate">@item.ProductName</p>
                                                                    <p class="text-xs text-outline mt-1">Qty: @item.Quantity × ₦@item.UnitPrice.ToString("N0")</p>
                                                                </div>
                                                                <p class="font-bold text-on-surface whitespace-nowrap">₦@((item.Quantity * item.UnitPrice).ToString("N0"))</p>
                                                            </div>
                                                        }
                                                    </div>

                                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                        <div class="rounded-xl bg-primary-light p-4">
                                                            <p class="text-xs uppercase tracking-[0.2em] text-outline">Total Amount</p>
                                                            <p class="text-2xl font-black text-primary mt-2">₦@selectedOrderDetails.TotalAmount.ToString("N0")</p>
                                                        </div>
                                                        <div class="rounded-xl bg-surface-container-low p-4">
                                                            <p class="text-xs uppercase tracking-[0.2em] text-outline">Status</p>
                                                            <p class="text-lg font-bold text-on-surface mt-2">@selectedOrderDetails.Status</p>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="h-full min-h-[240px] flex items-center justify-center text-center text-outline">
                                                    <div>
                                                        <span class="material-symbols-outlined text-[36px] mb-3">receipt_long</span>
                                                        <p class="font-semibold">Select an order and click "View Order Details".</p>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                }
            </tbody>
        </table>
    </div>

    @if (FilteredCustomers.Any())
    {
        <div class="px-5 py-4 border-t border-outline-variant/30 bg-surface-container-low flex flex-col sm:flex-row items-center justify-between gap-4">
            <span class="text-sm font-medium text-outline-variant">
                Showing @(((currentPage - 1) * pageSize) + 1) to @(Math.Min(currentPage * pageSize, FilteredCustomers.Count())) of @FilteredCustomers.Count() entries
            </span>
            <div class="flex flex-wrap gap-1.5 justify-center">
                <button @onclick="() => ChangePage(currentPage - 1)" disabled="@(currentPage == 1)" class="px-3 py-1.5 rounded-md bg-surface-container-lowest text-sm font-semibold text-on-surface-variant hover:bg-white disabled:opacity-50 disabled:cursor-not-allowed transition-colors">Prev</button>

                @for (int i = 1; i <= TotalPages; i++)
                {
                    int pageNum = i;
                    <button @onclick="() => ChangePage(pageNum)" class="px-3 py-1.5 rounded-md @(pageNum == currentPage ? "bg-primary text-white shadow-sm" : "bg-surface-container-lowest text-on-surface-variant hover:bg-white") text-sm font-semibold transition-colors">@pageNum</button>
                }

                <button @onclick="() => ChangePage(currentPage + 1)" disabled="@(currentPage == TotalPages)" class="px-3 py-1.5 rounded-md bg-surface-container-lowest text-sm font-semibold text-on-surface-variant hover:bg-white disabled:opacity-50 disabled:cursor-not-allowed transition-colors">Next</button>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool isLoadingOrderDetails = false;
    private List<CustomerDto> customers = new();
    private Guid? expandedCustomerId = null;

    private OrderDto? selectedOrderDetails;
    private Guid? selectedOrderCustomerId;
    private Guid? loadingCustomerId;
    private string? orderError;

    private readonly Dictionary<Guid, Guid?> selectedOrderIds = new();

    private int currentPage = 1;
    private int pageSize = 10;

    private string _searchTerm = string.Empty;
    private string SearchTerm
    {
        get => _searchTerm;
        set
        {
            if (_searchTerm != value)
            {
                _searchTerm = value;
                currentPage = 1;
                expandedCustomerId = null;
                selectedOrderDetails = null;
                selectedOrderCustomerId = null;
            }
        }
    }

    private IEnumerable<CustomerDto> FilteredCustomers => customers.Where(c =>
        string.IsNullOrWhiteSpace(_searchTerm) ||
        c.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
        c.Email.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
        c.Phone.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
    );

    private int TotalPages => (int)Math.Ceiling((double)FilteredCustomers.Count() / pageSize);
    private IEnumerable<CustomerDto> PaginatedCustomers => FilteredCustomers
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            customers = await Http.GetFromJsonAsync<List<CustomerDto>>("api/customer") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading customers: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            currentPage = page;
            expandedCustomerId = null;
            selectedOrderDetails = null;
            selectedOrderCustomerId = null;
        }
    }

    private void ToggleRow(Guid customerId)
    {
        if (expandedCustomerId == customerId)
        {
            expandedCustomerId = null;
            selectedOrderDetails = null;
            selectedOrderCustomerId = null;
            return;
        }

        expandedCustomerId = customerId;
        orderError = null;
        selectedOrderDetails = null;
        selectedOrderCustomerId = null;

        if (!selectedOrderIds.ContainsKey(customerId))
        {
            selectedOrderIds[customerId] = null;
        }
    }

    private void OnOrderChanged(Guid customerId, string? selectedValue)
    {
        orderError = null;

        if (Guid.TryParse(selectedValue, out var orderId))
        {
            selectedOrderIds[customerId] = orderId;
        }
        else
        {
            selectedOrderIds[customerId] = null;
        }
    }

    private string GetSelectedOrderValue(Guid customerId)
    {
        return selectedOrderIds.TryGetValue(customerId, out var orderId) && orderId.HasValue
            ? orderId.Value.ToString()
            : string.Empty;
    }

    private async Task ViewCustomerOrder(Guid customerId)
    {
        if (!selectedOrderIds.TryGetValue(customerId, out var orderId) || !orderId.HasValue)
            return;

        isLoadingOrderDetails = true;
        loadingCustomerId = customerId;
        orderError = null;

        try
        {
            selectedOrderDetails = await Http.GetFromJsonAsync<OrderDto>($"api/order/{orderId.Value}");
            selectedOrderCustomerId = customerId;
        }
        catch (Exception ex)
        {
            selectedOrderDetails = null;
            selectedOrderCustomerId = null;
            orderError = "Could not load this order. " + ex.Message;
        }
        finally
        {
            isLoadingOrderDetails = false;
            loadingCustomerId = null;
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "VJS";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }

    private static string GetStatusBadgeClass(string status)
    {
        return status.ToLowerInvariant() switch
        {
            "pending" => "bg-amber-100 text-amber-700",
            "delivered" => "bg-green-100 text-green-700",
            "cancelled" => "bg-red-100 text-red-700",
            _ => "bg-blue-100 text-blue-700"
        };
    }
}
