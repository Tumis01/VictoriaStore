@page "/admin/settings"
@layout Layout.AdminLayout

<PageTitle>Store Settings - Victoria Admin</PageTitle>

<div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 font-serif">Store Settings</h1>
    <p class="text-sm text-gray-500 mt-0.5">Manage your store's configuration and payment details.</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col md:flex-row min-h-[600px]">
    
    <div class="w-full md:w-64 bg-gray-50 border-r border-gray-200 flex-shrink-0 p-4">
        <nav class="space-y-1">
            <button @onclick='() => activeTab = "profile"' class="@GetTabClass("profile") w-full flex items-center gap-3 px-3 py-2.5 text-sm font-semibold rounded-lg transition-colors text-left">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                Store Profile
            </button>
            <button @onclick='() => activeTab = "bank"' class="@GetTabClass("bank") w-full flex items-center gap-3 px-3 py-2.5 text-sm font-semibold rounded-lg transition-colors text-left">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                Bank Account
            </button>
            <button @onclick='() => activeTab = "notifications"' class="@GetTabClass("notifications") w-full flex items-center gap-3 px-3 py-2.5 text-sm font-semibold rounded-lg transition-colors text-left">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                Notifications
            </button>
        </nav>
    </div>

    <div class="flex-1 p-6 sm:p-10">
        
        @if (activeTab == "profile")
        {
            <div class="max-w-2xl animate-fade-in">
                <h2 class="text-xl font-bold text-gray-900 font-serif mb-6">Store Profile</h2>
                <form class="space-y-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Store Name</label>
                        <input type="text" value="Victoria James Store" class="h-11 w-full px-4 rounded-lg border border-gray-300 text-sm focus:ring-2 focus:ring-brand outline-none" />
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Support Email</label>
                            <input type="email" value="support@victoriajames.com" class="h-11 w-full px-4 rounded-lg border border-gray-300 text-sm focus:ring-2 focus:ring-brand outline-none" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">WhatsApp Number</label>
                            <input type="text" value="+234 816 280 9886" class="h-11 w-full px-4 rounded-lg border border-gray-300 text-sm focus:ring-2 focus:ring-brand outline-none" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Physical Address</label>
                        <textarea rows="3" class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm focus:ring-2 focus:ring-brand outline-none">Lagos, Nigeria</textarea>
                    </div>
                    <button type="button" class="h-11 px-6 bg-brand text-white font-bold rounded-lg shadow-sm hover:bg-brand-dark transition-colors">Save Profile</button>
                </form>
            </div>
        }
        else if (activeTab == "bank")
        {
            <div class="max-w-2xl animate-fade-in">
                <h2 class="text-xl font-bold text-gray-900 font-serif mb-2">Bank Details</h2>
                <p class="text-sm text-gray-500 mb-6">This information is displayed to customers at checkout for bank transfer payments.</p>
                <form class="space-y-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Bank Name</label>
                        <input type="text" placeholder="e.g. Guarantee Trust Bank (GTB)" class="h-11 w-full px-4 rounded-lg border border-gray-300 text-sm focus:ring-2 focus:ring-brand outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Account Number</label>
                        <input type="text" placeholder="0123456789" class="h-11 w-full px-4 rounded-lg border border-gray-300 text-sm focus:ring-2 focus:ring-brand outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Account Name</label>
                        <input type="text" placeholder="Victoria James Enterprise" class="h-11 w-full px-4 rounded-lg border border-gray-300 text-sm focus:ring-2 focus:ring-brand outline-none" />
                    </div>
                    <button type="button" class="h-11 px-6 bg-brand text-white font-bold rounded-lg shadow-sm hover:bg-brand-dark transition-colors">Save Bank Details</button>
                </form>
            </div>
        }
        else if (activeTab == "notifications")
        {
            <div class="max-w-2xl animate-fade-in">
                <h2 class="text-xl font-bold text-gray-900 font-serif mb-6">Notification Preferences</h2>
                <div class="space-y-4">
                    <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg">
                        <div>
                            <p class="font-bold text-gray-900 text-sm">New Order Email</p>
                            <p class="text-xs text-gray-500 mt-0.5">Receive an email when a customer places an order.</p>
                        </div>
                        <input type="checkbox" checked class="w-5 h-5 text-brand border-gray-300 rounded focus:ring-brand" />
                    </div>
                    <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg">
                        <div>
                            <p class="font-bold text-gray-900 text-sm">Low Stock Alert</p>
                            <p class="text-xs text-gray-500 mt-0.5">Notify me when a product's stock drops below 5.</p>
                        </div>
                        <input type="checkbox" checked class="w-5 h-5 text-brand border-gray-300 rounded focus:ring-brand" />
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string activeTab = "profile";

    private string GetTabClass(string tabName)
    {
        return activeTab == tabName
            ? "bg-brand/10 text-brand"
            : "text-gray-600 hover:bg-gray-100";
    }
}