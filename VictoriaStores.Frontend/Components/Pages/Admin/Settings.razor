@page "/admin/settings"
@layout Layout.AdminLayout

<PageTitle>Store Settings - Victoria Admin</PageTitle>

<div class="mb-6">
    <h1 class="text-2xl font-bold text-on-surface font-serif">Store Settings</h1>
    <p class="text-sm text-outline mt-0.5">Manage your store's configuration and payment details.</p>
</div>

<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/30 overflow-hidden flex flex-col md:flex-row min-h-[600px]">
    
    <div class="w-full md:w-64 bg-surface-container-low border-r border-outline-variant/30 flex-shrink-0 p-4">
        <nav class="space-y-1">
            <button @onclick='() => activeTab = "profile"' class="@GetTabClass("profile") w-full flex items-center gap-3 px-3 py-2.5 text-sm font-semibold rounded-lg transition-colors text-left">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                Store Profile
            </button>
            <button @onclick='() => activeTab = "bank"' class="@GetTabClass("bank") w-full flex items-center gap-3 px-3 py-2.5 text-sm font-semibold rounded-lg transition-colors text-left">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                Bank Account
            </button>
            <button @onclick='() => activeTab = "notifications"' class="@GetTabClass("notifications") w-full flex items-center gap-3 px-3 py-2.5 text-sm font-semibold rounded-lg transition-colors text-left">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                Notifications
            </button>
            <button @onclick='() => activeTab = "seo"' class="@GetTabClass("seo") w-full flex items-center gap-3 px-3 py-2.5 text-sm font-semibold rounded-lg transition-colors text-left">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                SEO Settings
            </button>
        </nav>
    </div>

    <div class="flex-1 p-6 sm:p-10">
        
        @if (activeTab == "profile")
        {
            <div class="max-w-2xl animate-fade-in">
                <h2 class="text-xl font-bold text-on-surface font-serif mb-6">Store Profile</h2>
                <form class="space-y-6" @onsubmit='() => SaveSettings("profile")'>
                    @if(savedStatus == "profile") { <div class="p-3 bg-green-50 text-green-700 text-sm font-bold border border-green-200 rounded-lg">Profile settings saved!</div> }
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Store Name</label>
                        <input type="text" @bind="storeSettings.StoreName" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1">Support Email</label>
                            <input type="email" @bind="storeSettings.SupportEmail" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1">WhatsApp Number</label>
                            <input type="text" @bind="storeSettings.WhatsAppNumber" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Physical Address</label>
                        <textarea rows="3" @bind="storeSettings.Address" class="w-full px-4 py-3 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none"></textarea>
                    </div>
                    <button type="submit" disabled="@isSaving" class="h-11 px-6 bg-primary text-white font-bold rounded-lg shadow-sm hover:bg-primary-dark transition-colors disabled:bg-gray-400">Save Profile</button>
                </form>
            </div>
        }
        else if (activeTab == "bank")
        {
            <div class="max-w-2xl animate-fade-in">
                <h2 class="text-xl font-bold text-on-surface font-serif mb-2">Bank Details</h2>
                <p class="text-sm text-outline mb-6">This information is displayed to customers at checkout for bank transfer payments.</p>
                <form class="space-y-6" @onsubmit='() => SaveSettings("bank")'>
                    @if(savedStatus == "bank") { <div class="p-3 bg-green-50 text-green-700 text-sm font-bold border border-green-200 rounded-lg">Bank details saved!</div> }
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Bank Name</label>
                        <input type="text" @bind="storeSettings.BankName" placeholder="e.g. Guarantee Trust Bank (GTB)" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Account Number</label>
                        <input type="text" @bind="storeSettings.AccountNumber" placeholder="0123456789" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Account Name</label>
                        <input type="text" @bind="storeSettings.AccountName" placeholder="Victoria James Enterprise" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                    </div>
                    <button type="submit" disabled="@isSaving" class="h-11 px-6 bg-primary text-white font-bold rounded-lg shadow-sm hover:bg-primary-dark transition-colors disabled:bg-gray-400">Save Bank Details</button>
                </form>
            </div>
        }
        else if (activeTab == "notifications")
        {
            <div class="max-w-2xl animate-fade-in">
                <h2 class="text-xl font-bold text-on-surface font-serif mb-6">Notification Preferences</h2>
                <form class="space-y-4" @onsubmit='() => SaveSettings("notifications")'>
                    @if(savedStatus == "notifications") { <div class="p-3 bg-green-50 text-green-700 text-sm font-bold border border-green-200 rounded-lg mb-4">Notifications saved!</div> }
                    <div class="flex items-center justify-between p-4 border border-outline-variant/30 rounded-lg hover:border-primary transition-colors cursor-pointer" @onclick="() => storeSettings.NewOrderEmail = !storeSettings.NewOrderEmail">
                        <div>
                            <p class="font-bold text-on-surface text-sm">New Order Email</p>
                            <p class="text-xs text-outline mt-0.5">Receive an email when a customer places an order.</p>
                        </div>
                        <input type="checkbox" @bind="storeSettings.NewOrderEmail" class="w-5 h-5 text-primary border-outline-variant/50 rounded focus:ring-primary pointer-events-none" />
                    </div>
                    <div class="flex items-center justify-between p-4 border border-outline-variant/30 rounded-lg hover:border-primary transition-colors cursor-pointer" @onclick="() => storeSettings.LowStockAlert = !storeSettings.LowStockAlert">
                        <div>
                            <p class="font-bold text-on-surface text-sm">Low Stock Alert</p>
                            <p class="text-xs text-outline mt-0.5">Notify me when a product's stock drops below 5.</p>
                        </div>
                        <input type="checkbox" @bind="storeSettings.LowStockAlert" class="w-5 h-5 text-primary border-outline-variant/50 rounded focus:ring-primary pointer-events-none" />
                    </div>
                    <div class="pt-4">
                        <button type="submit" disabled="@isSaving" class="h-11 px-6 bg-primary text-white font-bold rounded-lg shadow-sm hover:bg-primary-dark transition-colors disabled:bg-gray-400">Save Preferences</button>
                    </div>
                </form>
            </div>
        }
        else if (activeTab == "seo")
        {
            <div class="max-w-2xl animate-fade-in">
                <h2 class="text-xl font-bold text-on-surface font-serif mb-2">Search Engine Optimization</h2>
                <p class="text-sm text-outline mb-6">Improve your store's visibility on Google and other search engines.</p>
                <form class="space-y-6" @onsubmit='() => SaveSettings("seo")'>
                    @if(savedStatus == "seo") { <div class="p-3 bg-green-50 text-green-700 text-sm font-bold border border-green-200 rounded-lg">SEO settings saved!</div> }
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Global Meta Title</label>
                        <input type="text" @bind="storeSettings.SeoTitle" placeholder="e.g. Victoria James | Premium Fashion" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Global Meta Description</label>
                        <textarea rows="3" @bind="storeSettings.SeoDescription" placeholder="Shop the latest fashion..." class="w-full px-4 py-3 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none"></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Meta Keywords (Comma separated)</label>
                        <input type="text" @bind="storeSettings.SeoKeywords" placeholder="fashion, dresses, premium" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                    </div>
                    <button type="submit" disabled="@isSaving" class="h-11 px-6 bg-primary text-white font-bold rounded-lg shadow-sm hover:bg-primary-dark transition-colors disabled:bg-gray-400">Save SEO Data</button>
                </form>
            </div>
        }
    </div>
</div>

@code {
    private string activeTab = "profile";
    private bool isSaving = false;
    private string? savedStatus = null;
    
    private StoreConfig storeSettings = new StoreConfig();

    protected override void OnInitialized()
    {
        // Mock load
        storeSettings = new StoreConfig
        {
            StoreName = "Victoria James Store",
            SupportEmail = "support@victoriajames.com",
            WhatsAppNumber = "08162809886",
            Address = "Lagos, Nigeria",
            BankName = "First Bank Nigeria",
            AccountNumber = "1234567890",
            AccountName = "VICTORIA JAMES",
            NewOrderEmail = true,
            LowStockAlert = true,
            SeoTitle = "Victoria James | Premium Fashion",
            SeoKeywords = "fashion, clothing, premium"
        };
    }

    private string GetTabClass(string tabName)
    {
        return activeTab == tabName
            ? "bg-primary/10 text-primary"
            : "text-on-surface-variant hover:bg-surface-container";
    }

    private async Task SaveSettings(string tab)
    {
        isSaving = true;
        savedStatus = null;
        
        // Mock save delay assuming no API endpoint exists yet
        await Task.Delay(800);
        
        savedStatus = tab;
        isSaving = false;

        // Clear status after 3 secs
        _ = Task.Run(async () => {
            await Task.Delay(3000);
            savedStatus = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    public class StoreConfig
    {
        public string StoreName { get; set; } = string.Empty;
        public string SupportEmail { get; set; } = string.Empty;
        public string WhatsAppNumber { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        
        public string BankName { get; set; } = string.Empty;
        public string AccountNumber { get; set; } = string.Empty;
        public string AccountName { get; set; } = string.Empty;

        public bool NewOrderEmail { get; set; } = true;
        public bool LowStockAlert { get; set; } = true;

        public string SeoTitle { get; set; } = string.Empty;
        public string SeoDescription { get; set; } = string.Empty;
        public string SeoKeywords { get; set; } = string.Empty;
    }
}