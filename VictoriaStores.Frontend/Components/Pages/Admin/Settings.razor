@page "/admin/settings"
@layout Layout.AdminLayout
@inject HttpClient Http
@using System.Net.Http.Json

<PageTitle>Store Settings - Victoria Admin</PageTitle>

<div class="mb-6">
    <h1 class="text-2xl font-bold text-on-surface font-serif">Store Settings</h1>
    <p class="text-sm text-outline mt-0.5">Manage your store profile, payment details, notifications and SEO.</p>
</div>

@if (isLoading)
{
    <div class="flex justify-center py-20">
        <svg class="animate-spin h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
    </div>
}
else
{
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/30 overflow-hidden flex flex-col lg:flex-row min-h-[640px]">
        <div class="w-full lg:w-72 bg-surface-container-low border-b lg:border-b-0 lg:border-r border-outline-variant/30 p-4">
            <nav class="grid grid-cols-2 gap-2 sm:grid-cols-4 lg:grid-cols-1">
                <button @onclick='() => activeTab = "profile"' class="@GetTabClass("profile") border-none outline-none w-full flex items-center gap-3 px-4 py-3 text-sm font-semibold rounded-xl transition-colors text-left">
                    <span class="material-symbols-outlined text-[20px]">storefront</span>
                    Store Profile
                </button>
                <button @onclick='() => activeTab = "bank"' class="@GetTabClass("bank") border-none outline-none w-full flex items-center gap-3 px-4 py-3 text-sm font-semibold rounded-xl transition-colors text-left">
                    <span class="material-symbols-outlined text-[20px]">account_balance</span>
                    Bank Account
                </button>
                <button @onclick='() => activeTab = "notifications"' class="@GetTabClass("notifications") border-none outline-none w-full flex items-center gap-3 px-4 py-3 text-sm font-semibold rounded-xl transition-colors text-left">
                    <span class="material-symbols-outlined text-[20px]">notifications</span>
                    Notifications
                </button>
                @* <button @onclick='() => activeTab = "seo"' class="@GetTabClass("seo")border-none outline-none w-full flex items-center gap-3 px-4 py-3 text-sm font-semibold rounded-xl transition-colors text-left">
                    <span class="material-symbols-outlined text-[20px]">travel_explore</span>
                    SEO Settings
                </button> *@
            </nav>
        </div>

        <div class="flex-1 p-5 sm:p-8 lg:p-10">
            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="mb-6 rounded-xl px-4 py-3 text-sm font-semibold @(statusIsError ? "bg-red-50 text-red-700 border border-red-200" : "bg-green-50 text-green-700 border border-green-200")">
                    @statusMessage
                </div>
            }

            @if (activeTab == "profile")
            {
                <div class="max-w-3xl">
                    <h2 class="text-xl font-bold text-on-surface font-serif mb-2">Store Profile</h2>
                    <p class="text-sm text-outline mb-6">These details appear across your storefront and customer communication.</p>

                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1">Store Name</label>
                            <input type="text" @bind="storeSettings.StoreName" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-semibold text-on-surface-variant mb-1">Support Email</label>
                                <input type="email" @bind="storeSettings.SupportEmail" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-on-surface-variant mb-1">WhatsApp Number</label>
                                <input type="text" @bind="storeSettings.WhatsAppNumber" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1">Physical Address</label>
                            <textarea rows="3" @bind="storeSettings.Address" class="w-full px-4 py-3 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none"></textarea>
                        </div>

                        <button type="button" @onclick='() => SaveSettings("profile")' disabled="@isSaving" class="h-11 px-6 bg-primary text-white font-bold rounded-lg shadow-sm hover:bg-primary-dark transition-colors disabled:bg-gray-400">
                            @(isSaving ? "Saving..." : "Save Profile")
                        </button>
                    </div>
                </div>
            }
            else if (activeTab == "bank")
            {
                <div class="max-w-3xl">
                    <h2 class="text-xl font-bold text-on-surface font-serif mb-2">Bank Details</h2>
                    <p class="text-sm text-outline mb-6">This is what customers will see on the confirmation page for bank transfers.</p>

                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1">Bank Name</label>
                            <input type="text" @bind="storeSettings.BankName" placeholder="e.g. GTBank" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-semibold text-on-surface-variant mb-1">Account Number</label>
                                <input type="text" @bind="storeSettings.AccountNumber" placeholder="0123456789" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-on-surface-variant mb-1">Account Name</label>
                                <input type="text" @bind="storeSettings.AccountName" placeholder="Victoria James Enterprise" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                        </div>

                        <button type="button" @onclick='() => SaveSettings("bank")' disabled="@isSaving" class="h-11 px-6 bg-primary text-white font-bold rounded-lg shadow-sm hover:bg-primary-dark transition-colors disabled:bg-gray-400">
                            @(isSaving ? "Saving..." : "Save Bank Details")
                        </button>
                    </div>
                </div>
            }
            else if (activeTab == "notifications")
            {
                <div class="max-w-3xl">
                    <h2 class="text-xl font-bold text-on-surface font-serif mb-2">Notification Preferences</h2>
                    <p class="text-sm text-outline mb-6">Control how the store alerts you about orders and stock updates.</p>

                    <div class="space-y-4">
                        <button type="button" class="w-full flex items-center justify-between p-4 border border-outline-variant/30 rounded-xl hover:border-primary transition-colors text-left" @onclick="() => storeSettings.NewOrderEmail = !storeSettings.NewOrderEmail">
                            <div>
                                <p class="font-bold text-on-surface text-sm">New Order Email</p>
                                <p class="text-xs text-outline mt-0.5">Receive an email when a customer places an order.</p>
                            </div>
                            <input type="checkbox" @bind="storeSettings.NewOrderEmail" class="w-5 h-5 pointer-events-none" />
                        </button>

                        <button type="button" class="w-full flex items-center justify-between p-4 border border-outline-variant/30 rounded-xl hover:border-primary transition-colors text-left" @onclick="() => storeSettings.LowStockAlert = !storeSettings.LowStockAlert">
                            <div>
                                <p class="font-bold text-on-surface text-sm">Low Stock Alert</p>
                                <p class="text-xs text-outline mt-0.5">Notify me when a product stock drops below 5.</p>
                            </div>
                            <input type="checkbox" @bind="storeSettings.LowStockAlert" class="w-5 h-5 pointer-events-none" />
                        </button>

                        <button type="button" @onclick='() => SaveSettings("notifications")' disabled="@isSaving" class="h-11 px-6 bg-primary text-white font-bold rounded-lg shadow-sm hover:bg-primary-dark transition-colors disabled:bg-gray-400">
                            @(isSaving ? "Saving..." : "Save Preferences")
                        </button>
                    </div>
                </div>
            }
            else if (activeTab == "seo")
            {
                <div class="max-w-3xl">
                    <h2 class="text-xl font-bold text-on-surface font-serif mb-2">SEO Settings</h2>
                    <p class="text-sm text-outline mb-6">Improve how your store appears on search engines and social sharing.</p>

                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1">Global Meta Title</label>
                            <input type="text" @bind="storeSettings.SeoTitle" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1">Global Meta Description</label>
                            <textarea rows="3" @bind="storeSettings.SeoDescription" class="w-full px-4 py-3 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none"></textarea>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1">Meta Keywords (Comma separated)</label>
                            <input type="text" @bind="storeSettings.SeoKeywords" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 text-sm focus:ring-2 focus:ring-primary outline-none" />
                        </div>

                        <button type="button" @onclick='() => SaveSettings("seo")' disabled="@isSaving" class="h-11 px-6 bg-primary text-white font-bold rounded-lg shadow-sm hover:bg-primary-dark transition-colors disabled:bg-gray-400">
                            @(isSaving ? "Saving..." : "Save SEO Data")
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private string activeTab = "profile";
    private bool isLoading = true;
    private bool isSaving = false;
    private bool statusIsError = false;
    private string? statusMessage;

    private StoreConfig storeSettings = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        try
        {
            isLoading = true;
            statusMessage = null;

            var settings = await Http.GetFromJsonAsync<StoreConfig>("api/store-settings");
            storeSettings = settings ?? new StoreConfig();
        }
        catch (Exception ex)
        {
            storeSettings = new StoreConfig();
            statusIsError = true;
            statusMessage = "Could not load store settings. " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetTabClass(string tabName)
    {
        return activeTab == tabName
            ? "bg-primary/10 text-primary"
            : "text-on-surface-variant hover:bg-surface-container";
    }

    private async Task SaveSettings(string tab)
    {
        isSaving = true;
        statusMessage = null;

        try
        {
            var response = await Http.PutAsJsonAsync("api/store-settings", storeSettings);

            if (response.IsSuccessStatusCode)
            {
                statusIsError = false;
                statusMessage = tab switch
                {
                    "profile" => "Profile settings saved successfully.",
                    "bank" => "Bank details saved successfully.",
                    "notifications" => "Notification settings saved successfully.",
                    "seo" => "SEO settings saved successfully.",
                    _ => "Settings saved successfully."
                };

                _ = ClearStatusLater();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                statusIsError = true;
                statusMessage = $"Could not save settings. {body}";
            }
        }
        catch (Exception ex)
        {
            statusIsError = true;
            statusMessage = "Could not save settings. " + ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ClearStatusLater()
    {
        await Task.Delay(3000);
        statusMessage = null;
        await InvokeAsync(StateHasChanged);
    }

    public class StoreConfig
    {
        public string StoreName { get; set; } = string.Empty;
        public string SupportEmail { get; set; } = string.Empty;
        public string WhatsAppNumber { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public string BankName { get; set; } = string.Empty;
        public string AccountNumber { get; set; } = string.Empty;
        public string AccountName { get; set; } = string.Empty;
        public bool NewOrderEmail { get; set; } = true;
        public bool LowStockAlert { get; set; } = true;
        public string SeoTitle { get; set; } = string.Empty;
        public string SeoDescription { get; set; } = string.Empty;
        public string SeoKeywords { get; set; } = string.Empty;
    }
}
