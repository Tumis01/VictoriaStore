@page "/admin"
@layout Layout.AdminLayout
@inject HttpClient Http
@using VictoriaStores.Frontend.Models
@using VictoriaStores.Frontend.Services
@inject VictoriaStores.Frontend.Services.ProductApiClient ProductApi

<PageTitle>Admin Dashboard - Victoria James Store</PageTitle>

<div class="mb-6">
    <h1 class="text-2xl font-bold text-on-surface font-serif">Dashboard</h1>
    <p class="text-sm text-outline mt-0.5">Welcome back, here is what's happening today.</p>
</div>

@if (isLoading)
{
    <div class="flex h-64 items-center justify-center">
        <svg class="animate-spin h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
    </div>
}
else
{
    <div class="flex flex-wrap gap-4 mb-8 animate-fade-in">
        <a href="/admin/products" class="inline-flex items-center gap-2 bg-primary text-white px-4 py-2.5 rounded-lg font-bold text-sm shadow-sm hover:bg-primary-dark transition-colors">
            <span class="material-symbols-outlined text-[20px]">add</span>
            Add Product (Via Products Tab)
        </a>
        <a href="/admin/orders" class="inline-flex items-center gap-2 bg-surface-container-lowest border border-outline-variant/50 text-on-surface-variant px-4 py-2.5 rounded-lg font-bold text-sm shadow-sm hover:bg-surface-container-low transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
            Manage Orders
        </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-8 animate-slide-up">
        
        <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/15 p-5">
            <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-semibold text-outline uppercase tracking-wide">Total Revenue</span>
                <span class="w-10 h-10 rounded-lg bg-green-50 flex items-center justify-center text-green-600">₦</span>
            </div>
            <p class="text-3xl font-extrabold text-on-surface flex items-end gap-2">
                ₦@totalRevenue.ToString("N0")
                <span class="text-xs text-green-500 font-bold mb-1 flex items-center"><svg class="w-3 h-3 mr-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg> 12.5%</span>
            </p>
        </div>

        <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/15 p-5">
            <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-semibold text-outline uppercase tracking-wide">Total Orders</span>
                <span class="w-10 h-10 rounded-lg bg-primary-container flex items-center justify-center text-blue-600">📦</span>
            </div>
            <p class="text-3xl font-extrabold text-on-surface flex items-end gap-2">
                @orders.Count
                <span class="text-xs text-green-500 font-bold mb-1 flex items-center"><svg class="w-3 h-3 mr-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg> 8.2%</span>
            </p>
        </div>

        <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/15 p-5">
            <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-semibold text-outline uppercase tracking-wide">Pending</span>
                <span class="w-10 h-10 rounded-lg bg-amber-50 flex items-center justify-center text-amber-600">⚠</span>
            </div>
            <p class="text-3xl font-extrabold text-on-surface">@pendingOrdersCount</p>
            @if (pendingOrdersCount > 0)
            {
                <p class="text-xs text-amber-600 font-semibold mt-1">Action needed</p>
            }
        </div>

        <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/15 p-5">
            <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-semibold text-outline uppercase tracking-wide">Out of Stock</span>
                <span class="w-10 h-10 rounded-lg bg-red-50 flex items-center justify-center text-red-600">✕</span>
            </div>
            <p class="text-3xl font-extrabold text-on-surface">@outOfStockCount</p>
            <p class="text-xs text-outline font-semibold mt-1">Total Catalog: @products.Count</p>
        </div>
    </div>

    @if (outOfStockCount > 0)
    {
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 flex items-center justify-between mb-8">
            <div class="flex items-center gap-3">
                <span class="text-amber-600 text-xl">⚠</span>
                <p class="text-sm font-medium text-amber-800">@outOfStockCount products are out of stock.</p>
            </div>
            <a href="/admin/products" class="text-sm font-bold text-amber-700 hover:underline">View Products</a>
        </div>
    }

    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/15 p-5 mb-8 animate-fade-in" style="animation-delay: 0.1s;">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-lg font-bold text-on-surface font-serif">Revenue Trend <span class="text-xs text-outline font-normal ml-2 tracking-wide font-body uppercase">Last 30 Days</span></h3>
            <select class="text-xs font-bold text-on-surface-variant bg-surface-container-low border border-outline-variant/30 rounded px-2 py-1 outline-none">
                <option>This Month</option>
                <option>Last Month</option>
                <option>This Year</option>
            </select>
        </div>
        <div class="h-64 w-full bg-surface-container-low border border-dashed border-outline-variant/30 rounded-lg flex items-center justify-center relative overflow-hidden">
            <svg class="absolute inset-x-0 bottom-0 h-full w-full" preserveAspectRatio="none" viewBox="0 0 100 100">
                <polyline points="0,95 10,90 20,60 30,70 40,40 50,45 60,25 70,30 80,15 90,20 100,5" fill="none" stroke="#1A56DB" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                <polygon points="0,100 0,95 10,90 20,60 30,70 40,40 50,45 60,25 70,30 80,15 90,20 100,5 100,100" fill="#1A56DB" fill-opacity="0.05" />
            </svg>
            <div class="text-primary font-bold text-xs z-10 bg-surface-container-lowest/70 px-4 py-2 rounded-lg backdrop-blur-sm shadow-sm flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                Chart.js Plugin Stub
            </div>
        </div>
    </div>

    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/15 animate-fade-in" style="animation-delay: 0.2s;">
        <div class="flex justify-between items-center p-5 border-b border-outline-variant/15">
            <h3 class="text-lg font-bold text-on-surface font-serif">Recent Orders</h3>
            <a href="/admin/orders" class="text-sm font-semibold text-primary hover:underline">View All</a>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 text-sm text-left">
                <thead class="bg-surface-container-low">
                    <tr>
                        <th class="px-5 py-3.5 text-xs font-bold text-outline uppercase tracking-wider">Order #</th>
                        <th class="px-5 py-3.5 text-xs font-bold text-outline uppercase tracking-wider">Customer</th>
                        <th class="px-5 py-3.5 text-xs font-bold text-outline uppercase tracking-wider">Date</th>
                        <th class="px-5 py-3.5 text-xs font-bold text-outline uppercase tracking-wider">Status</th>
                        <th class="px-5 py-3.5 text-xs font-bold text-outline uppercase tracking-wider">Amount</th>
                        <th class="px-5 py-3.5 text-xs font-bold text-outline uppercase tracking-wider">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var order in recentOrders)
                    {
                        <tr class="hover:bg-primary-light/30 transition-colors duration-100">
                            <td class="px-5 py-4 font-bold text-primary whitespace-nowrap">@order.OrderNumber</td>
                            <td class="px-5 py-4">
                                <div class="font-semibold text-on-surface">@order.CustomerName</div>
                                <div class="text-xs text-outline mt-0.5">@order.CustomerPhone</div>
                            </td>
                            <td class="px-5 py-4 text-on-surface-variant">@order.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</td>
                            <td class="px-5 py-4">
                                @if (order.Status == "Pending")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-700">Pending</span>
                                }
                                else if (order.Status == "Confirmed" || order.Status == "Shipped")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-700">@order.Status</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">@order.Status</span>
                                }
                            </td>
                            <td class="px-5 py-4 font-bold text-on-surface">₦@order.TotalAmount.ToString("N2")</td>
                            <td class="px-5 py-4">
                                <a href="/admin/orders/@order.Id" class="text-primary font-semibold hover:underline">View</a>
                            </td>
                        </tr>
                    }
                    @if (!recentOrders.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-5 py-8 text-center text-outline">No recent orders found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    // ... keep exact same @code block as you currently have
    private bool isLoading = true;
    private List<OrderResponseDto> orders = new();
    private List<OrderResponseDto> recentOrders = new();
    private List<ProductDto> products = new();
    
    private decimal totalRevenue = 0;
    private int pendingOrdersCount = 0;
    private int outOfStockCount = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                orders = await Http.GetFromJsonAsync<List<OrderResponseDto>>("api/order") ?? new List<OrderResponseDto>();
                products = await ProductApi.GetActiveProductsAsync() ?? new List<ProductDto>();

                totalRevenue = orders.Where(o => o.Status != "Cancelled").Sum(o => o.TotalAmount);
                pendingOrdersCount = orders.Count(o => o.Status == "Pending");
                recentOrders = orders.OrderByDescending(o => o.CreatedAt).Take(10).ToList();
                outOfStockCount = products.Count(p => p.StockQuantity <= 0);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading dashboard data: {ex.Message}");
            }
            finally
            {
                isLoading = false;
                StateHasChanged();
            }
        }
    }

    public class OrderResponseDto
    {
        public Guid Id { get; set; }
        public string OrderNumber { get; set; } = string.Empty;
        public string CustomerName { get; set; } = string.Empty;
        public string CustomerPhone { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public decimal TotalAmount { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}