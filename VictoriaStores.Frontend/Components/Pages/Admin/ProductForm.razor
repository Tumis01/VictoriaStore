@page "/admin/products/new"
@page "/admin/products/edit/{Id:guid}"
@layout Layout.AdminLayout
@inject HttpClient Http
@inject NavigationManager NavManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using System.Globalization
@using System.IO
@using System.Linq
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Text
@using Microsoft.AspNetCore.Components.Forms
@using VictoriaStores.Frontend.Models

<PageTitle>@(IsEditMode ? "Edit Product" : "Add New Product") - Victoria Admin</PageTitle>

<div class="flex flex-col gap-4 mb-6 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-4">
        <button type="button" @onclick='() => NavManager.NavigateTo("/admin/products")' class="p-2 rounded-full hover:bg-surface-container-high text-outline transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
        </button>
        <div>
            <h1 class="text-2xl font-bold text-on-surface font-serif">@(IsEditMode ? "Edit Product" : "Add New Product")</h1>
            <p class="text-sm text-outline mt-0.5">Fill out the details below to update your catalog.</p>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="flex h-64 items-center justify-center">
        <svg class="animate-spin h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
    </div>
}
else
{
    <EditForm Model="productModel" OnValidSubmit="SaveProduct" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <DataAnnotationsValidator />

        <div class="lg:col-span-2 space-y-6">
            <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/15 p-6">
                <h3 class="text-lg font-bold text-on-surface font-serif mb-4">Basic Information</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Product Name <span class="text-red-500">*</span></label>
                        <InputText @bind-Value="productModel.Name" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors" placeholder="e.g. Premium Non-Stick Frying Pan" />
                        <ValidationMessage For="@(() => productModel.Name)" class="text-xs text-red-500 mt-1" />
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1">SKU</label>
                            <InputText @bind-Value="productModel.SKU" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors" placeholder="Auto-generated if left blank" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1">Slug</label>
                            <InputText @bind-Value="productModel.Slug" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors" placeholder="Auto-generated from name if left blank" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Description</label>
                        <InputTextArea @bind-Value="productModel.Description" rows="5" class="w-full px-4 py-3 rounded-lg border border-outline-variant/50 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors" placeholder="Detailed product description..."></InputTextArea>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-2">Available Colors</label>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var color in predefinedColors)
                            {
                                <button type="button"
                                        @onclick="() => ToggleColor(color)"
                                        class="@(productModel.Colors.Contains(color) ? "bg-primary text-white" : "bg-surface-container-lowest text-on-surface-variant hover:bg-surface-container-low") px-4 py-1.5 rounded-full text-sm font-semibold transition-colors shadow-sm">
                                    @color
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/15 p-6">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between mb-4">
                    <div>
                        <h3 class="text-lg font-bold text-on-surface font-serif">Media</h3>
                        <p class="text-xs font-semibold text-outline mt-1">Up to @MaxFileCount images per product</p>
                    </div>

                    <div class="sm:text-right">
                        <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-bold @(TotalImageCount >= MaxFileCount ? "bg-amber-100 text-amber-700" : "bg-surface-container-low text-outline")">
                            @TotalImageCount / @MaxFileCount images
                        </span>

                        @if (TotalImageCount >= MaxFileCount)
                        {
                            <p class="text-xs font-medium text-amber-700 mt-2 max-w-xs">
                                Maximum image limit reached. Remove one image before adding another.
                            </p>
                        }
                    </div>
                </div>

                <label for="product-images" class="block border-2 border-dashed rounded-xl p-6 sm:p-8 text-center transition-colors @(TotalImageCount >= MaxFileCount ? "border-amber-300 bg-amber-50/60 cursor-not-allowed opacity-70" : "border-outline-variant/50 hover:bg-surface-container-low cursor-pointer")">
                    <div class="mx-auto w-12 h-12 bg-primary-light text-primary rounded-full flex items-center justify-center mb-3">
                        <span class="material-symbols-outlined text-[20px]">image</span>
                    </div>
                    <p class="text-sm font-bold text-primary">Click to upload <span class="text-outline font-normal">product image(s)</span></p>
                    <p class="text-xs text-outline-variant mt-1">PNG, JPG, JPEG, WEBP, GIF or SVG</p>
                    <p class="text-xs text-outline-variant mt-1">Images are resized to 1024px and converted to JPEG before upload</p>
                </label>

                <InputFile id="product-images" OnChange="HandleFilesSelected" accept="image/*" multiple class="hidden" disabled="@(TotalImageCount >= MaxFileCount)" />

                @if (TotalImageCount < MaxFileCount)
                {
                    <p class="mt-3 text-xs text-outline-variant">
                        You can still add @(MaxFileCount - TotalImageCount) more image(s).
                    </p>
                }
                else
                {
                    <div class="mt-3 rounded-lg border border-amber-200 bg-amber-50 p-3">
                        <p class="text-sm font-medium text-amber-800">
                            This product already has the maximum of @MaxFileCount images.
                        </p>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(uploadStatus))
                {
                    <div class="mt-4 rounded-lg border border-blue-200 bg-primary-container p-4">
                        <p class="text-sm font-medium text-on-primary-container">@uploadStatus</p>
                    </div>
                }

                @if (selectedFiles.Any())
                {
                    <div class="mt-4 rounded-lg border border-green-200 bg-green-50 p-4">
                        <div class="flex items-center justify-between gap-3 mb-3">
                            <p class="text-sm font-semibold text-green-800">Prepared files</p>
                            <span class="text-xs text-green-700">@selectedFiles.Count new image(s)</span>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            @foreach (var item in selectedFiles.Select((file, index) => new { file, index }))
                            {
                                <div class="relative rounded-lg border border-green-200 bg-surface-container-lowest px-3 py-3 pr-10">
                                    <button type="button"
                                            @onclick="() => RemovePreparedFile(item.index)"
                                            class="absolute right-2 top-2 h-7 w-7 rounded-full bg-red-500 text-white hover:bg-red-600 transition-colors flex items-center justify-center"
                                            aria-label="Remove file">
                                        <span class="text-sm leading-none">×</span>
                                    </button>

                                    <p class="text-sm font-medium text-on-surface truncate">@item.file.UploadName</p>
                                    <p class="text-xs text-outline">@FormatFileSize(item.file.Content.Length)</p>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (productModel.Images.Any())
                {
                    <div class="mt-6">
                        <p class="text-sm font-semibold text-on-surface-variant mb-3">Current gallery</p>
                        <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4">
                            @foreach (var image in productModel.Images.OrderBy(i => i.DisplayOrder))
                            {
                                <div class="relative rounded-xl border border-outline-variant/30 overflow-hidden bg-surface-container-lowest">
                                    <button type="button"
                                            @onclick="() => RemoveExistingImageAsync(image)"
                                            class="absolute right-2 top-2 z-10 h-8 w-8 rounded-full bg-red-500/95 text-white shadow hover:bg-red-600 transition-colors flex items-center justify-center"
                                            disabled="@isDeletingImage"
                                            aria-label="Delete image">
                                        <span class="text-base leading-none">×</span>
                                    </button>

                                    <div class="aspect-square bg-surface-container-low">
                                        <img src="@BuildImageUrl(image.ImageUrl)" alt="@productModel.Name" class="h-full w-full object-cover" />
                                    </div>

                                    <div class="p-3">
                                        <div class="flex items-center justify-between gap-2">
                                            <span class="text-xs text-outline">Order: @image.DisplayOrder</span>
                                            @if (image.IsMain)
                                            {
                                                <span class="inline-flex items-center rounded-full bg-primary-light px-2 py-0.5 text-xs font-semibold text-primary">Main</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="space-y-6">
            <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/15 p-6">
                <h3 class="text-lg font-bold text-on-surface font-serif mb-4">Pricing</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Regular Price (₦) <span class="text-red-500">*</span></label>
                        <InputNumber @bind-Value="productModel.Price" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 focus:ring-2 focus:ring-primary outline-none" />
                        <ValidationMessage For="@(() => productModel.Price)" class="text-xs text-red-500 mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Sale Price (₦)</label>
                        <InputNumber @bind-Value="productModel.SalePrice" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 focus:ring-2 focus:ring-primary outline-none" />
                    </div>
                </div>
            </div>

            <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/15 p-6">
                <h3 class="text-lg font-bold text-on-surface font-serif mb-4">Organization</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Category <span class="text-red-500">*</span></label>
                        <InputSelect @bind-Value="productModel.CategoryId" TValue="Guid" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 focus:ring-2 focus:ring-primary outline-none bg-surface-container-lowest">
                            <option value="@Guid.Empty">Select a category</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1">Stock Quantity <span class="text-red-500">*</span></label>
                        <InputNumber @bind-Value="productModel.StockQuantity" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 focus:ring-2 focus:ring-primary outline-none" />
                        <ValidationMessage For="@(() => productModel.StockQuantity)" class="text-xs text-red-500 mt-1" />
                    </div>

                    <div class="flex items-center gap-3 pt-2">
                        <InputCheckbox @bind-Value="productModel.IsActive" id="isActive" class="w-5 h-5 text-primary border-outline-variant/50 rounded focus:ring-primary" />
                        <label for="isActive" class="text-sm font-semibold text-on-surface-variant cursor-pointer">Product is Active</label>
                    </div>
                </div>
            </div>

            <div class="pt-4 flex flex-col gap-3">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="p-3 text-sm text-red-700 bg-red-100 rounded-lg">@errorMessage</div>
                }

                <button type="submit" disabled="@isSubmitting" class="h-12 w-full bg-primary text-white font-bold rounded-xl shadow-sm hover:bg-primary-dark transition-colors disabled:bg-gray-400">
                    @SaveButtonText
                </button>

                <button type="button" @onclick='() => NavManager.NavigateTo("/admin/products")' class="h-12 w-full bg-surface-container-lowest text-on-surface-variant font-bold rounded-xl shadow-sm hover:bg-surface-container-low transition-colors">
                    Cancel
                </button>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsEditMode => Id.HasValue;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool isDeletingImage = false;
    private string? errorMessage;
    private string? uploadStatus;

    private const int MaxFileCount = 5;
    private const long MaxFileSize = 1_500_000;

    private ProductDto productModel = new() { IsActive = true };
    private List<CategoryDto> categories = new();
    private List<PreparedUploadFile> selectedFiles = new();

    private readonly List<string> predefinedColors = new()
    {
        "Black", "White", "Red", "Blue", "Green", "Yellow", "Silver", "Gold", "Pink", "Brown", "Grey"
    };

    private int TotalImageCount => (productModel.Images?.Count ?? 0) + selectedFiles.Count;

    private string SaveButtonText =>
        isSubmitting
            ? (selectedFiles.Any() ? $"Uploading {selectedFiles.Count} image(s)..." : "Saving...")
            : (IsEditMode ? "Update Product" : "Save Product");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            categories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/category") ?? new();

            if (IsEditMode)
            {
                var fetched = await Http.GetFromJsonAsync<ProductDto>($"api/product/{Id}");
                if (fetched != null)
                {
                    productModel = fetched;
                }
            }

            productModel.Colors ??= new List<string>();
            productModel.Images ??= new List<ProductImageDto>();
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load required data. " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleColor(string color)
    {
        if (productModel.Colors.Contains(color))
        {
            productModel.Colors.Remove(color);
        }
        else
        {
            productModel.Colors.Add(color);
        }
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        uploadStatus = null;

        var existingImageCount = productModel.Images?.Count ?? 0;
        var currentPreparedCount = selectedFiles.Count;
        var remainingSlots = MaxFileCount - existingImageCount - currentPreparedCount;

        if (remainingSlots <= 0)
        {
            errorMessage = $"This product already has the maximum of {MaxFileCount} images. Remove one before adding another.";
            return;
        }

        IReadOnlyList<IBrowserFile> files;
        try
        {
            files = e.GetMultipleFiles(remainingSlots);
        }
        catch (InvalidOperationException)
        {
            errorMessage = $"You can only add {remainingSlots} more image(s). Maximum allowed per product is {MaxFileCount}.";
            return;
        }

        var preparedFiles = new List<PreparedUploadFile>();
        var current = 0;

        foreach (var file in files)
        {
            current++;
            uploadStatus = $"Preparing image {current} of {files.Count}...";
            await InvokeAsync(StateHasChanged);

            if (!file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
            {
                errorMessage = $"'{file.Name}' is not a valid image file.";
                uploadStatus = null;
                return;
            }

            var resizedFile = await file.RequestImageFileAsync("image/jpeg", 1024, 1024);

            if (resizedFile.Size > MaxFileSize)
            {
                errorMessage = $"'{file.Name}' is still too large after optimization. Please use a smaller image.";
                uploadStatus = null;
                return;
            }

            await using var inputStream = resizedFile.OpenReadStream(MaxFileSize);
            using var memoryStream = new MemoryStream();
            await inputStream.CopyToAsync(memoryStream);

            var safeBaseName = Path.GetFileNameWithoutExtension(file.Name);
            preparedFiles.Add(new PreparedUploadFile
            {
                UploadName = $"{safeBaseName}-{Guid.NewGuid():N}.jpg",
                ContentType = "image/jpeg",
                Content = memoryStream.ToArray()
            });
        }

        selectedFiles.AddRange(preparedFiles);

        var totalCount = existingImageCount + selectedFiles.Count;
        uploadStatus = $"{selectedFiles.Count} new image(s) ready. Total product images after save: {totalCount}/{MaxFileCount}.";
    }

    private void RemovePreparedFile(int index)
    {
        if (index < 0 || index >= selectedFiles.Count)
            return;

        selectedFiles.RemoveAt(index);
        uploadStatus = selectedFiles.Any()
            ? $"{selectedFiles.Count} new image(s) ready. Total product images after save: {TotalImageCount}/{MaxFileCount}."
            : null;
    }

    private async Task RemoveExistingImageAsync(ProductImageDto image)
    {
        if (!IsEditMode || image == null)
            return;

        if (image.Id == Guid.Empty)
        {
            productModel.Images.Remove(image);
            return;
        }

        isDeletingImage = true;
        errorMessage = null;

        try
        {
            var token = await LocalStorage.GetItemAsync<string>("authToken");
            var request = new HttpRequestMessage(HttpMethod.Delete, $"api/product/{Id}/images/{image.Id}");

            if (!string.IsNullOrWhiteSpace(token))
            {
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }

            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                productModel.Images.Remove(image);
                uploadStatus = selectedFiles.Any()
                    ? $"{selectedFiles.Count} new image(s) ready. Total product images after save: {TotalImageCount}/{MaxFileCount}."
                    : null;
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to delete image. {body}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to delete image. " + ex.Message;
        }
        finally
        {
            isDeletingImage = false;
        }
    }

    private async Task<HttpRequestMessage> CreateAuthorizedRequest(HttpMethod method, string url, HttpContent? content = null)
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");
        var request = new HttpRequestMessage(method, url);

        if (content != null)
        {
            request.Content = content;
        }

        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }

        return request;
    }

    private async Task SaveProduct()
    {
        isSubmitting = true;
        errorMessage = null;
        uploadStatus = selectedFiles.Any()
            ? $"Uploading {selectedFiles.Count} image(s)..."
            : "Saving product...";

        try
        {
            if (string.IsNullOrWhiteSpace(productModel.Name))
            {
                errorMessage = "Product name is required.";
                return;
            }

            if (productModel.CategoryId == Guid.Empty)
            {
                errorMessage = "Please select a category.";
                return;
            }

            if (TotalImageCount > MaxFileCount)
            {
                errorMessage = $"A product can only have a maximum of {MaxFileCount} images. Please remove some images before saving.";
                return;
            }

            var slug = string.IsNullOrWhiteSpace(productModel.Slug)
                ? BuildSlug(productModel.Name)
                : BuildSlug(productModel.Slug);

            var sku = string.IsNullOrWhiteSpace(productModel.SKU)
                ? $"VJS-{DateTime.UtcNow:yyyyMMddHHmmss}"
                : productModel.SKU.Trim().ToUpperInvariant();

            using var content = new MultipartFormDataContent
            {
                { new StringContent(productModel.Name.Trim()), "Name" },
                { new StringContent(slug), "Slug" },
                { new StringContent(productModel.Description ?? string.Empty), "Description" },
                { new StringContent(productModel.Price.ToString(CultureInfo.InvariantCulture)), "Price" },
                { new StringContent(sku), "SKU" },
                { new StringContent(productModel.StockQuantity.ToString(CultureInfo.InvariantCulture)), "StockQuantity" },
                { new StringContent(productModel.CategoryId.ToString()), "CategoryId" },
                { new StringContent(productModel.IsActive.ToString()), "IsActive" }
            };

            if (productModel.SalePrice.HasValue)
            {
                content.Add(new StringContent(productModel.SalePrice.Value.ToString(CultureInfo.InvariantCulture)), "SalePrice");
            }

            foreach (var color in productModel.Colors)
            {
                content.Add(new StringContent(color), "Colors");
            }

            foreach (var file in selectedFiles)
            {
                var byteArrayContent = new ByteArrayContent(file.Content);
                byteArrayContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
                content.Add(byteArrayContent, "Images", file.UploadName);
            }

            var method = IsEditMode ? HttpMethod.Put : HttpMethod.Post;
            var url = IsEditMode ? $"api/product/{Id}" : "api/product";

            using var request = await CreateAuthorizedRequest(method, url, content);
            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                NavManager.NavigateTo("/admin/products");
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();

                errorMessage = (int)response.StatusCode switch
                {
                    401 => "Not authorised. Please log out and log back in.",
                    403 => "Access denied. Only Super Admin can manage products.",
                    409 => body,
                    400 => $"Validation error: {body}",
                    _ => $"Failed to save product (HTTP {(int)response.StatusCode}). {body}"
                };
            }
        }
        catch (TaskCanceledException)
        {
            errorMessage = "The upload took too long and was cancelled. Try fewer images or smaller files.";
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while saving the product: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
            uploadStatus = null;
        }
    }

    private static string BuildSlug(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var builder = new StringBuilder();
        var previousDash = false;

        foreach (var ch in value.Trim().ToLowerInvariant())
        {
            if (char.IsLetterOrDigit(ch))
            {
                builder.Append(ch);
                previousDash = false;
            }
            else if (!previousDash)
            {
                builder.Append('-');
                previousDash = true;
            }
        }

        return builder.ToString().Trim('-');
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
            return $"{bytes} B";

        if (bytes < 1024 * 1024)
            return $"{Math.Round(bytes / 1024d, 1)} KB";

        return $"{Math.Round(bytes / 1024d / 1024d, 1)} MB";
    }

    private static string BuildImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
            return string.Empty;

        if (imageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return imageUrl;

        return $"https://localhost:7145{imageUrl}";
    }

    private sealed class PreparedUploadFile
    {
        public string UploadName { get; set; } = string.Empty;
        public string ContentType { get; set; } = string.Empty;
        public byte[] Content { get; set; } = Array.Empty<byte>();
    }
}
