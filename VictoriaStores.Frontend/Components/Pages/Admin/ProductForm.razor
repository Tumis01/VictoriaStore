@page "/admin/products/new"
@page "/admin/products/edit/{Id:guid}"
@layout Layout.AdminLayout
@inject HttpClient Http
@inject NavigationManager NavManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using System.Globalization
@using System.IO
@using System.Linq
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Text
@using Microsoft.AspNetCore.Components.Forms
@using VictoriaStores.Frontend.Models

<PageTitle>@(IsEditMode ? "Edit Product" : "Add New Product") - Victoria Admin</PageTitle>

<div class="flex items-center gap-4 mb-6">
    <button @onclick='() => NavManager.NavigateTo("/admin/products")' class="p-2 rounded-full hover:bg-gray-200 text-gray-500 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
    </button>
    <div>
        <h1 class="text-2xl font-bold text-gray-900 font-serif">@(IsEditMode ? "Edit Product" : "Add New Product")</h1>
        <p class="text-sm text-gray-500 mt-0.5">Fill out the details below to update your catalog.</p>
    </div>
</div>

@if (isLoading)
{
    <div class="flex h-64 items-center justify-center">
        <svg class="animate-spin h-10 w-10 text-brand" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
    </div>
}
else
{
    <EditForm Model="productModel" OnValidSubmit="SaveProduct" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <DataAnnotationsValidator />

        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-lg font-bold text-gray-900 font-serif mb-4">Basic Information</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Product Name <span class="text-red-500">*</span></label>
                        <InputText @bind-Value="productModel.Name" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition-colors" placeholder="e.g. Premium Non-Stick Frying Pan" />
                        <ValidationMessage For="@(() => productModel.Name)" class="text-xs text-red-500 mt-1" />
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">SKU</label>
                            <InputText @bind-Value="productModel.SKU" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition-colors" placeholder="Auto-generated if left blank" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Slug</label>
                            <InputText @bind-Value="productModel.Slug" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition-colors" placeholder="Auto-generated from name if left blank" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Description</label>
                        <InputTextArea @bind-Value="productModel.Description" rows="5" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition-colors" placeholder="Detailed product description..."></InputTextArea>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Available Colors</label>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var color in predefinedColors)
                            {
                                <button type="button"
                                        @onclick="() => ToggleColor(color)"
                                        class="@(productModel.Colors.Contains(color) ? "bg-brand text-white border-brand" : "bg-white text-gray-600 border-gray-300 hover:bg-gray-50") px-4 py-1.5 rounded-full border text-sm font-semibold transition-colors shadow-sm">
                                    @color
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-bold text-gray-900 font-serif">Media</h3>
                    <span class="text-xs font-semibold text-gray-500">Up to @MaxFileCount images, optimized before upload</span>
                </div>

                <label for="product-images" class="block border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:bg-gray-50 transition-colors cursor-pointer">
                    <div class="mx-auto w-12 h-12 bg-brand-light text-brand rounded-full flex items-center justify-center mb-3">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                    <p class="text-sm font-bold text-brand">Click to upload <span class="text-gray-500 font-normal">product image(s)</span></p>
                    <p class="text-xs text-gray-400 mt-1">PNG, JPG, JPEG, WEBP, GIF or SVG</p>
                    <p class="text-xs text-gray-400 mt-1">Images are resized to 1024px and converted to JPEG before upload</p>
                </label>

                <InputFile id="product-images" OnChange="HandleFilesSelected" accept="image/*" multiple class="hidden" />

                @if (!string.IsNullOrWhiteSpace(uploadStatus))
                {
                    <div class="mt-4 rounded-lg border border-blue-200 bg-blue-50 p-4">
                        <p class="text-sm font-medium text-blue-800">@uploadStatus</p>
                    </div>
                }

                @if (selectedFiles.Any())
                {
                    <div class="mt-4 rounded-lg border border-green-200 bg-green-50 p-4">
                        <p class="text-sm font-semibold text-green-800 mb-3">Prepared files</p>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            @foreach (var file in selectedFiles)
                            {
                                <div class="rounded-lg border border-green-200 bg-white px-3 py-2">
                                    <p class="text-sm font-medium text-gray-800 truncate">@file.UploadName</p>
                                    <p class="text-xs text-gray-500">@FormatFileSize(file.Content.Length)</p>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (productModel.Images.Any())
                {
                    <div class="mt-6">
                        <p class="text-sm font-semibold text-gray-700 mb-3">Current gallery</p>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                            @foreach (var image in productModel.Images.OrderBy(i => i.DisplayOrder))
                            {
                                <div class="rounded-xl border border-gray-200 overflow-hidden bg-white">
                                    <div class="aspect-square bg-gray-50">
                                        <img src="@($"https://localhost:7145{image.ImageUrl}")" alt="@productModel.Name" class="h-full w-full object-cover" />
                                    </div>
                                    <div class="p-3">
                                        <div class="flex items-center justify-between gap-2">
                                            <span class="text-xs text-gray-500">Order: @image.DisplayOrder</span>
                                            @if (image.IsMain)
                                            {
                                                <span class="inline-flex items-center rounded-full bg-brand-light px-2 py-0.5 text-xs font-semibold text-brand">Main</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="space-y-6">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-lg font-bold text-gray-900 font-serif mb-4">Pricing</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Regular Price (₦) <span class="text-red-500">*</span></label>
                        <InputNumber @bind-Value="productModel.Price" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand outline-none" />
                        <ValidationMessage For="@(() => productModel.Price)" class="text-xs text-red-500 mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Sale Price (₦)</label>
                        <InputNumber @bind-Value="productModel.SalePrice" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand outline-none" />
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-lg font-bold text-gray-900 font-serif mb-4">Organization</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Category <span class="text-red-500">*</span></label>
                        <InputSelect @bind-Value="productModel.CategoryId" TValue="Guid" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand outline-none bg-white">
                            <option value="">Select a category</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Stock Quantity <span class="text-red-500">*</span></label>
                        <InputNumber @bind-Value="productModel.StockQuantity" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand outline-none" />
                        <ValidationMessage For="@(() => productModel.StockQuantity)" class="text-xs text-red-500 mt-1" />
                    </div>

                    <div class="flex items-center gap-3 pt-2">
                        <InputCheckbox @bind-Value="productModel.IsActive" id="isActive" class="w-5 h-5 text-brand border-gray-300 rounded focus:ring-brand" />
                        <label for="isActive" class="text-sm font-semibold text-gray-700 cursor-pointer">Product is Active</label>
                    </div>
                </div>
            </div>

            <div class="pt-4 flex flex-col gap-3">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="p-3 text-sm text-red-700 bg-red-100 rounded-lg">@errorMessage</div>
                }

                <button type="submit" disabled="@isSubmitting" class="h-12 w-full bg-brand text-white font-bold rounded-xl shadow-sm hover:bg-brand-dark transition-colors disabled:bg-gray-400">
                    @SaveButtonText
                </button>

                <button type="button" @onclick='() => NavManager.NavigateTo("/admin/products")' class="h-12 w-full bg-white border border-gray-300 text-gray-700 font-bold rounded-xl shadow-sm hover:bg-gray-50 transition-colors">
                    Cancel
                </button>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsEditMode => Id.HasValue;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? uploadStatus;

    private const int MaxFileCount = 5;
    private const long MaxFileSize = 1_500_000;

    private ProductDto productModel = new() { IsActive = true };
    private List<CategoryDto> categories = new();
    private List<PreparedUploadFile> selectedFiles = new();

    private readonly List<string> predefinedColors = new()
    {
        "Black", "White", "Red", "Blue", "Green", "Yellow", "Silver", "Gold", "Pink", "Brown", "Grey"
    };

    private string SaveButtonText =>
        isSubmitting
            ? (selectedFiles.Any() ? $"Uploading {selectedFiles.Count} image(s)..." : "Saving...")
            : (IsEditMode ? "Update Product" : "Save Product");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            categories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/category") ?? new();

            if (IsEditMode)
            {
                var fetched = await Http.GetFromJsonAsync<ProductDto>($"api/product/{Id}");
                if (fetched != null)
                {
                    productModel = fetched;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load required data. " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleColor(string color)
    {
        if (productModel.Colors.Contains(color))
        {
            productModel.Colors.Remove(color);
        }
        else
        {
            productModel.Colors.Add(color);
        }
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        uploadStatus = null;
        selectedFiles.Clear();

        IReadOnlyList<IBrowserFile> files;

        try
        {
            files = e.GetMultipleFiles(MaxFileCount);
        }
        catch (InvalidOperationException)
        {
            errorMessage = $"Please select no more than {MaxFileCount} images.";
            return;
        }

        var preparedFiles = new List<PreparedUploadFile>();
        var current = 0;

        foreach (var file in files)
        {
            current++;
            uploadStatus = $"Preparing image {current} of {files.Count}...";

            if (!file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
            {
                errorMessage = $"'{file.Name}' is not a valid image file.";
                selectedFiles.Clear();
                uploadStatus = null;
                return;
            }

            var resizedFile = await file.RequestImageFileAsync("image/jpeg", 1024, 1024);

            if (resizedFile.Size > MaxFileSize)
            {
                errorMessage = $"'{file.Name}' is still too large after optimization. Please use a smaller image.";
                selectedFiles.Clear();
                uploadStatus = null;
                return;
            }

            await using var inputStream = resizedFile.OpenReadStream(MaxFileSize);
            using var memoryStream = new MemoryStream();
            await inputStream.CopyToAsync(memoryStream);

            var safeBaseName = Path.GetFileNameWithoutExtension(file.Name);
            preparedFiles.Add(new PreparedUploadFile
            {
                UploadName = $"{safeBaseName}.jpg",
                ContentType = "image/jpeg",
                Content = memoryStream.ToArray()
            });
        }

        selectedFiles = preparedFiles;
        uploadStatus = $"{selectedFiles.Count} optimized image(s) ready to upload.";
    }

    private async Task<HttpRequestMessage> CreateAuthorizedRequest(HttpMethod method, string url, HttpContent content)
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");
        var request = new HttpRequestMessage(method, url)
        {
            Content = content
        };

        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }

        return request;
    }

    private async Task SaveProduct()
    {
        isSubmitting = true;
        errorMessage = null;
        uploadStatus = selectedFiles.Any()
            ? $"Uploading {selectedFiles.Count} image(s)..."
            : "Saving product...";

        try
        {
            if (string.IsNullOrWhiteSpace(productModel.Name))
            {
                errorMessage = "Product name is required.";
                return;
            }

            if (productModel.CategoryId == Guid.Empty)
            {
                errorMessage = "Please select a category.";
                return;
            }

            var slug = string.IsNullOrWhiteSpace(productModel.Slug)
                ? BuildSlug(productModel.Name)
                : BuildSlug(productModel.Slug);

            var sku = string.IsNullOrWhiteSpace(productModel.SKU)
                ? $"VJS-{DateTime.UtcNow:yyyyMMddHHmmss}"
                : productModel.SKU.Trim().ToUpperInvariant();

            using var content = new MultipartFormDataContent
            {
                { new StringContent(productModel.Name.Trim()), "Name" },
                { new StringContent(slug), "Slug" },
                { new StringContent(productModel.Description ?? string.Empty), "Description" },
                { new StringContent(productModel.Price.ToString(CultureInfo.InvariantCulture)), "Price" },
                { new StringContent(sku), "SKU" },
                { new StringContent(productModel.StockQuantity.ToString(CultureInfo.InvariantCulture)), "StockQuantity" },
                { new StringContent(productModel.CategoryId.ToString()), "CategoryId" },
                { new StringContent(productModel.IsActive.ToString()), "IsActive" }
            };

            if (productModel.SalePrice.HasValue)
            {
                content.Add(new StringContent(productModel.SalePrice.Value.ToString(CultureInfo.InvariantCulture)), "SalePrice");
            }

            foreach (var color in productModel.Colors)
            {
                content.Add(new StringContent(color), "Colors");
            }

            foreach (var file in selectedFiles)
            {
                var byteArrayContent = new ByteArrayContent(file.Content);
                byteArrayContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
                content.Add(byteArrayContent, "Images", file.UploadName);
            }

            var method = IsEditMode ? HttpMethod.Put : HttpMethod.Post;
            var url = IsEditMode ? $"api/product/{Id}" : "api/product";

            using var request = await CreateAuthorizedRequest(method, url, content);
            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                NavManager.NavigateTo("/admin/products");
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();

                errorMessage = (int)response.StatusCode switch
                {
                    401 => "Not authorised. Please log out and log back in.",
                    403 => "Access denied. Only Super Admin can manage products.",
                    409 => body,
                    400 => $"Validation error: {body}",
                    _ => $"Failed to save product (HTTP {(int)response.StatusCode}). {body}"
                };
            }
        }
        catch (TaskCanceledException)
        {
            errorMessage = "The upload took too long and was cancelled. Try fewer images or smaller files.";
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while saving the product: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
            uploadStatus = null;
        }
    }

    private static string BuildSlug(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var builder = new StringBuilder();
        var previousDash = false;

        foreach (var ch in value.Trim().ToLowerInvariant())
        {
            if (char.IsLetterOrDigit(ch))
            {
                builder.Append(ch);
                previousDash = false;
            }
            else if (!previousDash)
            {
                builder.Append('-');
                previousDash = true;
            }
        }

        return builder.ToString().Trim('-');
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
            return $"{bytes} B";

        if (bytes < 1024 * 1024)
            return $"{Math.Round(bytes / 1024d, 1)} KB";

        return $"{Math.Round(bytes / 1024d / 1024d, 1)} MB";
    }

    private sealed class PreparedUploadFile
    {
        public string UploadName { get; set; } = string.Empty;
        public string ContentType { get; set; } = string.Empty;
        public byte[] Content { get; set; } = Array.Empty<byte>();
    }
}
