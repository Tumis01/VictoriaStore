@page "/admin/products/new"
@page "/admin/products/edit/{Id:guid}"
@layout Layout.AdminLayout
@inject HttpClient Http
@inject NavigationManager NavManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using System.Globalization
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Text
@using Microsoft.AspNetCore.Components.Forms
@using VictoriaStores.Frontend.Models

<PageTitle>@(IsEditMode ? "Edit Product" : "Add New Product") - Victoria Admin</PageTitle>

<div class="flex items-center gap-4 mb-6">
    <button @onclick='() => NavManager.NavigateTo("/admin/products")' class="p-2 rounded-full hover:bg-gray-200 text-gray-500 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
    </button>
    <div>
        <h1 class="text-2xl font-bold text-gray-900 font-serif">@(IsEditMode ? "Edit Product" : "Add New Product")</h1>
        <p class="text-sm text-gray-500 mt-0.5">Fill out the details below to update your catalog.</p>
    </div>
</div>

@if (isLoading)
{
    <div class="flex h-64 items-center justify-center">
        <svg class="animate-spin h-10 w-10 text-brand" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
    </div>
}
else
{
    <EditForm Model="productModel" OnValidSubmit="SaveProduct" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <DataAnnotationsValidator />

        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-lg font-bold text-gray-900 font-serif mb-4">Basic Information</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Product Name <span class="text-red-500">*</span></label>
                        <InputText @bind-Value="productModel.Name" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition-colors" placeholder="e.g. Premium Non-Stick Frying Pan" />
                        <ValidationMessage For="@(() => productModel.Name)" class="text-xs text-red-500 mt-1" />
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">SKU</label>
                            <InputText @bind-Value="productModel.SKU" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition-colors" placeholder="Auto-generated if left blank" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Slug</label>
                            <InputText @bind-Value="productModel.Slug" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition-colors" placeholder="Auto-generated from name if left blank" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Description</label>
                        <InputTextArea @bind-Value="productModel.Description" rows="5" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand focus:border-transparent outline-none transition-colors" placeholder="Detailed product description..."></InputTextArea>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Available Colors</label>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var color in predefinedColors)
                            {
                                <button type="button" @onclick="() => ToggleColor(color)" class="@(productModel.Colors.Contains(color) ? "bg-brand text-white border-brand" : "bg-white text-gray-600 border-gray-300 hover:bg-gray-50") px-4 py-1.5 rounded-full border text-sm font-semibold transition-colors shadow-sm">
                                    @color
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-lg font-bold text-gray-900 font-serif mb-4">Media</h3>
                <label for="product-images" class="block border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:bg-gray-50 transition-colors cursor-pointer">
                    <div class="mx-auto w-12 h-12 bg-brand-light text-brand rounded-full flex items-center justify-center mb-3">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                    <p class="text-sm font-bold text-brand">Click to upload <span class="text-gray-500 font-normal">product image(s)</span></p>
                </label>
                <InputFile id="product-images" OnChange="HandleFilesSelected" accept="image/*" multiple class="hidden" />

                @if (!string.IsNullOrWhiteSpace(productModel.MainImageUrl))
                {
                    <div class="mt-4">
                        <p class="text-sm font-semibold text-gray-700 mb-2">Current image</p>
                        <img src="@($"https://localhost:7145{productModel.MainImageUrl}")" alt="@productModel.Name" class="h-32 w-32 rounded-lg border object-cover" />
                    </div>
                }
            </div>
        </div>

        <div class="space-y-6">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-lg font-bold text-gray-900 font-serif mb-4">Pricing</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Regular Price (₦) <span class="text-red-500">*</span></label>
                        <InputNumber @bind-Value="productModel.Price" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand outline-none" />
                        <ValidationMessage For="@(() => productModel.Price)" class="text-xs text-red-500 mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Sale Price (₦)</label>
                        <InputNumber @bind-Value="productModel.SalePrice" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand outline-none" />
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-lg font-bold text-gray-900 font-serif mb-4">Organization</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Category <span class="text-red-500">*</span></label>
                        <InputSelect @bind-Value="productModel.CategoryId" TValue="Guid" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand outline-none bg-white">
                            <option value="">Select a category</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => productModel.CategoryId)" class="text-xs text-red-500 mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Stock Quantity <span class="text-red-500">*</span></label>
                        <InputNumber @bind-Value="productModel.StockQuantity" class="h-11 w-full px-4 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand outline-none" />
                        <ValidationMessage For="@(() => productModel.StockQuantity)" class="text-xs text-red-500 mt-1" />
                    </div>
                    <div class="flex items-center gap-3 pt-2">
                        <InputCheckbox @bind-Value="productModel.IsActive" id="isActive" class="w-5 h-5 text-brand border-gray-300 rounded focus:ring-brand" />
                        <label for="isActive" class="text-sm font-semibold text-gray-700 cursor-pointer">Product is Active</label>
                    </div>
                </div>
            </div>

            <div class="pt-4 flex flex-col gap-3">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="p-3 text-sm text-red-700 bg-red-100 rounded-lg">@errorMessage</div>
                }
                <button type="submit" disabled="@isSubmitting" class="h-12 w-full bg-brand text-white font-bold rounded-xl shadow-sm hover:bg-brand-dark transition-colors disabled:bg-gray-400">
                    @(isSubmitting ? "Saving..." : (IsEditMode ? "Update Product" : "Save Product"))
                </button>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsEditMode => Id.HasValue;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? errorMessage;

    private ProductDto productModel = new() { IsActive = true };
    private List<CategoryDto> categories = new();
    private IReadOnlyList<IBrowserFile> selectedFiles = Array.Empty<IBrowserFile>();

    // Standard list of colors for the admin to choose from
    private List<string> predefinedColors = new() { "Black", "White", "Red", "Blue", "Green", "Yellow", "Silver", "Gold", "Pink", "Brown", "Grey" };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            categories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/category") ?? new();

            if (IsEditMode)
            {
                var fetched = await Http.GetFromJsonAsync<ProductDto>($"api/product/{Id}");
                if (fetched != null) productModel = fetched;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load required data. " + ex.Message;
        }
        finally { isLoading = false; }
    }

    private void ToggleColor(string color)
    {
        if (productModel.Colors.Contains(color))
        {
            productModel.Colors.Remove(color);
        }
        else
        {
            productModel.Colors.Add(color);
        }
    }

    private void HandleFilesSelected(InputFileChangeEventArgs e)
    {
        selectedFiles = e.GetMultipleFiles(10);
    }

    private async Task<HttpRequestMessage> CreateAuthorizedRequest(HttpMethod method, string url, HttpContent content)
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");
        var request = new HttpRequestMessage(method, url) { Content = content };
        if (!string.IsNullOrWhiteSpace(token)) request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
        return request;
    }

    private async Task SaveProduct()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var slug = string.IsNullOrWhiteSpace(productModel.Slug) ? BuildSlug(productModel.Name) : BuildSlug(productModel.Slug);
            var sku = string.IsNullOrWhiteSpace(productModel.SKU) ? $"VJS-{DateTime.UtcNow:yyyyMMddHHmmss}" : productModel.SKU.Trim().ToUpperInvariant();

            using var content = new MultipartFormDataContent
            {
                { new StringContent(productModel.Name.Trim()), "Name" },
                { new StringContent(slug), "Slug" },
                { new StringContent(productModel.Description ?? string.Empty), "Description" },
                { new StringContent(productModel.Price.ToString(CultureInfo.InvariantCulture)), "Price" },
                { new StringContent(sku), "SKU" },
                { new StringContent(productModel.StockQuantity.ToString(CultureInfo.InvariantCulture)), "StockQuantity" },
                { new StringContent(productModel.CategoryId.ToString()), "CategoryId" },
                { new StringContent(productModel.IsActive.ToString()), "IsActive" }
            };

            if (productModel.SalePrice.HasValue)
                content.Add(new StringContent(productModel.SalePrice.Value.ToString(CultureInfo.InvariantCulture)), "SalePrice");

            // Attach selected colors
            foreach (var color in productModel.Colors)
            {
                content.Add(new StringContent(color), "Colors");
            }

            foreach (var file in selectedFiles)
            {
                var streamContent = new StreamContent(file.OpenReadStream(10 * 1024 * 1024));
                streamContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
                content.Add(streamContent, "Images", file.Name);
            }

            // Execute PUT for Edit, POST for New
            HttpMethod method = IsEditMode ? HttpMethod.Put : HttpMethod.Post;
            string url = IsEditMode ? $"api/product/{Id}" : "api/product";

            using var request = await CreateAuthorizedRequest(method, url, content);
            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                NavManager.NavigateTo("/admin/products");
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = $"Validation error: {body}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while saving the product: " + ex.Message;
        }
        finally { isSubmitting = false; }
    }

    private static string BuildSlug(string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;
        var builder = new StringBuilder();
        var previousDash = false;
        foreach (var ch in value.Trim().ToLowerInvariant())
        {
            if (char.IsLetterOrDigit(ch)) { builder.Append(ch); previousDash = false; }
            else if (!previousDash) { builder.Append('-'); previousDash = true; }
        }
        return builder.ToString().Trim('-');
    }
}