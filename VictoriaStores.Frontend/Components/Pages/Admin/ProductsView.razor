@page "/admin/products"
@layout Layout.AdminLayout
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Linq
@using VictoriaStores.Frontend.Models

<PageTitle>Products - Victoria Admin</PageTitle>

<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-on-surface font-serif">Products</h1>
        <p class="text-sm text-outline mt-0.5">Manage your store inventory, pricing, and stock.</p>
    </div>
    <div class="flex items-center gap-3">
        <a href="/admin/products/new" class="h-10 px-4 bg-primary text-white font-semibold text-sm rounded-lg hover:bg-primary-dark transition-colors shadow-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-[20px]">add</span>
            Add Product
        </a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="mb-4 rounded-md bg-red-50 p-4 border border-red-200">
        <p class="text-sm font-medium text-red-800">@errorMessage</p>
    </div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="mb-4 rounded-md bg-green-50 p-4 border border-green-200">
        <p class="text-sm font-medium text-green-800">@successMessage</p>
    </div>
}

<div class="bg-surface-container-lowest rounded-t-xl border border-outline-variant/30 border-b-0 p-4 flex flex-col sm:flex-row gap-4 justify-between items-center shadow-sm">
    <div class="flex items-center gap-3 w-full sm:w-auto">
        <div class="relative flex-1 sm:w-80">
            <span class="material-symbols-outlined text-[20px]">search</span>
            <input type="text" @bind="searchTerm" @bind:event="oninput" placeholder="Search products by name..." class="h-10 w-full pl-10 pr-4 rounded-lg bg-surface-container-low border border-transparent focus:border-primary focus:bg-surface-container-lowest text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors" />
        </div>
    </div>
    <div class="flex items-center gap-3 w-full sm:w-auto overflow-x-auto custom-scrollbar">
        @if (selectedProductIds.Any())
        {
            <div class="flex items-center bg-primary/10 text-primary px-3 h-10 rounded-lg text-sm font-bold border border-primary/20 whitespace-nowrap">
                <span>@selectedProductIds.Count selected</span>
                <div class="w-px h-5 bg-primary/20 mx-3"></div>
                <button @onclick="DeleteSelected" class="hover:text-red-600 transition-colors flex items-center gap-1">
                    <span class="material-symbols-outlined text-[20px]">delete</span>
                    Delete
                </button>
            </div>
        }
        <select @bind="statusFilter" class="h-10 px-3 rounded-lg border border-outline-variant/50 text-sm focus:outline-none focus:ring-2 focus:ring-primary bg-surface-container-lowest flex-1 sm:flex-none">
            <option value="">All Statuses</option>
            <option value="in_stock">In Stock</option>
            <option value="out_of_stock">Out of Stock</option>
        </select>
    </div>
</div>

<div class="bg-surface-container-lowest rounded-b-xl border border-outline-variant/30 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm text-left">
            <thead class="bg-surface-container-low border-b border-outline-variant/15">
                <tr>
                    <th class="w-12 px-5 py-3 text-center">
                        <input type="checkbox" checked="@IsAllSelected" @onchange="ToggleSelectAll" class="w-4 h-4 rounded border-outline-variant/50 text-primary focus:ring-primary transition-colors" />
                    </th>
                    <th class="px-5 py-3 text-xs font-bold text-outline uppercase tracking-wider">Product</th>
                    <th class="px-5 py-3 text-xs font-bold text-outline uppercase tracking-wider">Price</th>
                    <th class="px-5 py-3 text-xs font-bold text-outline uppercase tracking-wider">Stock</th>
                    <th class="px-5 py-3 text-xs font-bold text-outline uppercase tracking-wider">Status</th>
                    <th class="px-5 py-3 text-xs font-bold text-outline uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (isLoading)
                {
                    <tr>
                        <td colspan="6" class="px-5 py-12 text-center">
                            <svg class="animate-spin h-8 w-8 text-primary mx-auto" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        </td>
                    </tr>
                }
                else if (!FilteredProducts.Any())
                {
                    <tr><td colspan="6" class="px-5 py-12 text-center text-outline">No products found matching your criteria.</td></tr>
                }
                else
                {
                    @foreach (var product in PagedProducts)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors duration-150 group cursor-pointer" @onclick="() => ToggleSelection(product.Id, !selectedProductIds.Contains(product.Id))">
                            <td class="px-5 py-4 text-center select-none" @onclick:stopPropagation="true">
                                <input type="checkbox" checked="@selectedProductIds.Contains(product.Id)" @onchange="@(e => ToggleSelection(product.Id, e.Value))" class="w-4 h-4 rounded border-outline-variant/50 text-primary focus:ring-primary" />
                            </td>
                            <td class="px-5 py-4">
                                <div class="flex items-center gap-4">
                                    <div class="h-12 w-12 rounded-lg bg-surface-container border border-outline-variant/30 overflow-hidden flex-shrink-0">
                                        @if (!string.IsNullOrEmpty(product.MainImageUrl))
                                        {
                                            <img src="https://localhost:7145@(product.MainImageUrl)" class="h-full w-full object-cover mix-blend-multiply" alt="@product.Name" />
                                        }
                                        else
                                        {
                                            <span class="flex items-center justify-center h-full text-outline-variant">
                                                <span class="material-symbols-outlined text-[20px]">image</span>
                                            </span>
                                        }
                                    </div>
                                    <div>
                                        <div class="font-bold text-on-surface group-hover:text-primary transition-colors">@product.Name</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-5 py-4">
                                <div class="font-bold text-on-surface">₦@product.Price.ToString("N0")</div>
                                @if (product.SalePrice.HasValue)
                                {
                                    <div class="text-xs text-tertiary font-semibold">Sale: ₦@product.SalePrice.Value.ToString("N0")</div>
                                }
                            </td>
                            <td class="px-5 py-4 font-medium text-on-surface-variant">@product.StockQuantity units</td>
                            <td class="px-5 py-4">
                                @if (product.StockQuantity > 10)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-800 border border-green-200 shadow-sm">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-600 mr-1.5"></span> In Stock
                                    </span>
                                }
                                else if (product.StockQuantity > 0)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-amber-100 text-amber-800 border border-amber-200 shadow-sm">
                                        <span class="w-1.5 h-1.5 rounded-full bg-amber-600 mr-1.5 animate-pulse"></span> Low Stock
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-red-100 text-red-800 border border-red-200 shadow-sm">
                                        <span class="w-1.5 h-1.5 rounded-full bg-red-600 mr-1.5"></span> Out of Stock
                                    </span>
                                }
                            </td>
                            <td class="px-5 py-4 text-right">
                                <div class="flex items-center justify-end gap-4 transition-opacity">
                                    <a href="/admin/products/edit/@product.Id" class="text-primary hover:text-primary-dark font-bold">Edit</a>
                                    <button @onclick="() => DeleteProduct(product.Id)" class="text-red-500 hover:text-red-700 font-bold">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (FilteredProducts.Any() && totalPages > 1)
    {
        <div class="px-5 py-4 border-t border-outline-variant/30 bg-surface-container-low flex items-center justify-between">
            <span class="text-sm font-medium text-outline">Showing @(((currentPage - 1) * pageSize) + 1) to @Math.Min(currentPage * pageSize, FilteredProducts.Count()) of <span class="font-bold text-on-surface">@FilteredProducts.Count()</span></span>
            <div class="flex gap-2">
                <button disabled="@(currentPage == 1)" @onclick="() => currentPage--" class="h-9 px-4 border border-outline-variant/50 rounded-lg text-sm font-bold bg-surface-container-lowest text-on-surface-variant hover:bg-surface-container-low transition-colors disabled:opacity-50 disabled:cursor-not-allowed shadow-sm flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    Prev
                </button>
                <div class="hidden sm:flex items-center gap-1">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var pageNum = i;
                        if (totalPages <= 5 || i == 1 || i == totalPages || Math.Abs(i - currentPage) <= 1)
                        {
                            <button @onclick="() => currentPage = pageNum" class="w-9 h-9 flex items-center justify-center border font-bold text-sm rounded-lg transition-colors @(currentPage == pageNum ? "bg-primary text-white border-primary shadow-sm" : "bg-surface-container-lowest text-on-surface-variant border-outline-variant/50 hover:bg-surface-container-low")">@pageNum</button>
                        }
                        else if (Math.Abs(i - currentPage) == 2)
                        {
                            <span class="px-1 text-outline-variant">...</span>
                        }
                    }
                </div>
                <button disabled="@(currentPage == totalPages)" @onclick="() => currentPage++" class="h-9 px-4 border border-outline-variant/50 rounded-lg text-sm font-bold bg-surface-container-lowest text-on-surface-variant hover:bg-surface-container-low transition-colors disabled:opacity-50 disabled:cursor-not-allowed shadow-sm flex items-center gap-1">
                    Next
                    <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                </button>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<ProductDto> products = new();
    private string searchTerm = string.Empty;
    private string statusFilter = string.Empty;
    private string? errorMessage;
    private string? successMessage;
    
    private int currentPage = 1;
    private int pageSize = 10;
    private HashSet<Guid> selectedProductIds = new();

    private IEnumerable<ProductDto> FilteredProducts => products.Where(p =>
        (string.IsNullOrWhiteSpace(searchTerm) || p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrWhiteSpace(statusFilter) ||
            (statusFilter == "in_stock" && p.StockQuantity > 0) ||
            (statusFilter == "out_of_stock" && p.StockQuantity <= 0))
    );

    private IEnumerable<ProductDto> PagedProducts => FilteredProducts.Skip((currentPage - 1) * pageSize).Take(pageSize);
    private int totalPages => Math.Max(1, (int)Math.Ceiling(FilteredProducts.Count() / (double)pageSize));

    private bool IsAllSelected => PagedProducts.Any() && PagedProducts.All(p => selectedProductIds.Contains(p.Id));

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        if (isChecked)
        {
            foreach (var p in PagedProducts) selectedProductIds.Add(p.Id);
        }
        else
        {
            foreach (var p in PagedProducts) selectedProductIds.Remove(p.Id);
        }
    }

    private void ToggleSelection(Guid id, object? isChecked)
    {
        if ((bool)(isChecked ?? false)) selectedProductIds.Add(id);
        else selectedProductIds.Remove(id);
    }

    private async Task DeleteSelected()
    {
        if (!selectedProductIds.Any()) return;
        var idsToDelete = selectedProductIds.ToList();
        foreach (var id in idsToDelete)
        {
            await DeleteProduct(id);
        }
        selectedProductIds.Clear();
        // Adjust pagination if necessary
        if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task<HttpRequestMessage> CreateAuthorizedRequest(HttpMethod method, string url)
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");
        var request = new HttpRequestMessage(method, url);

        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }

        return request;
    }

    private async Task LoadProducts()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            using var request = await CreateAuthorizedRequest(HttpMethod.Get, "api/product/admin");
            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                products = await response.Content.ReadFromJsonAsync<List<ProductDto>>() ?? new();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = (int)response.StatusCode switch
                {
                    401 => "Not authorised. Please log out and log back in.",
                    403 => "Access denied. Only Super Admin can manage products.",
                    _ => $"Failed to load products (HTTP {(int)response.StatusCode}). {body}"
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while loading products.";
            Console.WriteLine($"Load products failed: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteProduct(Guid id)
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            using var request = await CreateAuthorizedRequest(HttpMethod.Delete, $"api/product/{id}");
            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                products.RemoveAll(p => p.Id == id);
                successMessage = "Product deleted successfully.";
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = (int)response.StatusCode switch
                {
                    401 => "Not authorised. Please log out and log back in.",
                    403 => "Access denied. Only Super Admin can manage products.",
                    404 => "Product not found.",
                    _ => $"Failed to delete product (HTTP {(int)response.StatusCode}). {body}"
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while deleting the product.";
            Console.WriteLine($"Delete failed: {ex.Message}");
        }
    }
}
