@page "/admin/products"
@layout Layout.AdminLayout
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Linq
@using VictoriaStores.Frontend.Models

<PageTitle>Products - Victoria Admin</PageTitle>

<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900 font-serif">Products</h1>
        <p class="text-sm text-gray-500 mt-0.5">Manage your store inventory, pricing, and stock.</p>
    </div>
    <div class="flex items-center gap-3">
        <a href="/admin/products/new" class="h-10 px-4 bg-brand text-white font-semibold text-sm rounded-lg hover:bg-brand-dark transition-colors shadow-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Add Product
        </a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="mb-4 rounded-md bg-red-50 p-4 border border-red-200">
        <p class="text-sm font-medium text-red-800">@errorMessage</p>
    </div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="mb-4 rounded-md bg-green-50 p-4 border border-green-200">
        <p class="text-sm font-medium text-green-800">@successMessage</p>
    </div>
}

<div class="bg-white rounded-t-xl border border-gray-200 border-b-0 p-4 flex flex-col sm:flex-row gap-4 justify-between items-center shadow-sm">
    <div class="relative w-full sm:w-96">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        <input type="text" @bind="searchTerm" @bind:event="oninput" placeholder="Search products by name..." class="h-10 w-full pl-10 pr-4 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition-colors" />
    </div>
    <div class="flex items-center gap-3 w-full sm:w-auto">
        <select @bind="statusFilter" class="h-10 px-3 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand bg-white flex-1 sm:flex-none">
            <option value="">All Statuses</option>
            <option value="in_stock">In Stock</option>
            <option value="out_of_stock">Out of Stock</option>
        </select>
    </div>
</div>

<div class="bg-white rounded-b-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm text-left">
            <thead class="bg-gray-50">
                <tr>
                    <th class="w-12 px-5 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider text-center">#</th>
                    <th class="px-5 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Product</th>
                    <th class="px-5 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Price</th>
                    <th class="px-5 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Stock</th>
                    <th class="px-5 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-5 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (isLoading)
                {
                    <tr>
                        <td colspan="6" class="px-5 py-12 text-center">
                            <svg class="animate-spin h-8 w-8 text-brand mx-auto" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        </td>
                    </tr>
                }
                else if (!FilteredProducts.Any())
                {
                    <tr><td colspan="6" class="px-5 py-12 text-center text-gray-500">No products found matching your criteria.</td></tr>
                }
                else
                {
                    var index = 1;
                    @foreach (var product in FilteredProducts)
                    {
                        <tr class="hover:bg-gray-50 transition-colors duration-150 group">
                            <td class="px-5 py-4 text-center font-semibold text-gray-500">@(index++)</td>
                            <td class="px-5 py-4">
                                <div class="flex items-center gap-4">
                                    <div class="h-12 w-12 rounded-lg bg-gray-100 border border-gray-200 overflow-hidden flex-shrink-0">
                                        @if (!string.IsNullOrEmpty(product.MainImageUrl))
                                        {
                                            <img src="https://localhost:7145@(product.MainImageUrl)" class="h-full w-full object-cover mix-blend-multiply" alt="@product.Name" />
                                        }
                                        else
                                        {
                                            <span class="flex items-center justify-center h-full text-gray-400">
                                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                            </span>
                                        }
                                    </div>
                                    <div>
                                        <div class="font-bold text-gray-900 group-hover:text-brand transition-colors">@product.Name</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-5 py-4">
                                <div class="font-bold text-gray-900">₦@product.Price.ToString("N0")</div>
                                @if (product.SalePrice.HasValue)
                                {
                                    <div class="text-xs text-accent font-semibold">Sale: ₦@product.SalePrice.Value.ToString("N0")</div>
                                }
                            </td>
                            <td class="px-5 py-4 font-medium text-gray-700">@product.StockQuantity units</td>
                            <td class="px-5 py-4">
                                @if (product.StockQuantity > 10)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700 border border-green-200">In Stock</span>
                                }
                                else if (product.StockQuantity > 0)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-700 border border-amber-200">Low Stock</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700 border border-red-200">Out of Stock</span>
                                }
                            </td>
                            <td class="px-5 py-4 text-right">
                                <div class="flex items-center justify-end gap-4 transition-opacity">
                                    <a href="/admin/products/edit/@product.Id" class="text-brand hover:text-brand-dark font-bold">Edit</a>
                                    <button @onclick="() => DeleteProduct(product.Id)" class="text-red-500 hover:text-red-700 font-bold">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private bool isLoading = true;
    private List<ProductDto> products = new();
    private string searchTerm = string.Empty;
    private string statusFilter = string.Empty;
    private string? errorMessage;
    private string? successMessage;

    private IEnumerable<ProductDto> FilteredProducts => products.Where(p =>
        (string.IsNullOrWhiteSpace(searchTerm) || p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrWhiteSpace(statusFilter) ||
            (statusFilter == "in_stock" && p.StockQuantity > 0) ||
            (statusFilter == "out_of_stock" && p.StockQuantity <= 0))
    );

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task<HttpRequestMessage> CreateAuthorizedRequest(HttpMethod method, string url)
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");
        var request = new HttpRequestMessage(method, url);

        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }

        return request;
    }

    private async Task LoadProducts()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            using var request = await CreateAuthorizedRequest(HttpMethod.Get, "api/product/admin");
            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                products = await response.Content.ReadFromJsonAsync<List<ProductDto>>() ?? new();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = (int)response.StatusCode switch
                {
                    401 => "Not authorised. Please log out and log back in.",
                    403 => "Access denied. Only Super Admin can manage products.",
                    _ => $"Failed to load products (HTTP {(int)response.StatusCode}). {body}"
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while loading products.";
            Console.WriteLine($"Load products failed: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteProduct(Guid id)
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            using var request = await CreateAuthorizedRequest(HttpMethod.Delete, $"api/product/{id}");
            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                products.RemoveAll(p => p.Id == id);
                successMessage = "Product deleted successfully.";
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = (int)response.StatusCode switch
                {
                    401 => "Not authorised. Please log out and log back in.",
                    403 => "Access denied. Only Super Admin can manage products.",
                    404 => "Product not found.",
                    _ => $"Failed to delete product (HTTP {(int)response.StatusCode}). {body}"
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while deleting the product.";
            Console.WriteLine($"Delete failed: {ex.Message}");
        }
    }
}
