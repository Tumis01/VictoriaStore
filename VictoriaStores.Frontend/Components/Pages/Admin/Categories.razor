@page "/admin/categories"
@layout Layout.AdminLayout
@inject HttpClient Http
@using VictoriaStores.Frontend.Models

<PageTitle>Manage Categories - Victoria Admin</PageTitle>

<div class="flex items-center justify-between mb-6">
    <div>
        <h2 class="text-2xl font-semibold text-gray-800">Categories</h2>
        <p class="text-sm text-gray-500 mt-1">Organize your store's product catalog.</p>
    </div>
    <button @onclick="ToggleAddForm" class="flex items-center justify-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
        <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Add Category
    </button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="mb-4 rounded-md bg-red-50 p-4 border border-red-200">
        <p class="text-sm font-medium text-red-800">@errorMessage</p>
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="mb-4 rounded-md bg-green-50 p-4 border border-green-200">
        <p class="text-sm font-medium text-green-800">@successMessage</p>
    </div>
}

@if (showAddForm)
{
    <div class="mb-8 rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all">
        <h3 class="mb-4 text-lg font-medium text-gray-900">Create New Category</h3>
        <EditForm Model="newCategory" OnValidSubmit="HandleSubmit" class="space-y-4">
            <DataAnnotationsValidator />
            
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                    <label class="block text-sm font-medium text-gray-700">Category Name</label>
                    <InputText @bind-Value="newCategory.Name" required class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 sm:text-sm" placeholder="e.g., Household Items" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Description</label>
                    <InputText @bind-Value="newCategory.Description" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 sm:text-sm" placeholder="Short description..." />
                </div>
            </div>

            <div class="flex justify-end space-x-3 pt-2">
                <button type="button" @onclick="ToggleAddForm" class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                    Cancel
                </button>
                <button type="submit" disabled="@isSubmitting" class="flex items-center justify-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-700 disabled:bg-blue-400">
                    @if (isSubmitting)
                    {
                        <svg class="mr-2 h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save Category</span>
                    }
                </button>
            </div>
        </EditForm>
    </div>
}

<div class="rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-gray-500">
            <thead class="bg-gray-50 text-xs uppercase text-gray-700">
                <tr>
                    <th scope="col" class="px-6 py-3">Category Name</th>
                    <th scope="col" class="px-6 py-3">Description</th>
                    <th scope="col" class="px-6 py-3 text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr>
                        <td colspan="3" class="px-6 py-8 text-center">
                            <div class="inline-block h-6 w-6 animate-spin rounded-full border-b-2 border-t-2 border-blue-600"></div>
                        </td>
                    </tr>
                }
                else if (!categories.Any())
                {
                    <tr>
                        <td colspan="3" class="px-6 py-8 text-center text-gray-500">No categories found. Start by adding one above.</td>
                    </tr>
                }
                else
                {
                    @foreach (var category in categories)
                    {
                        <tr class="border-b bg-white hover:bg-gray-50">
                            <td class="whitespace-nowrap px-6 py-4 font-medium text-gray-900">
                                @category.Name
                            </td>
                            <td class="px-6 py-4">
                                @category.Description
                            </td>
                            <td class="px-6 py-4 text-right">
                                <button class="font-medium text-blue-600 hover:text-blue-800 mr-3">Edit</button>
                                <button @onclick="() => DeleteCategory(category.Id)" class="font-medium text-red-600 hover:text-red-800">Delete</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool showAddForm = false;
    
    private string? errorMessage;
    private string? successMessage;
    
    private List<CategoryDto> categories = new();
    private CreateCategoryRequest newCategory = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        try
        {
            isLoading = true;
            categories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/category") ?? new List<CategoryDto>();
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load categories. Please check your connection.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleAddForm()
    {
        showAddForm = !showAddForm;
        errorMessage = null;
        successMessage = null;
        if (!showAddForm) 
        {
            newCategory = new CreateCategoryRequest(); // Reset form if closed
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/category", newCategory);

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Category added successfully!";
                newCategory = new CreateCategoryRequest();
                showAddForm = false;
                await LoadCategories();
            }
            else
            {
                // Read the actual error from the API for diagnosis
                var body = await response.Content.ReadAsStringAsync();

                errorMessage = (int)response.StatusCode switch
                {
                    401 => "Not authorised. Please log out and log back in.",
                    403 => "Access denied. Only Super Admin can manage categories.",
                    400 => $"Validation error: {body}",
                    _ => $"Failed to add category (HTTP {(int)response.StatusCode})."
                };

                Console.WriteLine($"[Category POST] {(int)response.StatusCode}: {body}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = "A network error occurred while saving the category.";
            Console.WriteLine($"[Category POST] Exception: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteCategory(Guid id)
    {
        // Note: In a production app, use a proper custom confirmation modal here.
        // For now, we proceed to delete.
        try
        {
            var response = await Http.DeleteAsync($"api/category/{id}");
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Category deleted successfully.";
                await LoadCategories();
            }
            else
            {
                errorMessage = "Failed to delete category. It might be in use by existing products.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while deleting the category.";
            Console.WriteLine(ex.Message);
        }
    }
}