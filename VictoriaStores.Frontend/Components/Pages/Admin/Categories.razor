@page "/admin/categories"
@layout Layout.AdminLayout
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using VictoriaStores.Frontend.Models

<PageTitle>Manage Categories - Victoria Admin</PageTitle>

<div class="flex items-center justify-between mb-6">
    <div>
        <h2 class="text-2xl font-semibold text-on-surface">Categories</h2>
        <p class="text-sm text-outline mt-1">Organize your store's product catalog.</p>
    </div>
    <button @onclick="ToggleAddForm" class="flex items-center justify-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
        <span class="material-symbols-outlined text-[20px]">add</span>
        @(showAddForm && editingCategoryId.HasValue ? "Cancel Edit" : "Add Category")
    </button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="mb-4 rounded-md bg-red-50 p-4 border border-red-200">
        <p class="text-sm font-medium text-red-800">@errorMessage</p>
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="mb-4 rounded-md bg-green-50 p-4 border border-green-200">
        <p class="text-sm font-medium text-green-800">@successMessage</p>
    </div>
}

@if (showAddForm)
{
    <div class="mb-8 rounded-xl border border-outline-variant/30 bg-surface-container-lowest p-6 shadow-sm transition-all">
        <h3 class="mb-4 text-lg font-medium text-on-surface">@(editingCategoryId.HasValue ? "Edit Category" : "Create New Category")</h3>
        <EditForm Model="newCategory" OnValidSubmit="HandleSubmit" FormName="categoryForm" class="space-y-4">
            <DataAnnotationsValidator />

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                    <label class="block text-sm font-medium text-on-surface-variant mb-1">Category Name <span class="text-red-500">*</span></label>
                    <InputText @bind-Value="newCategory.Name" class="block w-full rounded-md border border-outline-variant/50 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 sm:text-sm" placeholder="e.g., Household Items" />
                    <ValidationMessage For="@(() => newCategory.Name)" class="text-xs text-red-500 mt-1" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface-variant mb-1">Description</label>
                    <InputText @bind-Value="newCategory.Description" class="block w-full rounded-md border border-outline-variant/50 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 sm:text-sm" placeholder="Short description..." />
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-sm font-medium text-on-surface-variant mb-1">Category Banner Image</label>
                    <div class="mt-1 flex justify-center rounded-md border-2 border-dashed border-outline-variant/50 px-6 pt-5 pb-6 relative overflow-hidden">
                        <div class="space-y-1 text-center">
                            @if (!string.IsNullOrEmpty(imagePreviewUrl))
                            {
                                <img src="@imagePreviewUrl" class="mx-auto h-32 w-auto object-contain mb-3 rounded" />
                            }
                            else if (!string.IsNullOrEmpty(newCategory.BannerImageUrl))
                            {
                                // Show existing image from DB if editing
                                <img src="https://localhost:7145@(newCategory.BannerImageUrl)" class="mx-auto h-32 w-auto object-contain mb-3 rounded" />
                            }
                            else
                            {
                                <svg class="mx-auto h-12 w-12 text-outline-variant" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true"><path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                            }
                            <div class="flex text-sm text-on-surface-variant justify-center mt-2">
                                <label for="file-upload" class="relative cursor-pointer rounded-md bg-surface-container-lowest font-medium text-blue-600 focus-within:outline-none hover:text-blue-500 px-3 py-1 border border-blue-100">
                                    <span>Upload a file</span>
                                    <InputFile id="file-upload" OnChange="HandleFileChange" class="sr-only" accept="image/*" />
                                </label>
                            </div>
                            <p class="text-xs text-outline mt-2">PNG, JPG, GIF up to 2MB</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex justify-end space-x-3 pt-2">
                <button type="button" @onclick="CloseForm" class="rounded-md border border-outline-variant/50 bg-surface-container-lowest px-4 py-2 text-sm font-medium text-on-surface-variant shadow-sm hover:bg-surface-container-low">
                    Cancel
                </button>
                <button type="submit" disabled="@isSubmitting" class="flex items-center justify-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-700 disabled:bg-blue-400">
                    @if (isSubmitting)
                    {
                        <svg class="mr-2 h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>@(editingCategoryId.HasValue ? "Update Category" : "Save Category")</span>
                    }
                </button>
            </div>
        </EditForm>
    </div>
}

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 animate-fade-in">
    @if (isLoading)
    {
        @for (int i = 0; i < 4; i++)
        {
            <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/15 overflow-hidden h-64 animate-pulse">
                <div class="bg-surface-container-high h-32 w-full"></div>
                <div class="p-4 flex flex-col flex-1">
                    <div class="bg-surface-container-high h-4 w-1/2 mb-2 rounded"></div>
                    <div class="bg-surface-container-high h-3 w-3/4 mb-4 rounded"></div>
                    <div class="mt-auto flex justify-end gap-2">
                        <div class="bg-surface-container-high h-4 w-10 rounded"></div>
                        <div class="bg-surface-container-high h-4 w-10 rounded"></div>
                    </div>
                </div>
            </div>
        }
    }
    else if (!categories.Any())
    {
        <div class="col-span-full">
            <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/15 p-12 text-center max-w-2xl mx-auto">
                <div class="w-20 h-20 bg-primary-light/30 rounded-full flex items-center justify-center mx-auto mb-4 text-primary">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-on-surface mb-2">No categories found</h3>
                <p class="text-outline mb-6">Start by adding your first product category.</p>
                <button @onclick="ToggleAddForm" class="text-blue-600 font-bold hover:underline">Add Category</button>
            </div>
        </div>
    }
    else
    {
        @foreach (var category in categories)
        {
            <div class="bg-surface-container-lowest rounded-xl shadow-[0_2px_10px_-3px_rgba(6,81,237,0.1)] border border-outline-variant/15 overflow-hidden flex flex-col hover:shadow-lg transition-all hover:scale-[1.02]">
                @if (!string.IsNullOrEmpty(category.BannerImageUrl))
                {
                    <img src="https://localhost:7145@(category.BannerImageUrl)" alt="@category.Name" class="h-40 w-full object-cover" />
                }
                else
                {
                    <div class="h-40 w-full bg-gradient-to-br from-gray-100 to-gray-50 flex flex-col items-center justify-center text-outline-variant border-b border-outline-variant/15">
                        <span class="material-symbols-outlined text-[20px]">image</span>
                        <span class="text-xs font-semibold uppercase tracking-wider text-outline-variant">No Image</span>
                    </div>
                }
                <div class="p-5 flex-1 flex flex-col">
                    <h4 class="font-bold text-on-surface text-lg mb-1">@category.Name</h4>
                    <p class="text-sm text-outline mb-4 line-clamp-2 flex-1">@(string.IsNullOrEmpty(category.Description) ? "No description provided." : category.Description)</p>
                    
                    <div class="flex items-center justify-between pt-4 border-t border-outline-variant/15 mt-auto">
                        <span class="text-xs font-semibold text-outline-variant">Order: @category.DisplayOrder</span>
                        <div class="flex items-center gap-3">
                            <button @onclick="() => EditCategory(category)" class="text-xs font-bold text-blue-600 hover:text-on-primary-container transition-colors">Edit</button>
                            <button @onclick="() => DeleteCategory(category.Id)" class="text-xs font-bold text-red-500 hover:text-red-700 transition-colors">Delete</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool showAddForm = false;
    private Guid? editingCategoryId = null;

    private string? errorMessage;
    private string? successMessage;
    private List<CategoryDto> categories = new();
    private CreateCategoryRequest newCategory = new();
    
    // Image handling fields
    private IBrowserFile? selectedImageFile;
    private string? imagePreviewUrl;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task<HttpRequestMessage> CreateAuthorizedRequest(HttpMethod method, string url, object? body = null)
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");
        var request = new HttpRequestMessage(method, url);

        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }

        if (body is not null)
        {
            request.Content = JsonContent.Create(body);
        }

        return request;
    }

    private async Task LoadCategories()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            using var request = await CreateAuthorizedRequest(HttpMethod.Get, "api/category/admin");
            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                categories = await response.Content.ReadFromJsonAsync<List<CategoryDto>>() ?? new();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = (int)response.StatusCode switch
                {
                    401 => "Not authorised. Please log out and log back in.",
                    403 => "Access denied. Only Super Admin can manage categories.",
                    _ => $"Failed to load categories (HTTP {(int)response.StatusCode}). {body}"
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load categories. Please check your connection.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleAddForm()
    {
        if (showAddForm)
        {
            CloseForm();
            return;
        }

        showAddForm = true;
        editingCategoryId = null;
        newCategory = new CreateCategoryRequest();
        selectedImageFile = null;
        imagePreviewUrl = null;
        errorMessage = null;
    }

    private void CloseForm()
    {
        showAddForm = false;
        editingCategoryId = null;
        newCategory = new CreateCategoryRequest();
        selectedImageFile = null;
        imagePreviewUrl = null;
        errorMessage = null;
    }

    private void EditCategory(CategoryDto category)
    {
        editingCategoryId = category.Id;
        newCategory = new CreateCategoryRequest
        {
            Name = category.Name,
            Description = category.Description,
            Slug = category.Slug,
            BannerImageUrl = category.BannerImageUrl,
            DisplayOrder = category.DisplayOrder,
            IsActive = category.IsActive
        };
        selectedImageFile = null;
        imagePreviewUrl = null; // Clear preview so the DB image shows
        
        showAddForm = true;
        errorMessage = null;
        successMessage = null;
    }

    private async Task HandleFileChange(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file != null)
            {
                // Store the raw file for multipart upload later
                selectedImageFile = file;

                // Create a quick base64 preview for the UI ONLY
                var format = "image/png";
                var resizedImage = await file.RequestImageFileAsync(format, 600, 400);
                using var stream = resizedImage.OpenReadStream(1024 * 1024 * 5);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var base64 = Convert.ToBase64String(ms.ToArray());
                imagePreviewUrl = $"data:{format};base64,{base64}";
                
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error preparing image preview: " + ex.Message;
            Console.WriteLine(ex.Message);
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            // STEP 1: Create or Update the Category Data (JSON)
            var method = editingCategoryId.HasValue ? HttpMethod.Put : HttpMethod.Post;
            var url = editingCategoryId.HasValue ? $"api/category/{editingCategoryId.Value}" : "api/category";

            using var request = await CreateAuthorizedRequest(method, url, newCategory);
            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var categoryResult = await response.Content.ReadFromJsonAsync<CategoryDto>();
                var targetId = editingCategoryId ?? categoryResult?.Id;

                // STEP 2: Upload the Image (Multipart/form-data) if a file was selected
                if (targetId.HasValue && selectedImageFile != null)
                {
                    var token = await LocalStorage.GetItemAsync<string>("authToken");
                    
                    using var content = new MultipartFormDataContent();
                    
                    // Create a stream that doesn't close immediately
                    var fileStream = selectedImageFile.OpenReadStream(1024 * 1024 * 5); // 5MB max
                    var streamContent = new StreamContent(fileStream);
                    streamContent.Headers.ContentType = new MediaTypeHeaderValue(selectedImageFile.ContentType);
                    
                    // The "image" name must match the parameter name in the API controller: UploadImage(Guid id, IFormFile image)
                    content.Add(streamContent, "image", selectedImageFile.Name);

                    var uploadRequest = new HttpRequestMessage(HttpMethod.Post, $"api/category/{targetId.Value}/image");
                    if (!string.IsNullOrWhiteSpace(token))
                    {
                        uploadRequest.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
                    }
                    uploadRequest.Content = content;

                    var uploadResponse = await Http.SendAsync(uploadRequest);

                    if (!uploadResponse.IsSuccessStatusCode)
                    {
                        var errorBody = await uploadResponse.Content.ReadAsStringAsync();
                        errorMessage = $"Category saved, but image upload failed: {errorBody}";
                        isSubmitting = false;
                        return; // Stop here, don't close form, let user see error
                    }
                }

                var wasEditing = editingCategoryId.HasValue;
                CloseForm();
                successMessage = wasEditing ? "Category updated successfully." : "Category added successfully.";
                await LoadCategories();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to save category. {body}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "A network error occurred while saving the category.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteCategory(Guid id)
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            using var request = await CreateAuthorizedRequest(HttpMethod.Delete, $"api/category/{id}");
            using var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Category deleted successfully.";
                await LoadCategories();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = (int)response.StatusCode switch
                {
                    401 => "Not authorised. Please log out and log back in.",
                    403 => "Access denied. Only Super Admin can manage categories.",
                    404 => "Category not found.",
                    409 => body, // "Cannot delete because products are assigned"
                    _ => $"Failed to delete category. {body}"
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while deleting the category.";
            Console.WriteLine(ex.Message);
        }
    }
}