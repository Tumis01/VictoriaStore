@page "/how-to-order"
@layout Layout.StoreLayout

<PageTitle>How to Order - Victoria James Store</PageTitle>

<div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20 animate-fade-in">
    <div class="text-center mb-12">
        <h1 class="font-serif text-3xl md:text-4xl font-bold text-gray-900 mb-4">How to Place an Order</h1>
        <p class="text-gray-500 text-lg">Shopping with us is simple, secure, and fast.</p>
    </div>

    <div class="space-y-8 relative before:absolute before:inset-0 before:ml-6 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-1 before:bg-gray-100">
        
        <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
            <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand text-white font-bold text-xl shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 absolute left-0 md:left-1/2 z-10">1</div>
            <div class="w-[calc(100%-4rem)] md:w-[calc(50%-3rem)] ml-auto md:ml-0 p-6 rounded-2xl bg-white shadow-sm border border-gray-100">
                <h3 class="font-bold text-lg text-gray-900 mb-2">Find Your Products</h3>
                <p class="text-gray-600">Browse our store by category or use the search bar. Click on any product, choose your preferred color/quantity, and click "Add to Cart".</p>
            </div>
        </div>

        <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
            <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand text-white font-bold text-xl shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 absolute left-0 md:left-1/2 z-10">2</div>
            <div class="w-[calc(100%-4rem)] md:w-[calc(50%-3rem)] ml-auto md:ml-0 p-6 rounded-2xl bg-white shadow-sm border border-gray-100">
                <h3 class="font-bold text-lg text-gray-900 mb-2">Checkout & Details</h3>
                <p class="text-gray-600">Go to your cart and click "Proceed to Checkout". Enter your correct delivery address, phone number, and email.</p>
            </div>
        </div>

        <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
            <div class="flex items-center justify-center w-12 h-12 rounded-full bg-accent text-white font-bold text-xl shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 absolute left-0 md:left-1/2 z-10">3</div>
            <div class="w-[calc(100%-4rem)] md:w-[calc(50%-3rem)] ml-auto md:ml-0 p-6 rounded-2xl bg-brand-light/30 shadow-sm border border-brand/20">
                <h3 class="font-bold text-lg text-brand mb-2">Make Payment via Transfer</h3>
                <p class="text-gray-700">Once you place your order, you will see our Official Bank Details. Transfer the exact amount and send the payment proof to our WhatsApp number.</p>
            </div>
        </div>

        <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
            <div class="flex items-center justify-center w-12 h-12 rounded-full bg-green-500 text-white font-bold text-xl shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 absolute left-0 md:left-1/2 z-10">4</div>
            <div class="w-[calc(100%-4rem)] md:w-[calc(50%-3rem)] ml-auto md:ml-0 p-6 rounded-2xl bg-white shadow-sm border border-gray-100">
                <h3 class="font-bold text-lg text-gray-900 mb-2">Receive Your Order</h3>
                <p class="text-gray-600">We will verify your payment and dispatch your items immediately. You can track your order status live on our website!</p>
            </div>
        </div>
    </div>

    <div class="text-center mt-16">
        <a href="/store" class="inline-flex h-12 items-center justify-center px-8 bg-brand text-white font-bold rounded-lg shadow-sm hover:bg-brand-dark transition-colors">Start Shopping Now</a>
    </div>
</div>