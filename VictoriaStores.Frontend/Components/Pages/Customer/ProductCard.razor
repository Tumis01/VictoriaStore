@using VictoriaStores.Frontend.Models
@inject NavigationManager NavManager
@inject VictoriaStores.Frontend.Services.CartService Cart

<div class="group bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-200 overflow-hidden relative cursor-pointer @(IsListView ? "flex flex-row" : "flex flex-col")" @onclick="GoToDetails">
    
    <div class="@(IsListView ? "w-1/3 sm:w-1/4" : "aspect-square") bg-gray-50 relative overflow-hidden flex-shrink-0">
        @if (!string.IsNullOrEmpty(Product.MainImageUrl))
        {
            <img src="https://localhost:7145@(Product.MainImageUrl)" alt="@Product.Name" class="w-full h-full object-cover p-4 group-hover:scale-105 transition-transform duration-500 mix-blend-multiply" loading="lazy" decoding="async" />
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center text-gray-300">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
        }

        @if (Product.SalePrice.HasValue)
        {
            var discount = Math.Round((1 - (Product.SalePrice.Value / Product.Price)) * 100);
            <span class="absolute top-3 left-3 bg-accent text-white text-xs font-bold px-2 py-1 rounded-md shadow-sm">-@discount% OFF</span>
        }
        else if ((DateTime.UtcNow - Product.CreatedAt).TotalDays < 7)
        {
            <span class="absolute top-3 left-3 bg-brand text-white text-xs font-bold px-2 py-1 rounded-md shadow-sm">NEW</span>
        }

        <button class="absolute top-3 right-3 w-8 h-8 bg-white text-gray-400 hover:text-red-500 rounded-full flex items-center justify-center shadow hover:shadow-md transition-colors" @onclick:stopPropagation="true">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
        </button>

        <div class="absolute bottom-0 left-0 right-0 p-3 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
            <button class="w-full bg-white/90 backdrop-blur-sm text-gray-900 font-bold text-xs py-2 rounded shadow-sm hover:bg-white" @onclick:stopPropagation="true">Quick View</button>
        </div>
    </div>

    <div class="p-4 flex flex-col flex-1">
        <div class="text-[11px] font-semibold text-brand uppercase tracking-wider mb-1">@Product.CategoryName</div>
        <h3 class="text-[14px] sm:text-[15px] font-semibold text-gray-800 line-clamp-2 leading-snug mb-2 flex-1 group-hover:text-brand transition-colors">@Product.Name</h3>
        
        <div class="flex items-center gap-1 mb-3">
            <div class="flex text-accent">
                @for (int i = 0; i < 5; i++)
                {
                    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                }
            </div>
            <span class="text-xs text-gray-400">(12)</span>
        </div>

        <div class="mt-auto">
            <div class="flex items-end flex-wrap gap-2 mb-3">
                @if (Product.SalePrice.HasValue)
                {
                    <span class="text-accent font-extrabold text-lg leading-none">₦@Product.SalePrice.Value.ToString("N0")</span>
                    <span class="text-gray-400 line-through text-sm leading-none mb-0.5">₦@Product.Price.ToString("N0")</span>
                }
                else
                {
                    <span class="text-gray-900 font-extrabold text-lg leading-none">₦@Product.Price.ToString("N0")</span>
                }
            </div>
            
            <button class="w-full h-10 bg-brand text-white font-semibold text-sm rounded-lg hover:bg-brand-dark active:scale-95 transition-all flex items-center justify-center gap-2" @onclick="AddToCart" @onclick:stopPropagation="true">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                Add to Cart
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public ProductDto Product { get; set; } = default!;
    [Parameter] public bool IsListView { get; set; } = false;

    private void GoToDetails()
    {
        NavManager.NavigateTo($"/product/{Product.Slug ?? Product.Id.ToString()}");
    }

    private async Task AddToCart()
    {
        var item = new CartItemDto {
            ProductId = Product.Id,
            Name = Product.Name,
            Price = Product.SalePrice ?? Product.Price,
            MainImageUrl = Product.MainImageUrl,
            Quantity = 1
        };
        await Cart.AddToCartAsync(item);
    }
}