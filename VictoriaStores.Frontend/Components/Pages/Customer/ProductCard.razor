@using VictoriaStores.Frontend.Models
@inject NavigationManager NavManager
@inject VictoriaStores.Frontend.Services.CartService CartService

<style>
    .pc-img{transition:transform .5s cubic-bezier(.16,1,.3,1)}
    .pc-wrap:hover .pc-img{transform:scale(1.07)}
    .pc-quick{transition:transform .3s cubic-bezier(.16,1,.3,1),opacity .3s ease}
    .pc-wrap:hover .pc-quick{transform:translateY(0);opacity:1}
    .pc-wish{transition:transform .2s ease,color .2s ease}
    .pc-wish:hover{transform:scale(1.25)}
    @@keyframes addedPop{0%,100%{transform:scale(1)}40%{transform:scale(1.15)}70%{transform:scale(.96)}}
    .added-pop{animation:addedPop .4s ease}
</style>

<div class="pc-wrap group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 overflow-hidden flex @(IsListView ? "flex-row h-36 sm:h-52" : "flex-col") relative cursor-pointer"
     @onclick="GoToDetails">

    <!-- ── Image area ──────────────────────────────────────── -->
    <div class="@(IsListView ? "w-36 sm:w-52 h-full flex-shrink-0" : "aspect-square") bg-gradient-to-br from-gray-50 to-gray-100 relative overflow-hidden">

        @if (!string.IsNullOrEmpty(Product.MainImageUrl))
        {
            <img src="https://localhost:7145@(Product.MainImageUrl)"
                 alt="@Product.Name"
                 class="pc-img w-full h-full object-cover p-3 mix-blend-multiply"
                 loading="lazy" decoding="async" />
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center">
                <svg class="w-14 h-14 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
            </div>
        }

        <!-- Discount / New badge -->
        @if (Product.SalePrice.HasValue && Product.Price > 0)
        {
            var discount = (int)Math.Round(((Product.Price - Product.SalePrice.Value) / Product.Price) * 100);
            <span class="absolute top-2.5 left-2.5 bg-accent text-white text-[10px] font-extrabold px-2 py-1 rounded-lg shadow-md tracking-wide">@discount% OFF</span>
        }
        else if ((DateTime.UtcNow - Product.CreatedAt).TotalDays < 7)
        {
            <span class="absolute top-2.5 left-2.5 bg-gradient-to-r from-[#1A56DB] to-blue-500 text-white text-[10px] font-extrabold px-2 py-1 rounded-lg shadow-md tracking-wide">NEW</span>
        }

        <!-- Wishlist button -->
        <button class="pc-wish absolute top-2.5 right-2.5 w-8 h-8 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center text-gray-300 hover:text-red-500 shadow-sm border border-white/60 z-10"
                @onclick:stopPropagation="true" aria-label="Add to wishlist">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
        </button>

        <!-- Quick view slide-up overlay -->
        @if (!IsListView)
        {
            <div class="pc-quick absolute bottom-0 left-0 right-0 p-2.5 translate-y-full opacity-0">
                <button class="w-full bg-white/95 backdrop-blur-sm text-gray-900 font-bold text-xs py-2.5 rounded-xl shadow border border-gray-100 hover:bg-white hover:text-brand transition-colors"
                        @onclick:stopPropagation="true">
                    Quick View
                </button>
            </div>
        }
    </div>

    <!-- ── Info area ───────────────────────────────────────── -->
    <div class="p-3.5 sm:p-4 flex flex-col flex-1 @(IsListView ? "justify-center gap-1" : "gap-2")">

        <!-- Category label -->
        <span class="text-[10.5px] font-extrabold text-brand uppercase tracking-widest">@Product.CategoryName</span>

        <!-- Product name -->
        <h3 class="text-[13.5px] sm:text-[14.5px] font-semibold text-gray-800 line-clamp-2 leading-snug flex-1 group-hover:text-brand transition-colors duration-200">@Product.Name</h3>

        <!-- Description (list view only) -->
        @if (IsListView && !string.IsNullOrEmpty(Product.Description))
        {
            <p class="hidden sm:block text-xs text-gray-500 line-clamp-2">@Product.Description</p>
        }

        <!-- Stars -->
        <div class="flex items-center gap-1.5">
            <div class="flex text-accent gap-0.5">
                @for (int i = 0; i < 5; i++)
                {
                    <svg class="w-3 h-3 fill-current" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                }
            </div>
            <span class="text-[11px] text-gray-400 font-medium">(12)</span>
        </div>

        <!-- Price + CTA -->
        <div class="@(IsListView ? "flex items-center justify-between mt-1" : "mt-auto") flex-wrap gap-2">

            <div class="flex items-end flex-wrap gap-1.5">
                @if (Product.SalePrice.HasValue)
                {
                    <span class="text-accent font-extrabold text-lg sm:text-xl leading-none">₦@Product.SalePrice.Value.ToString("N0")</span>
                    <span class="text-gray-400 line-through text-sm leading-none mb-0.5">₦@Product.Price.ToString("N0")</span>
                }
                else
                {
                    <span class="text-gray-900 font-extrabold text-lg sm:text-xl leading-none">₦@Product.Price.ToString("N0")</span>
                }
            </div>

            <button class="@(IsListView ? "h-9 px-4 sm:px-5 text-xs" : "w-full h-10 text-sm mt-1") @(_justAdded ? "bg-green-600 added-pop" : "bg-gradient-to-r from-[#1A56DB] to-[#1e4fd8] hover:from-[#1E40AF] hover:to-[#1A56DB]") text-white font-bold rounded-xl active:scale-95 transition-all flex items-center justify-center gap-1.5 shadow-sm flex-shrink-0"
                    @onclick:stopPropagation="true" @onclick="AddToCart">
                @if (_justAdded)
                {
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    <span class="@(IsListView ? "hidden sm:inline" : "")">Added!</span>
                }
                else
                {
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    <span class="@(IsListView ? "hidden sm:inline" : "")">Add to Cart</span>
                }
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public ProductDto Product { get; set; } = default!;
    [Parameter] public bool IsListView { get; set; } = false;

    private bool _justAdded = false;

    private void GoToDetails() => NavManager.NavigateTo($"/product/{Product.Id}");

    private async Task AddToCart()
    {
        var cartItem = new CartItemDto
        {
            ProductId = Product.Id,
            ProductName = Product.Name,
            UnitPrice = Product.SalePrice ?? Product.Price,
            Quantity = 1,
            ImageUrl = Product.MainImageUrl
        };
        await CartService.AddToCartAsync(cartItem);

        // Green flash feedback
        _justAdded = true;
        StateHasChanged();
        await Task.Delay(1600);
        _justAdded = false;
        StateHasChanged();
    }
}
