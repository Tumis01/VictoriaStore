@page "/about"
@layout Layout.StoreLayout

<PageTitle>About Us - Victoria James Store</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 animate-fade-in">
    <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-brand font-bold tracking-wider uppercase text-sm mb-2 block">Our Story</span>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-gray-900 mb-6">Quality Living, Delivered.</h1>
        <p class="text-lg text-gray-600 leading-relaxed">
            Victoria James Store was founded with a simple mission: to provide Nigerian households with premium, affordable, and durable lifestyle products. From essential kitchen utensils to modern household items and beautiful fashion giftpacks, we curate products that make everyday living better.
        </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mb-16">
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center">
            <div class="w-16 h-16 bg-brand-light text-brand rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="font-bold text-xl text-gray-900 mb-3">Guaranteed Quality</h3>
            <p class="text-gray-500 text-sm">Every product we sell is physically inspected by our team before it leaves our warehouse to ensure you get exactly what you paid for.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center">
            <div class="w-16 h-16 bg-brand-light text-brand rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="font-bold text-xl text-gray-900 mb-3">Fast Nationwide Delivery</h3>
            <p class="text-gray-500 text-sm">We partner with reliable logistics companies to ensure your orders arrive safely and quickly, no matter where you are in Nigeria.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center">
            <div class="w-16 h-16 bg-brand-light text-brand rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            </div>
            <h3 class="font-bold text-xl text-gray-900 mb-3">Dedicated Support</h3>
            <p class="text-gray-500 text-sm">Our customer service team is always a WhatsApp message away. We treat every customer like family.</p>
        </div>
    </div>
</div>