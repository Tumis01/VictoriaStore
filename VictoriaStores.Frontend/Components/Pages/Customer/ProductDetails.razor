@page "/product/{Id:guid}"
@layout Layout.StoreLayout
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components
@using VictoriaStores.Frontend.Models
@using VictoriaStores.Frontend.Components.Layout

@inject HttpClient Http
@inject VictoriaStores.Frontend.Services.CartService CartService
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(product?.Name ?? "Loading...") - Victoria James Store</PageTitle>

@if (isLoading)
{
    <div class="max-w-7xl mx-auto px-4 py-32 flex flex-col items-center justify-center min-h-[60vh]">
        <svg class="animate-spin h-10 w-10 text-primary mb-4" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
    </div>
}
else if (product == null)
{
    <div class="max-w-3xl mx-auto px-4 py-24">
        <div class="text-center bg-white rounded-2xl shadow-sm border border-gray-200 p-12">
            <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-400">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Product Not Found</h2>
            <p class="text-gray-500 mb-8">The product you are looking for doesn't exist or has been removed.</p>
            <a href="/store" class="inline-flex items-center justify-center px-8 py-3 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-colors">
                Return to Store
            </a>
        </div>
    </div>
}
else
{
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
        <nav class="flex flex-wrap items-center text-sm text-gray-500 mb-8 gap-y-2">
            <a href="/store" class="hover:text-primary transition-colors">Store</a>
            <span class="mx-3 text-gray-400">/</span>
            <a href="/category/@product.CategoryId" class="hover:text-primary transition-colors capitalize">@product.CategoryName.ToLower()</a>
            <span class="mx-3 text-gray-400">/</span>
            <span class="text-gray-900 font-medium truncate">@product.Name</span>
        </nav>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16 items-start">
            
            <div class="flex flex-col gap-4 sticky top-6">
                <div class="w-full aspect-square relative flex items-center justify-center bg-gray-50 rounded-2xl overflow-hidden border border-gray-100 group">
                    @if (!string.IsNullOrEmpty(activeImageUrl))
                    {
                        <img src="@BuildImageUrl(activeImageUrl)" alt="@product.Name" class="w-full h-full object-cover mix-blend-multiply" />

                        @if (OrderedImages.Count > 1)
                        {
                            <button @onclick="PreviousImage" class="absolute left-4 top-1/2 -translate-y-1/2 h-10 w-10 rounded-full bg-white/90 text-gray-600 shadow-sm border border-gray-200 hover:text-primary transition-colors flex items-center justify-center opacity-0 group-hover:opacity-100 focus:opacity-100">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                            </button>
                            <button @onclick="NextImage" class="absolute right-4 top-1/2 -translate-y-1/2 h-10 w-10 rounded-full bg-white/90 text-gray-600 shadow-sm border border-gray-200 hover:text-primary transition-colors flex items-center justify-center opacity-0 group-hover:opacity-100 focus:opacity-100">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                            </button>
                        }
                    }
                    else
                    {
                        <div class="text-gray-300 flex flex-col items-center">
                            <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            <span class="text-sm font-medium">No Image</span>
                        </div>
                    }
                </div>

                @if (OrderedImages.Count > 1)
                {
                    <div class="grid grid-cols-5 gap-3">
                        @foreach (var img in OrderedImages)
                        {
                            <button @onclick="() => activeImageUrl = img.ImageUrl"
                                    class="aspect-square rounded-xl overflow-hidden bg-gray-50 border-2 transition-colors @(activeImageUrl == img.ImageUrl ? "border-primary" : "border-transparent hover:border-gray-300")">
                                <img src="@BuildImageUrl(img.ImageUrl)" alt="Thumbnail" class="w-full h-full object-cover mix-blend-multiply p-1" />
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="flex flex-col">
                
                <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-4">
                    @product.Name
                </h1>

                <div class="flex items-center gap-4 mb-6 pb-6 border-b border-gray-100">
                    <div class="flex items-center gap-1.5">
                        <div class="flex text-yellow-400">
                            @for (int i = 0; i < 5; i++)
                            {
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                            }
                        </div>
                        <span class="text-sm text-gray-500 hover:text-primary cursor-pointer transition-colors">(14 reviews)</span>
                    </div>
                    
                    <span class="w-1 h-1 rounded-full bg-gray-300"></span>

                    @if (product.StockQuantity > 10)
                    {
                        <span class="text-sm font-semibold text-green-600 flex items-center gap-1.5">
                            <span class="w-2 h-2 rounded-full bg-green-500"></span> In Stock
                        </span>
                    }
                    else if (product.StockQuantity > 0)
                    {
                        <span class="text-sm font-semibold text-amber-600 flex items-center gap-1.5">
                            <span class="w-2 h-2 rounded-full bg-amber-500"></span> Low Stock (@product.StockQuantity left)
                        </span>
                    }
                    else
                    {
                        <span class="text-sm font-semibold text-red-600 flex items-center gap-1.5">
                            <span class="w-2 h-2 rounded-full bg-red-500"></span> Out of Stock
                        </span>
                    }
                </div>

                <div class="mb-8">
                    <div class="flex items-end gap-3">
                        @if (product.SalePrice.HasValue)
                        {
                            <span class="text-4xl font-extrabold text-gray-900 leading-none">₦@product.SalePrice.Value.ToString("N0")</span>
                            <span class="text-lg text-gray-400 font-medium line-through mb-1">₦@product.Price.ToString("N0")</span>
                            var discount = Math.Round((1 - (product.SalePrice.Value / product.Price)) * 100);
                            <span class="inline-flex items-center px-2 py-1 rounded bg-red-50 text-red-700 text-xs font-bold uppercase tracking-wide ml-2 mb-1">
                                Save @discount%
                            </span>
                        }
                        else
                        {
                            <span class="text-4xl font-extrabold text-gray-900 leading-none">₦@product.Price.ToString("N0")</span>
                        }
                    </div>
                    <p class="text-sm text-gray-500 mt-2">Taxes included. Delivery calculated at checkout.</p>
                </div>

                @if (product.Colors != null && product.Colors.Any())
                {
                    <div class="mb-8">
                        <div class="flex items-center justify-between mb-3">
                            <label class="text-sm font-semibold text-gray-900">Color</label>
                            <span class="text-sm text-gray-500">@selectedColor</span>
                        </div>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var color in product.Colors)
                            {
                                <button @onclick="() => selectedColor = color"
                                        class="px-5 py-2.5 rounded-xl border text-sm font-medium transition-all @(selectedColor == color ? "border-gray-900 bg-gray-900 text-white" : "border-gray-200 text-gray-700 hover:border-gray-900")">
                                    @color
                                </button>
                            }
                        </div>
                    </div>
                }

                <div class="mb-8">
                    @if (showAddedToCartToast)
                    {
                        <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-800 rounded-xl text-sm font-medium flex items-center justify-between animate-fade-in">
                            <div class="flex items-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                Added to your cart!
                            </div>
                            <a href="/cart" class="font-bold hover:underline">View Cart</a>
                        </div>
                    }

                    <div class="flex flex-col sm:flex-row gap-4 mb-4">
                        <div class="flex items-center justify-between px-2 w-full sm:w-32 h-14 border border-gray-300 rounded-xl bg-white">
                            <button @onclick="DecrementQty" class="border-none outline-none w-10 h-full flex items-center justify-center text-gray-500 hover:text-gray-900 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path></svg>
                            </button>
                            <input type="text" readonly value="@quantity" class="w-10 text-center font-semibold text-gray-900 bg-transparent border-none focus:ring-0 p-0" />
                            <button @onclick="IncrementQty" class="border-none outline-none w-10 h-full flex items-center justify-center text-gray-500 hover:text-gray-900 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                            </button>
                        </div>

                        <button @onclick="AddToCart" disabled="@(product.StockQuantity == 0)" class="flex-1 h-14 bg-primary text-white font-semibold text-base rounded-xl hover:bg-primary-dark transition-colors disabled:bg-gray-300 disabled:text-gray-500 disabled:cursor-not-allowed flex items-center justify-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                            @(product.StockQuantity == 0 ? "Out of Stock" : "Add to Cart")
                        </button>
                    </div>

                    <a href="@GetWhatsAppLink()" target="_blank" class="flex items-center justify-center w-full h-14 rounded-xl border border-gray-300 bg-white text-gray-700 font-semibold hover:bg-gray-50 hover:text-gray-900 transition-colors gap-2">
                        <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"></path>
                        </svg>
                        Need Help? Ask on WhatsApp
                    </a>
                </div>

                <div class="mt-4 pt-8 border-t border-gray-100">
                    <h2 class="text-lg font-bold text-gray-900 mb-4">Product Details</h2>
                    <div class="prose prose-sm text-gray-600 max-w-none leading-relaxed">
                        @((MarkupString)(product.Description?.Replace("\n", "<br/>") ?? "No additional description available."))
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-10 pt-8 border-t border-gray-100">
                    <div class="flex flex-col gap-2">
                        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <div>
                            <p class="text-sm font-semibold text-gray-900">Fast Delivery</p>
                            <p class="text-xs text-gray-500 mt-0.5">Nationwide dispatch</p>
                        </div>
                    </div>
                    <div class="flex flex-col gap-2">
                        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        <div>
                            <p class="text-sm font-semibold text-gray-900">Quality Assured</p>
                            <p class="text-xs text-gray-500 mt-0.5">Carefully selected items</p>
                        </div>
                    </div>
                    <div class="flex flex-col gap-2">
                        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                        <div>
                            <p class="text-sm font-semibold text-gray-900">Secure Payment</p>
                            <p class="text-xs text-gray-500 mt-0.5">Bank transfer checkout</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="mt-24 pt-12 border-t border-gray-100">
            <h2 class="text-2xl font-bold text-gray-900 mb-8">You May Also Like</h2>

            @if (relatedProducts.Any())
            {
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                    @foreach (var related in relatedProducts.Take(4))
                    {
                        <ProductCard Product="related" />
                    }
                </div>
            }
            else
            {
                <div class="bg-gray-50 rounded-xl p-8 text-center border border-gray-100">
                    <p class="text-gray-500 font-medium">No related products found.</p>
                </div>
            }
        </div>

        <SignInModal @bind-IsVisible="showSignInModal" />
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool isLoading = true;
    private ProductDto? product;
    private List<ProductDto> relatedProducts = new();
    private string activeImageUrl = string.Empty;
    private string? selectedColor;
    private int quantity = 1;
    private bool showAddedToCartToast = false;
    private bool showSignInModal = false;

    private List<ProductImageDto> OrderedImages =>
        product?.Images?.OrderBy(i => i.DisplayOrder).ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            product = await Http.GetFromJsonAsync<ProductDto>($"api/product/{Id}");

            if (product != null)
            {
                activeImageUrl = product.Images?
                    .OrderBy(i => i.DisplayOrder)
                    .FirstOrDefault(i => i.IsMain)?.ImageUrl
                    ?? product.Images?.OrderBy(i => i.DisplayOrder).FirstOrDefault()?.ImageUrl
                    ?? string.Empty;

                if (product.Colors != null && product.Colors.Any())
                {
                    selectedColor = product.Colors.First();
                }

                var allProducts = await Http.GetFromJsonAsync<List<ProductDto>>("api/product") ?? new();
                relatedProducts = allProducts
                    .Where(p => p.CategoryId == product.CategoryId && p.Id != product.Id)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading product: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NextImage()
    {
        if (!OrderedImages.Any()) return;

        var currentIndex = OrderedImages.FindIndex(i => i.ImageUrl == activeImageUrl);

        if (currentIndex >= 0 && currentIndex < OrderedImages.Count - 1)
        {
            activeImageUrl = OrderedImages[currentIndex + 1].ImageUrl;
        }
        else
        {
            activeImageUrl = OrderedImages[0].ImageUrl;
        }
    }

    private void PreviousImage()
    {
        if (!OrderedImages.Any()) return;

        var currentIndex = OrderedImages.FindIndex(i => i.ImageUrl == activeImageUrl);

        if (currentIndex > 0)
        {
            activeImageUrl = OrderedImages[currentIndex - 1].ImageUrl;
        }
        else
        {
            activeImageUrl = OrderedImages[^1].ImageUrl;
        }
    }

    private void IncrementQty()
    {
        if (product != null && quantity < product.StockQuantity)
            quantity++;
    }

    private void DecrementQty()
    {
        if (quantity > 1)
            quantity--;
    }

    private async Task AddToCart()
    {
        if (product == null) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var cartItem = new CartItemDto
            {
                ProductId = product.Id,
                ProductName = product.Name,
                UnitPrice = product.SalePrice ?? product.Price,
                Quantity = quantity,
                ImageUrl = activeImageUrl
            };

            await CartService.AddToCartAsync(cartItem);

            showAddedToCartToast = true;
            StateHasChanged();

            await Task.Delay(3000);
            showAddedToCartToast = false;
            StateHasChanged();
        }
        else
        {
            showSignInModal = true;
        }
    }

    private static string BuildImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
            return string.Empty;

        if (imageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return imageUrl;

        return $"https://localhost:7145{imageUrl}";
    }

    private string GetWhatsAppLink()
    {
        var name = Uri.EscapeDataString(product?.Name ?? "this product");
        return $"https://wa.me/2348162809886?text=Hi! I have a question about {name}";
    }
}