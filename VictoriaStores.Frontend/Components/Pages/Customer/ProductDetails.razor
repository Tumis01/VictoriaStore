@page "/product/{Id:guid}"
@layout Layout.StoreLayout
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Authorization
@using VictoriaStores.Frontend.Models
@using VictoriaStores.Frontend.Components.Layout

@inject HttpClient Http
@inject VictoriaStores.Frontend.Services.CartService CartService
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(product?.Name ?? "Loading...") - Victoria James Store</PageTitle>

@if (isLoading)
{
    <div class="max-w-7xl mx-auto px-4 py-16 flex justify-center">
        <svg class="animate-spin h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
    </div>
}
else if (product == null)
{
    <div class="max-w-7xl mx-auto px-4 py-16 text-center">
        <h2 class="text-2xl font-bold text-on-surface mb-4">Product Not Found</h2>
        <a href="/" class="text-primary hover:underline font-semibold">← Return to Home</a>
    </div>
}
else
{
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <nav class="flex text-sm text-outline mb-8 font-semibold">
            <a href="/" class="hover:text-primary transition-colors">Home</a>
            <span class="mx-2">/</span>
            <a href="/category/@product.CategoryId" class="hover:text-primary transition-colors uppercase">@product.CategoryName</a>
            <span class="mx-2">/</span>
            <span class="text-on-surface">@product.Name</span>
        </nav>

        <div class="flex flex-col lg:flex-row gap-10 lg:gap-16 mb-16">
            
            <div class="w-full lg:w-1/2">
                <div class="aspect-square bg-surface-container-low rounded-2xl border border-outline-variant/15 overflow-hidden mb-4 relative flex items-center justify-center">
                    @if (!string.IsNullOrEmpty(activeImageUrl))
                    {
                        <img src="https://localhost:7145@(activeImageUrl)" alt="@product.Name" class="w-full h-full object-cover p-4 mix-blend-multiply transition-opacity duration-300" />
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-[20px]">image</span>
                    }
                </div>

                @if (product.Images.Count > 1)
                {
                    <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide">
                        @foreach (var img in product.Images.OrderBy(i => i.DisplayOrder))
                        {
                            <button @onclick="() => activeImageUrl = img.ImageUrl" class="w-20 h-20 rounded-xl border-2 flex-shrink-0 bg-surface-container-low overflow-hidden transition-colors @(activeImageUrl == img.ImageUrl ? "border-primary" : "border-transparent hover:border-primary-light")">
                                <img src="https://localhost:7145@(img.ImageUrl)" class="w-full h-full object-cover p-1 mix-blend-multiply" />
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="w-full lg:w-1/2 flex flex-col">
                <div class="mb-6">
                    <a href="/category/@product.CategoryId" class="text-xs font-bold text-primary uppercase tracking-wider hover:underline">@product.CategoryName</a>
                    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-on-surface mt-2 mb-4 leading-tight">@product.Name</h1>
                    
                    <div class="flex items-center gap-4 flex-wrap">
                        <div class="flex items-center gap-1">
                            <div class="flex text-tertiary">
                                @for (int i = 0; i < 5; i++)
                                {
                                    <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                                }
                            </div>
                            <span class="text-sm text-primary font-semibold hover:underline cursor-pointer">(14 reviews)</span>
                        </div>
                        <span class="text-gray-300">|</span>
                        @if (product.StockQuantity > 10)
                        {
                            <span class="text-sm font-bold text-green-600 flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> In Stock</span>
                        }
                        else if (product.StockQuantity > 0)
                        {
                            <span class="text-sm font-bold text-amber-600 flex items-center gap-1">⚠ Low Stock (@product.StockQuantity left)</span>
                        }
                        else
                        {
                            <span class="text-sm font-bold text-red-600">✕ Out of Stock</span>
                        }
                    </div>
                </div>

                <hr class="border-outline-variant/15 mb-6" />

                <div class="mb-6">
                    <div class="flex items-end gap-3 mb-2">
                        @if (product.SalePrice.HasValue)
                        {
                            <span class="text-4xl font-extrabold text-tertiary leading-none">₦@product.SalePrice.Value.ToString("N0")</span>
                            <span class="text-xl text-outline-variant line-through leading-none mb-1">₦@product.Price.ToString("N0")</span>
                            var savings = product.Price - product.SalePrice.Value;
                            <span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded ml-2 mb-1">Save ₦@savings.ToString("N0")</span>
                        }
                        else
                        {
                            <span class="text-4xl font-extrabold text-on-surface leading-none">₦@product.Price.ToString("N0")</span>
                        }
                    </div>
                </div>

                <p class="text-on-surface-variant leading-relaxed mb-8">@product.Description</p>

                @if (product.Colors != null && product.Colors.Any())
                {
                    <div class="mb-8">
                        <label class="block text-sm font-bold text-on-surface mb-3">Color: <span class="text-outline font-normal">@selectedColor</span></label>
                        <div class="flex flex-wrap gap-3">
                            @foreach (var color in product.Colors)
                            {
                                <button @onclick="() => selectedColor = color" class="px-4 py-2 rounded-lg border-2 text-sm font-semibold transition-all @(selectedColor == color ? "border-primary text-primary bg-primary-light/30" : "border-outline-variant/30 text-on-surface-variant hover:border-outline-variant/50")">
                                    @color
                                </button>
                            }
                        </div>
                    </div>
                }

                <div class="mt-auto">
                    @if (showAddedToCartToast)
                    {
                        <div class="mb-4 p-3 bg-green-50 border border-green-200 text-green-800 rounded-lg text-sm font-bold flex justify-between items-center animate-fade-in">
                            <div class="flex items-center gap-2">
                                <span>✓</span> Added to cart successfully!
                            </div>
                            <a href="/cart" class="text-primary hover:underline">View Cart</a>
                        </div>
                    }

                    <div class="flex flex-col sm:flex-row gap-4 mb-6">
                        <div class="flex items-center border-2 border-outline-variant/30 rounded-xl h-14 w-full sm:w-36 bg-surface-container-lowest overflow-hidden">
                            <button @onclick="DecrementQty" class="w-12 h-full flex items-center justify-center text-outline hover:text-primary hover:bg-surface-container-low text-xl font-bold transition-colors">−</button>
                            <input type="text" readonly value="@quantity" class="w-12 h-full text-center text-lg font-bold text-on-surface border-x-2 border-outline-variant/30 focus:outline-none" />
                            <button @onclick="IncrementQty" class="w-12 h-full flex items-center justify-center text-outline hover:text-primary hover:bg-surface-container-low text-xl font-bold transition-colors">+</button>
                        </div>

                        <button @onclick="AddToCart" disabled="@(product.StockQuantity == 0)" class="flex-1 h-14 bg-primary text-white font-bold text-lg rounded-xl hover:bg-primary-dark active:scale-[0.98] transition-all shadow-md flex items-center justify-center gap-3 disabled:bg-gray-400 disabled:cursor-not-allowed">
                            <span class="material-symbols-outlined text-[20px]">shopping_bag</span>
                            @(product.StockQuantity == 0 ? "Out of Stock" : "Add to Cart")
                        </button>
                    </div>

                    <a href="https://wa.me/2348162809886?text=Hi! I have a question about @product.Name" target="_blank" class="flex items-center justify-center w-full h-12 rounded-xl border-2 border-green-500 text-green-600 font-bold hover:bg-green-50 transition-colors gap-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.183-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.765-5.77zM12.031 0C5.385 0 0 5.388 0 12.036c0 2.125.556 4.195 1.611 6.02L.055 24l6.096-1.599c1.787.973 3.82 1.486 5.88 1.487 6.645-.001 12.031-5.388 12.031-12.036S18.676 0 12.031 0zM15.54 13.911c-.193-.097-1.14-.563-1.317-.627-.176-.065-.304-.097-.432.097-.129.194-.497.627-.609.756-.112.129-.224.146-.417.049-.193-.097-.813-.3-1.55-961-.572-.515-.957-1.15-1.07-1.344-.112-.194-.012-.298.085-.395.088-.088.193-.226.29-.339.097-.113.129-.194.193-.323.065-.129.032-.242-.016-.339-.048-.097-.432-1.042-.591-1.427-.156-.375-.315-.325-.432-.331-.112-.006-.241-.007-.37-.007-.129 0-.339.048-.516.242-.177.194-.676.662-.676 1.615s.692 1.874.788 2.003c.097.129 1.365 2.083 3.308 2.923 1.547.668 2.106.711 2.89.596.536-.078 1.14-.467 1.3-918.16-.452.16-.84.112-.918z" /></svg>
                        Ask on WhatsApp
                    </a>
                </div>

                <div class="grid grid-cols-3 gap-4 mt-8 pt-8 border-t border-outline-variant/15">
                    <div class="flex flex-col items-center text-center gap-2">
                        <span class="w-10 h-10 bg-surface-container-low rounded-full flex items-center justify-center text-primary text-lg">🚚</span>
                        <span class="text-xs font-bold text-on-surface-variant uppercase tracking-wide">Fast Delivery</span>
                    </div>
                    <div class="flex flex-col items-center text-center gap-2">
                        <span class="w-10 h-10 bg-surface-container-low rounded-full flex items-center justify-center text-primary text-lg">🛡️</span>
                        <span class="text-xs font-bold text-on-surface-variant uppercase tracking-wide">Quality Assured</span>
                    </div>
                    <div class="flex flex-col items-center text-center gap-2">
                        <span class="w-10 h-10 bg-surface-container-low rounded-full flex items-center justify-center text-primary text-lg">🏦</span>
                        <span class="text-xs font-bold text-on-surface-variant uppercase tracking-wide">Bank Transfer</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-16">
            <div class="border-b border-outline-variant/30 flex gap-8 mb-6">
                <button class="pb-3 text-primary font-bold border-b-2 border-primary text-lg">Description</button>
                <button class="pb-3 text-outline hover:text-on-surface font-bold text-lg transition-colors">Specifications</button>
            </div>
            <div class="prose max-w-none text-on-surface-variant leading-loose">
                @((MarkupString)(product.Description?.Replace("\n", "<br/>") ?? "No additional description available."))
            </div>
        </div>

        <div class="border-t border-outline-variant/30 pt-12 pb-8">
            <h2 class="font-serif text-2xl font-bold text-on-surface mb-8">Related Products</h2>
            @if (relatedProducts.Any())
            {
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                    @foreach (var related in relatedProducts.Take(4))
                    {
                        <ProductCard Product="related" />
                    }
                </div>
            }
            else
            {
                <p class="text-outline">No related products found.</p>
            }
        </div>
        
        <SignInModal @bind-IsVisible="showSignInModal" />
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool isLoading = true;
    private ProductDto? product;
    private List<ProductDto> relatedProducts = new();
    private string activeImageUrl = string.Empty;
    private string? selectedColor;
    private int quantity = 1;
    private bool showAddedToCartToast = false;
    private bool showSignInModal = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            product = await Http.GetFromJsonAsync<ProductDto>($"api/product/{Id}");
            
            if (product != null)
            {
                activeImageUrl = product.MainImageUrl;
                if (product.Colors != null && product.Colors.Any())
                {
                    selectedColor = product.Colors.First(); // Default to first color
                }

                // Fetch related products (using all products for demo purposes)
                var allProducts = await Http.GetFromJsonAsync<List<ProductDto>>("api/product") ?? new();
                relatedProducts = allProducts.Where(p => p.CategoryId == product.CategoryId && p.Id != product.Id).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading product: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void IncrementQty()
    {
        if (product != null && quantity < product.StockQuantity)
            quantity++;
    }

    private void DecrementQty()
    {
        if (quantity > 1)
            quantity--;
    }

    private async Task AddToCart()
    {
        if (product == null) return;

        // 1. Get the current user's authentication state
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        
        // 2. Check if the user is logged in
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var cartItem = new CartItemDto
            {
                ProductId = product.Id,
                ProductName = product.Name,
                UnitPrice = product.SalePrice ?? product.Price,
                Quantity = quantity, // BUG FIX: Changed from hardcoded 1 to use the dynamic `quantity` variable!
                ImageUrl = product.MainImageUrl
            };

            await CartService.AddToCartAsync(cartItem);
            
            showAddedToCartToast = true;
            
            // Hide toast after 3 seconds
            await Task.Delay(3000);
            showAddedToCartToast = false;
            StateHasChanged();
        }
        else
        {
            // 3. Trigger the sign-in modal
            showSignInModal = true;
        }
    }
}