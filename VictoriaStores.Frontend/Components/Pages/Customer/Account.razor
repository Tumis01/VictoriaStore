@page "/account"
@layout Layout.StoreLayout
@using Microsoft.AspNetCore.Authorization
@using VictoriaStores.Frontend.Models
@inject HttpClient Http
@inject NavigationManager NavManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@attribute [Authorize]

<PageTitle>My Account - Victoria James Store</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    @if (isLoading)
    {
        <div class="flex justify-center items-center h-64">
            <svg class="animate-spin h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        </div>
    }
    else if (profile == null)
    {
        <div class="max-w-xl mx-auto bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/15 p-8 text-center">
            <div class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="material-symbols-outlined text-[28px]">warning</span>
            </div>
            <h2 class="font-serif text-2xl font-bold text-on-surface mb-2">Could not load profile</h2>
            <p class="text-sm text-outline mb-6">There was a problem fetching your account details.</p>
            <button @onclick="LoadProfile" class="inline-flex items-center justify-center gap-2 h-11 px-6 bg-primary text-white font-semibold text-sm rounded-xl hover:bg-primary-dark transition-all shadow-sm">
                Try Again
            </button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 xl:grid-cols-[320px,minmax(0,1fr)] gap-6">
            <aside class="space-y-4">
                <div class="rounded-3xl overflow-hidden shadow-sm bg-gradient-to-br from-primary via-primary-dark to-gray-900 text-white">
                    <div class="p-6">
                        <div class="flex items-start justify-between gap-4">
                            <div class="w-14 h-14 rounded-2xl bg-white/15 backdrop-blur flex items-center justify-center text-2xl font-bold uppercase">
                                @GetUserInitial()
                            </div>
                            <button @onclick="Logout" class="h-10 px-4 rounded-xl bg-white/10 hover:bg-white/20 text-sm font-semibold transition-colors">
                                Sign Out
                            </button>
                        </div>

                        <div class="mt-6">
                            <p class="text-white/70 text-sm">My Account</p>
                            <h1 class="font-serif text-2xl font-bold mt-1">@profile.Name</h1>
                            <p class="text-sm text-white/75 mt-2 break-all">@profile.Email</p>
                            <p class="text-sm text-white/75">@profile.Phone</p>
                        </div>

                        <div class="grid grid-cols-2 gap-3 mt-6">
                            <div class="rounded-2xl bg-white/10 p-4">
                                <p class="text-[11px] uppercase tracking-[0.2em] text-white/60">Orders</p>
                                <p class="text-2xl font-bold mt-2">@profile.OrdersCount</p>
                            </div>
                            <div class="rounded-2xl bg-white/10 p-4">
                                <p class="text-[11px] uppercase tracking-[0.2em] text-white/60">Spent</p>
                                <p class="text-2xl font-bold mt-2">₦@profile.TotalSpent.ToString("N0")</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-surface-container-lowest rounded-3xl shadow-sm border border-outline-variant/15 p-3">
                    <nav class="grid grid-cols-1 sm:grid-cols-3 xl:grid-cols-1 gap-2">
                        <button @onclick='() => SwitchTab("dashboard")' class="@GetTabButtonClass("dashboard") border-none outline-none">
                            <span class="material-symbols-outlined text-[20px]">dashboard</span>
                            Dashboard
                        </button>
                        <button @onclick='() => SwitchTab("orders")' class="@GetTabButtonClass("orders") border-none outline-none">
                            <span class="material-symbols-outlined text-[20px]">orders</span>
                            Orders
                        </button>
                        <button @onclick='() => SwitchTab("settings")' class="@GetTabButtonClass("settings") border-none outline-none">
                            <span class="material-symbols-outlined text-[20px]">settings</span>
                            Settings
                        </button>
                    </nav>
                </div>
            </aside>

            <section class="min-w-0">
                @if (activeTab == "dashboard")
                {
                    <div class="space-y-6">
                        <div class="bg-surface-container-lowest rounded-3xl shadow-sm border border-outline-variant/15 p-6 md:p-8">
                            <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
                                <div>
                                    <p class="text-sm uppercase tracking-[0.25em] text-outline">Overview</p>
                                    <h2 class="font-serif text-3xl md:text-4xl font-bold text-on-surface mt-2">Welcome back, @GetFirstName(profile.Name)</h2>
                                    <p class="text-sm text-outline mt-3">Manage your orders, keep your details up to date, and track payments in one place.</p>
                                </div>
                                <div class="flex flex-wrap gap-3">
                                    <button @onclick='() => SwitchTab("orders")' class="h-11 px-5 bg-primary text-white rounded-xl font-semibold shadow-sm hover:bg-primary-dark transition-colors">
                                        View Orders
                                    </button>
                                    <a href="/store" class="inline-flex items-center justify-center h-11 px-5 bg-surface-container-low text-on-surface rounded-xl font-semibold shadow-sm hover:bg-surface-container transition-colors">
                                        Continue Shopping
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div class="bg-surface-container-lowest rounded-3xl shadow-sm border border-outline-variant/15 p-5">
                                <p class="text-xs uppercase tracking-[0.2em] text-outline">Orders</p>
                                <p class="text-3xl font-bold text-on-surface mt-3">@profile.OrdersCount</p>
                            </div>
                            <div class="bg-surface-container-lowest rounded-3xl shadow-sm border border-outline-variant/15 p-5">
                                <p class="text-xs uppercase tracking-[0.2em] text-outline">Total Spent</p>
                                <p class="text-3xl font-bold text-on-surface mt-3">₦@profile.TotalSpent.ToString("N0")</p>
                            </div>
                            <div class="bg-surface-container-lowest rounded-3xl shadow-sm border border-outline-variant/15 p-5">
                                <p class="text-xs uppercase tracking-[0.2em] text-outline">Phone</p>
                                <p class="text-xl font-bold text-on-surface mt-3 break-words">@profile.Phone</p>
                            </div>
                        </div>

                        <div class="bg-surface-container-lowest rounded-3xl shadow-sm border border-outline-variant/15 p-6">
                            <div class="flex items-center justify-between gap-3 mb-5">
                                <div>
                                    <h3 class="font-serif text-2xl font-bold text-on-surface">Recent Orders</h3>
                                    <p class="text-sm text-outline mt-1">Tap any order to see the full details.</p>
                                </div>
                                <button @onclick='() => SwitchTab("orders")' class="text-primary text-sm font-semibold hover:underline border-none outline-none">
                                    View all
                                </button>
                            </div>

                            @if (profile.RecentOrders == null || !profile.RecentOrders.Any())
                            {
                                <div class="rounded-2xl bg-surface-container-low p-8 text-center">
                                    <p class="text-lg font-semibold text-on-surface">No orders yet</p>
                                    <p class="text-sm text-outline mt-2 mb-5">When you place an order, it will show up here.</p>
                                    <a href="/store" class="inline-flex items-center justify-center h-11 px-6 bg-primary text-white rounded-xl font-semibold shadow-sm hover:bg-primary-dark transition-colors">
                                        Start Shopping
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    @foreach (var order in profile.RecentOrders.Take(4))
                                    {
                                        <button @onclick="() => ViewOrderDetails(order.Id)" class="text-left rounded-2xl bg-surface-container-low p-5 hover:bg-primary-light/40 transition-colors shadow-sm border-none outline-none">
                                            <div class="flex items-start justify-between gap-3">
                                                <div>
                                                    <p class="text-sm text-outline">Order Number</p>
                                                    <p class="text-lg font-bold text-primary mt-1">@order.OrderNumber</p>
                                                </div>
                                                <span class="@GetStatusBadgeClass(order.Status) px-3 py-1 rounded-full text-xs font-bold">@order.Status</span>
                                            </div>
                                            <div class="mt-4 flex items-end justify-between gap-3">
                                                <div>
                                                    <p class="text-xs text-outline">Placed</p>
                                                    <p class="text-sm font-medium text-on-surface mt-1">@order.CreatedAt.ToString("MMM dd, yyyy")</p>
                                                </div>
                                                <div class="text-right">
                                                    <p class="text-xs text-outline">Total</p>
                                                    <p class="text-lg font-black text-on-surface mt-1">₦@order.TotalAmount.ToString("N0")</p>
                                                </div>
                                            </div>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (activeTab == "orders")
                {
                    <div class="space-y-6">
                        @if (isLoadingDetails)
                        {
                            <div class="flex justify-center items-center h-64">
                                <svg class="animate-spin h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                            </div>
                        }
                        else if (selectedOrderDetails != null)
                        {
                            <div class="bg-surface-container-lowest rounded-3xl shadow-sm border border-outline-variant/15 overflow-hidden">
                                <div class="p-6 md:p-8 border-b border-outline-variant/15 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                                    <div>
                                        <button @onclick="CloseOrderDetails" class="mb-4 text-sm font-semibold text-outline hover:text-primary transition-colors">
                                            Back to orders
                                        </button>
                                        <h2 class="font-serif text-3xl font-bold text-on-surface">Order #@selectedOrderDetails.OrderNumber</h2>
                                        <p class="text-sm text-outline mt-2">Placed on @selectedOrderDetails.CreatedAt.ToLocalTime().ToString("MMMM dd, yyyy 'at' hh:mm tt")</p>
                                    </div>
                                    <span class="@GetStatusBadgeClass(selectedOrderDetails.Status) px-4 py-2 rounded-full text-sm font-bold w-fit">@selectedOrderDetails.Status</span>
                                </div>

                                <div class="p-6 md:p-8">
                                    <h3 class="text-xs uppercase tracking-[0.25em] text-outline mb-4">Items Ordered</h3>
                                    <div class="space-y-4">
                                        @foreach (var item in selectedOrderDetails.Items)
                                        {
                                            <div class="flex items-center justify-between gap-4 rounded-2xl bg-surface-container-low p-4">
                                                <div class="flex items-center gap-4 min-w-0">
                                                    <div class="w-16 h-16 bg-surface-container rounded-2xl overflow-hidden flex-shrink-0">
                                                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                                        {
                                                            <img src="@item.ImageUrl" class="w-full h-full object-cover" alt="@item.ProductName" />
                                                        }
                                                        else
                                                        {
                                                            <div class="w-full h-full flex items-center justify-center text-gray-300">
                                                                <span class="material-symbols-outlined text-[20px]">image</span>
                                                            </div>
                                                        }
                                                    </div>
                                                    <div class="min-w-0">
                                                        <p class="font-bold text-on-surface truncate">@item.ProductName</p>
                                                        <p class="text-sm text-outline mt-1">Qty: @item.Quantity × ₦@item.UnitPrice.ToString("N0")</p>
                                                    </div>
                                                </div>
                                                <p class="font-extrabold text-on-surface whitespace-nowrap">₦@((item.Quantity * item.UnitPrice).ToString("N0"))</p>
                                            </div>
                                        }
                                    </div>

                                    <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <div class="rounded-2xl bg-primary-light p-5">
                                            <p class="text-xs uppercase tracking-[0.25em] text-outline">Total Amount</p>
                                            <p class="text-3xl font-black text-primary mt-3">₦@selectedOrderDetails.TotalAmount.ToString("N0")</p>
                                        </div>
                                        <div class="rounded-2xl bg-surface-container-low p-5 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end">
                                            <a href="/track?orderNumber=@selectedOrderDetails.OrderNumber&phone=@profile.Phone" class="inline-flex items-center justify-center h-11 px-5 bg-surface-container-lowest text-on-surface font-semibold rounded-xl shadow-sm hover:bg-surface-container transition-colors">
                                                Track Order
                                            </a>
                                            <a href="/confirmation/@selectedOrderDetails.Id" class="inline-flex items-center justify-center h-11 px-5 bg-green-500 text-white font-semibold rounded-xl shadow-sm hover:bg-green-600 transition-colors">
                                                Complete Payment
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="bg-surface-container-lowest rounded-3xl shadow-sm border border-outline-variant/15 p-6 md:p-8">
                                <div class="mb-6">
                                    <h2 class="font-serif text-3xl font-bold text-on-surface">Order History</h2>
                                    <p class="text-sm text-outline mt-2">Every order you've placed appears here.</p>
                                </div>

                                @if (profile.RecentOrders == null || !profile.RecentOrders.Any())
                                {
                                    <div class="rounded-2xl bg-surface-container-low p-8 text-center">
                                        <p class="text-lg font-semibold text-on-surface">No order history</p>
                                        <p class="text-sm text-outline mt-2 mb-5">Looks like you haven't made any purchases yet.</p>
                                        <a href="/store" class="inline-flex items-center justify-center h-11 px-6 bg-primary text-white rounded-xl font-semibold shadow-sm hover:bg-primary-dark transition-colors">
                                            Browse Products
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <div class="space-y-4">
                                        @foreach (var order in profile.RecentOrders)
                                        {
                                            <button @onclick="() => ViewOrderDetails(order.Id)" class="w-full text-left rounded-2xl bg-surface-container-low p-5 hover:bg-primary-light/40 transition-colors shadow-sm">
                                                <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                                                    <div>
                                                        <div class="flex flex-wrap items-center gap-3">
                                                            <span class="font-bold text-on-surface text-lg">@order.OrderNumber</span>
                                                            <span class="@GetStatusBadgeClass(order.Status) px-3 py-1 rounded-full text-xs font-bold">@order.Status</span>
                                                        </div>
                                                        <p class="text-sm text-outline mt-2">Ordered on @order.CreatedAt.ToLocalTime().ToString("MMMM dd, yyyy 'at' hh:mm tt")</p>
                                                    </div>
                                                    <div class="text-left md:text-right">
                                                        <p class="text-xs uppercase tracking-[0.2em] text-outline">Total</p>
                                                        <p class="text-2xl font-black text-on-surface mt-2">₦@order.TotalAmount.ToString("N0")</p>
                                                    </div>
                                                </div>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                @if (activeTab == "settings")
                {
                    <div class="bg-surface-container-lowest rounded-3xl shadow-sm border border-outline-variant/15 p-6 md:p-8 max-w-3xl">
                        <div class="mb-6">
                            <p class="text-sm uppercase tracking-[0.25em] text-outline">Account Settings</p>
                            <h2 class="font-serif text-3xl font-bold text-on-surface mt-2">Update your details</h2>
                            <p class="text-sm text-outline mt-3">Keep your personal and contact information current.</p>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(updateError))
                        {
                            <div class="mb-5 rounded-xl bg-red-50 text-red-700 px-4 py-3 text-sm font-medium border border-red-200">
                                @updateError
                            </div>
                        }

                        @if (updateSuccess)
                        {
                            <div class="mb-5 rounded-xl bg-green-50 text-green-700 px-4 py-3 text-sm font-medium border border-green-200">
                                Profile updated successfully.
                            </div>
                        }

                        <EditForm Model="updateModel" OnValidSubmit="HandleUpdate" FormName="updateProfileForm" class="space-y-5">
                            <DataAnnotationsValidator />

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div class="md:col-span-2">
                                    <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Full Name</label>
                                    <InputText @bind-Value="updateModel.Name" class="h-12 w-full px-4 rounded-xl border border-outline-variant/50 bg-surface-container-lowest text-sm text-on-surface focus:outline-none focus:ring-2 focus:ring-primary transition-colors" placeholder="e.g. Chioma Okonkwo" />
                                    <ValidationMessage For="@(() => updateModel.Name)" class="text-xs text-red-600 mt-1" />
                                </div>

                                <div>
                                    <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Email Address</label>
                                    <input type="email" value="@profile.Email" disabled class="h-12 w-full px-4 rounded-xl bg-surface-container-low text-outline text-sm cursor-not-allowed" />
                                    <p class="text-xs text-outline mt-1">Email cannot be changed.</p>
                                </div>

                                <div>
                                    <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Phone Number</label>
                                    <InputText @bind-Value="updateModel.Phone" class="h-12 w-full px-4 rounded-xl border border-outline-variant/50 bg-surface-container-lowest text-sm text-on-surface focus:outline-none focus:ring-2 focus:ring-primary transition-colors" placeholder="08012345678" />
                                    <ValidationMessage For="@(() => updateModel.Phone)" class="text-xs text-red-600 mt-1" />
                                </div>
                            </div>

                            <div class="pt-4 flex justify-end">
                                <button type="submit" disabled="@isUpdating" class="inline-flex items-center justify-center gap-2 h-12 px-6 bg-primary text-white font-semibold text-sm rounded-xl hover:bg-primary-dark transition-all shadow-sm disabled:opacity-75 disabled:cursor-not-allowed">
                                    @if (isUpdating)
                                    {
                                        <svg class="animate-spin w-4 h-4 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <span>Save Changes</span>
                                    }
                                </button>
                            </div>
                        </EditForm>
                    </div>
                }
            </section>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool isUpdating = false;
    private bool updateSuccess = false;
    private string? updateError;
    private string activeTab = "dashboard";

    private OrderDto? selectedOrderDetails;
    private bool isLoadingDetails = false;

    private CustomerDto? profile;
    private UpdateProfileRequest updateModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProfile();
    }

    private async Task LoadProfile()
    {
        isLoading = true;
        updateSuccess = false;
        updateError = null;

        try
        {
            profile = await Http.GetFromJsonAsync<CustomerDto>("api/customer/profile");

            if (profile != null)
            {
                updateModel.Name = profile.Name;
                updateModel.Phone = profile.Phone;
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await Logout();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading profile: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SwitchTab(string tabName)
    {
        activeTab = tabName;
        selectedOrderDetails = null;
    }

    private async Task ViewOrderDetails(Guid orderId)
    {
        activeTab = "orders";
        isLoadingDetails = true;
        updateError = null;

        try
        {
            selectedOrderDetails = await Http.GetFromJsonAsync<OrderDto>($"api/order/{orderId}");
        }
        catch (Exception ex)
        {
            updateError = "Could not load order details. " + ex.Message;
        }
        finally
        {
            isLoadingDetails = false;
        }
    }

    private void CloseOrderDetails()
    {
        selectedOrderDetails = null;
    }

    private async Task HandleUpdate()
    {
        isUpdating = true;
        updateSuccess = false;
        updateError = null;

        try
        {
            var response = await Http.PutAsJsonAsync("api/customer/profile", updateModel);
            if (response.IsSuccessStatusCode)
            {
                updateSuccess = true;

                if (profile != null)
                {
                    profile.Name = updateModel.Name;
                    profile.Phone = updateModel.Phone;
                }

                _ = ClearSuccessLater();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                updateError = $"Could not save your changes. {body}";
            }
        }
        catch (Exception ex)
        {
            updateError = "Error updating profile: " + ex.Message;
        }
        finally
        {
            isUpdating = false;
        }
    }

    private async Task ClearSuccessLater()
    {
        await Task.Delay(4000);
        updateSuccess = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task Logout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        NavManager.NavigateTo("/login", forceLoad: true);
    }

    private string GetUserInitial()
    {
        if (string.IsNullOrWhiteSpace(profile?.Name))
            return "U";

        return profile.Name.Trim()[0].ToString().ToUpperInvariant();
    }

    private static string GetFirstName(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName))
            return "there";

        return fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "there";
    }

    private string GetTabButtonClass(string tabName)
    {
        var isActive = activeTab == tabName;
        return isActive
            ? "w-full flex items-center gap-3 px-4 py-3 rounded-2xl bg-primary text-white font-semibold shadow-sm transition-colors"
            : "w-full flex items-center gap-3 px-4 py-3 rounded-2xl text-on-surface-variant hover:bg-surface-container-low font-semibold transition-colors";
    }

    private static string GetStatusBadgeClass(string status)
    {
        return status.ToLowerInvariant() switch
        {
            "delivered" => "bg-green-100 text-green-700",
            "shipped" => "bg-indigo-100 text-indigo-700",
            "confirmed" => "bg-blue-100 text-blue-700",
            "cancelled" => "bg-red-100 text-red-700",
            _ => "bg-amber-100 text-amber-700"
        };
    }

    public class UpdateProfileRequest
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required")]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Phone number is required")]
        public string Phone { get; set; } = string.Empty;
    }
}
