@page "/cart"
@layout Layout.StoreLayout
@inject VictoriaStores.Frontend.Services.CartService CartService
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@using VictoriaStores.Frontend.Models
@implements IDisposable

<PageTitle>Your Shopping Cart - Victoria James Store</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 animate-fade-in">
    
    <div class="mb-8">
        <h1 class="font-serif text-3xl md:text-4xl font-bold text-on-surface">Your Shopping Cart</h1>
        <p class="text-outline mt-2">Review your items before proceeding to checkout.</p>
    </div>

    @if (isLoading)
    {
        <div class="flex justify-center py-20">
            <svg class="animate-spin h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        </div>
    }
    else if (!cartItems.Any())
    {
        <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/15 p-12 text-center max-w-2xl mx-auto">
            <div class="w-24 h-24 bg-surface-container-low rounded-full flex items-center justify-center mx-auto mb-6 text-gray-300">
                <span class="material-symbols-outlined text-[20px]">shopping_bag</span>
            </div>
            <h2 class="font-serif text-2xl font-bold text-on-surface mb-2">Your cart is currently empty</h2>
            <p class="text-outline mb-8">Looks like you haven't added anything to your cart yet. Let's change that!</p>
            <a href="/" class="inline-flex items-center justify-center gap-2 h-12 px-8 bg-primary text-white font-bold text-sm rounded-xl hover:bg-primary-dark active:scale-95 transition-all shadow-sm">
                Continue Shopping
            </a>
        </div>
    }
    else
    {
        <div class="flex flex-col lg:flex-row gap-8 items-start">
            
            <div class="w-full lg:w-[65%] bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/15 overflow-hidden">
                <div class="p-6 border-b border-outline-variant/15 bg-surface-container-low/50 flex justify-between items-center">
                    <h2 class="font-bold text-on-surface text-lg">Cart Items (@cartItems.Sum(i => i.Quantity))</h2>
                    <button @onclick="ClearCart" class="text-sm font-semibold text-red-500 hover:text-red-700 hover:underline transition-colors">Clear Cart</button>
                </div>
                
                <div class="px-6">
                    @foreach (var item in cartItems)
                    {
                        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 py-6 border-b border-outline-variant/15 last:border-0 group">
                            <a href="/product/@item.ProductId" class="w-24 h-24 rounded-xl bg-surface-container-low border border-outline-variant/15 flex-shrink-0 p-2 block hover:border-primary transition-colors">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="https://localhost:7145@(item.ImageUrl)" alt="@item.ProductName" class="w-full h-full object-cover mix-blend-multiply" />
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center text-gray-300">
                                        <span class="material-symbols-outlined text-[20px]">image</span>
                                    </div>
                                }
                            </a>

                            <div class="flex-1 min-w-0">
                                <a href="/product/@item.ProductId" class="font-bold text-on-surface text-base line-clamp-2 hover:text-primary transition-colors mb-1">@item.ProductName</a>
                                <div class="text-sm font-extrabold text-on-surface-variant">₦@item.UnitPrice.ToString("N0") <span class="text-outline-variant font-medium text-xs">each</span></div>
                            </div>

                            <div class="flex items-center justify-between w-full sm:w-auto gap-6 mt-4 sm:mt-0">
                                <div class="flex items-center border border-outline-variant/50 rounded-lg h-10 w-28 bg-surface-container-lowest">
                                    <button @onclick="() => UpdateQuantity(item.ProductId, item.Quantity - 1)" class="w-8 h-full flex items-center justify-center text-outline hover:text-primary hover:bg-surface-container-low font-bold transition-colors">−</button>
                                    <input type="text" readonly value="@item.Quantity" class="w-12 h-full text-center text-sm font-bold text-on-surface border-x border-outline-variant/50 focus:outline-none" />
                                    <button @onclick="() => UpdateQuantity(item.ProductId, item.Quantity + 1)" class="w-8 h-full flex items-center justify-center text-outline hover:text-primary hover:bg-surface-container-low font-bold transition-colors">+</button>
                                </div>

                                <div class="text-right sm:w-28">
                                    <div class="font-extrabold text-primary text-lg">₦@item.LineTotal.ToString("N0")</div>
                                </div>

                                <button @onclick="() => RemoveItem(item.ProductId)" class="w-8 h-8 flex items-center justify-center text-outline-variant hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors" title="Remove item">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="w-full lg:w-[35%] bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/15 p-6 lg:sticky lg:top-24">
                <h3 class="font-serif text-xl font-bold text-on-surface mb-6">Order Summary</h3>
                
                <div class="space-y-4 text-sm font-semibold text-on-surface-variant mb-6">
                    <div class="flex justify-between items-center">
                        <span>Subtotal (@cartItems.Sum(i => i.Quantity) items)</span>
                        <span class="text-on-surface">₦@Subtotal.ToString("N0")</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span>Delivery</span>
                        <span class="text-outline-variant font-medium italic">Calculated at checkout</span>
                    </div>
                </div>

                <hr class="border-outline-variant/15 mb-6" />

                <div class="flex justify-between items-center mb-8">
                    <span class="font-bold text-on-surface text-lg">Total</span>
                    <span class="font-extrabold text-tertiary text-3xl tracking-tight">₦@Subtotal.ToString("N0")</span>
                </div>

                <a href="/checkout" class="flex items-center justify-center w-full h-14 bg-tertiary text-white font-bold text-lg rounded-xl hover:bg-tertiary-dark active:scale-[0.98] transition-all shadow-md mb-4">
                    Proceed to Checkout
                </a>
                
                <a href="/" class="flex items-center justify-center w-full h-12 bg-surface-container-lowest text-on-surface-variant font-bold text-sm rounded-xl border border-outline-variant/50 hover:bg-surface-container-low transition-colors">
                    Continue Shopping
                </a>

                <div class="mt-6 flex items-center justify-center gap-2 text-xs font-semibold text-outline-variant">
                    <span class="material-symbols-outlined text-[20px]">lock</span>
                    Secure checkout | Bank transfer payment
                </div>
            </div>

        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<CartItemDto> cartItems = new();

    private decimal Subtotal => cartItems.Sum(i => i.LineTotal);

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to cart changes so if something changes globally, this page updates
        CartService.OnCartChanged += RefreshCart;
        await LoadCartAsync();
    }

    private async Task LoadCartAsync()
    {
        isLoading = true;
        cartItems = await CartService.GetCartAsync();
        isLoading = false;
        StateHasChanged();
    }

    private async void RefreshCart()
    {
        cartItems = await CartService.GetCartAsync();
        StateHasChanged();
    }

    private async Task UpdateQuantity(Guid productId, int newQuantity)
    {
        // If they click minus when it's 1, we can prompt or just remove. Let's just update (which removes if <= 0).
        await CartService.UpdateQuantityAsync(productId, newQuantity);
    }

    private async Task RemoveItem(Guid productId)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to remove this item?");
        if (confirmed)
        {
            await CartService.RemoveFromCartAsync(productId);
        }
    }

    private async Task ClearCart()
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to clear your entire cart?");
        if (confirmed)
        {
            await CartService.ClearCartAsync();
        }
    }

    public void Dispose()
    {
        // Prevent memory leaks by unsubscribing when the page is destroyed
        CartService.OnCartChanged -= RefreshCart;
    }
}