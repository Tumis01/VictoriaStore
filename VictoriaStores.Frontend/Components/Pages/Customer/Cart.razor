@page "/cart"
@layout Layout.StoreLayout
@inject VictoriaStores.Frontend.Services.CartService CartService
@inject NavigationManager NavManager
@using VictoriaStores.Frontend.Models
@implements IDisposable

<PageTitle>Your Shopping Cart - Victoria James Store</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 animate-fade-in">
    
    <div class="mb-8">
        <h1 class="font-serif text-3xl md:text-4xl font-bold text-gray-900">Your Shopping Cart</h1>
        <p class="text-gray-500 mt-2">Review your items before proceeding to checkout.</p>
    </div>

    @if (isLoading)
    {
        <div class="flex justify-center py-20">
            <svg class="animate-spin h-10 w-10 text-brand" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        </div>
    }
    else if (!cartItems.Any())
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 text-center max-w-2xl mx-auto">
            <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-300">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            </div>
            <h2 class="font-serif text-2xl font-bold text-gray-900 mb-2">Your cart is currently empty</h2>
            <p class="text-gray-500 mb-8">Looks like you haven't added anything to your cart yet. Let's change that!</p>
            <a href="/" class="inline-flex items-center justify-center gap-2 h-12 px-8 bg-brand text-white font-bold text-sm rounded-xl hover:bg-brand-dark active:scale-95 transition-all shadow-sm">
                Continue Shopping
            </a>
        </div>
    }
    else
    {
        <div class="flex flex-col lg:flex-row gap-8 items-start">
            
            <div class="w-full lg:w-[65%] bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-6 border-b border-gray-100 bg-gray-50/50 flex justify-between items-center">
                    <h2 class="font-bold text-gray-900 text-lg">Cart Items (@cartItems.Sum(i => i.Quantity))</h2>
                    <button @onclick="ClearCart" class="text-sm font-semibold text-red-500 hover:text-red-700 hover:underline transition-colors">Clear Cart</button>
                </div>
                
                <div class="px-6">
                    @foreach (var item in cartItems)
                    {
                        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 py-6 border-b border-gray-100 last:border-0 group">
                            <a href="/product/@item.ProductId" class="w-24 h-24 rounded-xl bg-gray-50 border border-gray-100 flex-shrink-0 p-2 block hover:border-brand transition-colors">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="https://localhost:7145@(item.ImageUrl)" alt="@item.ProductName" class="w-full h-full object-cover mix-blend-multiply" />
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center text-gray-300">
                                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    </div>
                                }
                            </a>

                            <div class="flex-1 min-w-0">
                                <a href="/product/@item.ProductId" class="font-bold text-gray-900 text-base line-clamp-2 hover:text-brand transition-colors mb-1">@item.ProductName</a>
                                <div class="text-sm font-extrabold text-gray-700">₦@item.UnitPrice.ToString("N0") <span class="text-gray-400 font-medium text-xs">each</span></div>
                            </div>

                            <div class="flex items-center justify-between w-full sm:w-auto gap-6 mt-4 sm:mt-0">
                                <div class="flex items-center border border-gray-300 rounded-lg h-10 w-28 bg-white">
                                    <button @onclick="() => UpdateQuantity(item.ProductId, item.Quantity - 1)" class="w-8 h-full flex items-center justify-center text-gray-500 hover:text-brand hover:bg-gray-50 font-bold transition-colors">−</button>
                                    <input type="text" readonly value="@item.Quantity" class="w-12 h-full text-center text-sm font-bold text-gray-900 border-x border-gray-300 focus:outline-none" />
                                    <button @onclick="() => UpdateQuantity(item.ProductId, item.Quantity + 1)" class="w-8 h-full flex items-center justify-center text-gray-500 hover:text-brand hover:bg-gray-50 font-bold transition-colors">+</button>
                                </div>

                                <div class="text-right sm:w-28">
                                    <div class="font-extrabold text-brand text-lg">₦@item.LineTotal.ToString("N0")</div>
                                </div>

                                <button @onclick="() => RemoveItem(item.ProductId)" class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors" title="Remove item">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="w-full lg:w-[35%] bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:sticky lg:top-24">
                <h3 class="font-serif text-xl font-bold text-gray-900 mb-6">Order Summary</h3>
                
                <div class="space-y-4 text-sm font-semibold text-gray-600 mb-6">
                    <div class="flex justify-between items-center">
                        <span>Subtotal (@cartItems.Sum(i => i.Quantity) items)</span>
                        <span class="text-gray-900">₦@Subtotal.ToString("N0")</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span>Delivery</span>
                        <span class="text-gray-400 font-medium italic">Calculated at checkout</span>
                    </div>
                </div>

                <hr class="border-gray-100 mb-6" />

                <div class="flex justify-between items-center mb-8">
                    <span class="font-bold text-gray-900 text-lg">Total</span>
                    <span class="font-extrabold text-accent text-3xl tracking-tight">₦@Subtotal.ToString("N0")</span>
                </div>

                <a href="/checkout" class="flex items-center justify-center w-full h-14 bg-accent text-white font-bold text-lg rounded-xl hover:bg-accent-dark active:scale-[0.98] transition-all shadow-md mb-4">
                    Proceed to Checkout
                </a>
                
                <a href="/" class="flex items-center justify-center w-full h-12 bg-white text-gray-700 font-bold text-sm rounded-xl border border-gray-300 hover:bg-gray-50 transition-colors">
                    Continue Shopping
                </a>

                <div class="mt-6 flex items-center justify-center gap-2 text-xs font-semibold text-gray-400">
                    <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7a4 4 0 00-8 0v4h8z"></path></svg>
                    Secure checkout | Bank transfer payment
                </div>
            </div>

        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<CartItemDto> cartItems = new();

    private decimal Subtotal => cartItems.Sum(i => i.LineTotal);

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to cart changes so if something changes globally, this page updates
        CartService.OnCartChanged += RefreshCart;
        await LoadCartAsync();
    }

    private async Task LoadCartAsync()
    {
        isLoading = true;
        cartItems = await CartService.GetCartAsync();
        isLoading = false;
        StateHasChanged();
    }

    private async void RefreshCart()
    {
        cartItems = await CartService.GetCartAsync();
        StateHasChanged();
    }

    private async Task UpdateQuantity(Guid productId, int newQuantity)
    {
        // If they click minus when it's 1, we can prompt or just remove. Let's just update (which removes if <= 0).
        await CartService.UpdateQuantityAsync(productId, newQuantity);
    }

    private async Task RemoveItem(Guid productId)
    {
        await CartService.RemoveFromCartAsync(productId);
    }

    private async Task ClearCart()
    {
        await CartService.ClearCartAsync();
    }

    public void Dispose()
    {
        // Prevent memory leaks by unsubscribing when the page is destroyed
        CartService.OnCartChanged -= RefreshCart;
    }
}