@page "/contact"
@layout Layout.StoreLayout

<PageTitle>Contact Us - Victoria James Store</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 animate-fade-in">
    <div class="max-w-3xl mx-auto text-center mb-16">
        <h1 class="font-serif text-4xl font-bold text-on-surface mb-4">Get in Touch</h1>
        <p class="text-outline text-lg">Have a question about a product or an order? We are here to help!</p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 max-w-4xl mx-auto">
        <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/15 p-8">
            <h2 class="font-serif text-2xl font-bold text-on-surface mb-6">Contact Information</h2>
            
            <div class="space-y-6">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-green-50 text-green-600 rounded-full flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.183-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.765-5.77z..." /></svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-on-surface">WhatsApp & Phone</h3>
                        <p class="text-on-surface-variant">0816 280 9886</p>
                        <a href="https://wa.me/2348162809886" target="_blank" class="text-primary text-sm font-semibold hover:underline mt-1 inline-block">Chat with us →</a>
                    </div>
                </div>

                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-primary-light text-primary rounded-full flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-on-surface">Email Support</h3>
                        <p class="text-on-surface-variant">support@victoriajames.com</p>
                    </div>
                </div>

                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-tertiary/10 text-tertiary rounded-full flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-on-surface">Business Hours</h3>
                        <p class="text-on-surface-variant">Monday - Saturday: 8:00 AM - 8:00 PM</p>
                        <p class="text-on-surface-variant">Sunday: Closed</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-surface-container-low rounded-2xl border border-outline-variant/30 p-8">
            <h2 class="font-serif text-2xl font-bold text-on-surface mb-6">Send a Message</h2>
            <form class="space-y-4">
                <div>
                    <label class="block text-sm font-bold text-on-surface-variant mb-1">Name</label>
                    <input type="text" class="w-full h-11 px-4 rounded-lg border border-outline-variant/50 focus:ring-2 focus:ring-primary outline-none" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-on-surface-variant mb-1">Email</label>
                    <input type="email" class="w-full h-11 px-4 rounded-lg border border-outline-variant/50 focus:ring-2 focus:ring-primary outline-none" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-on-surface-variant mb-1">Message</label>
                    <textarea rows="4" class="w-full p-4 rounded-lg border border-outline-variant/50 focus:ring-2 focus:ring-primary outline-none resize-none"></textarea>
                </div>
                <button type="button" class="w-full h-12 bg-primary text-white font-bold rounded-lg hover:bg-primary-dark transition-colors shadow-sm">Send Message</button>
            </form>
        </div>
    </div>
</div>