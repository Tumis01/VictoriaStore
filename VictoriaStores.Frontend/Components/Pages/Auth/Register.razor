@page "/register"
@layout Layout.StoreLayout
@inject HttpClient Http
@inject NavigationManager NavManager
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json

<PageTitle>Create an Account - Victoria James Store</PageTitle>

<div class="max-w-md mx-auto my-12 px-4 sm:px-6">
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/15 p-8">
        
        <div class="text-center mb-8">
            <h1 class="font-serif text-3xl font-bold text-on-surface mb-2">Create an Account</h1>
            <p class="text-outline text-sm">Join Victoria James Store to track your orders and checkout faster.</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-800 text-sm font-semibold flex items-start gap-3">
                <span class="text-red-500 mt-0.5">✕</span>
                <p>@errorMessage</p>
            </div>
        }

        <EditForm Model="registerModel" OnValidSubmit="HandleRegister" FormName="registerForm" class="space-y-5">
            <DataAnnotationsValidator />

            <div>
                <label class="block text-sm font-bold text-on-surface-variant mb-1.5">Full Name</label>
                <InputText @bind-Value="registerModel.FullName" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 bg-surface-container-lowest text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors" placeholder="e.g. Chioma Okonkwo" />
                <ValidationMessage For="@(() => registerModel.FullName)" class="text-xs text-red-500 mt-1" />
            </div>

            <div>
                <label class="block text-sm font-bold text-on-surface-variant mb-1.5">Phone Number</label>
                <InputText @bind-Value="registerModel.PhoneNumber" type="tel" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 bg-surface-container-lowest text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors" placeholder="08012345678" />
                <ValidationMessage For="@(() => registerModel.PhoneNumber)" class="text-xs text-red-500 mt-1" />
            </div>

            <div>
                <label class="block text-sm font-bold text-on-surface-variant mb-1.5">Email Address</label>
                <InputText @bind-Value="registerModel.Email" type="email" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 bg-surface-container-lowest text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors" placeholder="your@email.com" />
                <ValidationMessage For="@(() => registerModel.Email)" class="text-xs text-red-500 mt-1" />
            </div>

            <div>
                <label class="block text-sm font-bold text-on-surface-variant mb-1.5">Password</label>
                <InputText @bind-Value="registerModel.Password" type="password" class="h-11 w-full px-4 rounded-lg border border-outline-variant/50 bg-surface-container-lowest text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors" placeholder="••••••••" />
                <ValidationMessage For="@(() => registerModel.Password)" class="text-xs text-red-500 mt-1" />
            </div>

            <button type="submit" disabled="@isSubmitting" class="w-full h-12 mt-4 bg-primary text-white font-bold text-sm rounded-lg hover:bg-primary-dark active:scale-[0.98] transition-all shadow-sm disabled:bg-gray-400">
                @(isSubmitting ? "Creating Account..." : "Sign Up")
            </button>
        </EditForm>

        <div class="mt-8 text-center text-sm font-semibold text-on-surface-variant">
            Already have an account?
            <a href="/login" class="text-primary hover:underline">Sign in here</a>
        </div>
    </div>
</div>

@code {
    private bool isSubmitting = false;
    private string? errorMessage;
    private RegisterRequest registerModel = new();

    private async Task HandleRegister()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            // The API expects a JSON payload matching the backend RegisterRequest DTO.
            var response = await Http.PostAsJsonAsync("api/auth/register", registerModel);
            
            if (response.IsSuccessStatusCode)
            {
                // Navigate to login after successful registration
                NavManager.NavigateTo("/login?isRegistered=true");
            }
            else
            {
                // Attempt to read the error from Identity (usually returns an array of error objects)
                var errorMsg = await response.Content.ReadAsStringAsync();
                
                if (errorMsg.Contains("DuplicateUserName"))
                {
                    errorMessage = "An account with this email already exists.";
                }
                else
                {
                    errorMessage = "Registration failed. Please check your details and try again.";
                }
            }
        }
        catch (Exception)
        {
            errorMessage = "A network error occurred. Please check your connection.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class RegisterRequest
    {
        [Required(ErrorMessage = "Full name is required")]
        public string FullName { get; set; } = string.Empty; // Changed from Name

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Phone number is required")]
        [Phone(ErrorMessage = "Invalid phone number")]
        public string PhoneNumber { get; set; } = string.Empty; // Changed from Phone

        [Required(ErrorMessage = "Password is required")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = string.Empty;

        // Hardcode the Customer role for the public frontend
        public string Role { get; set; } = "Customer";
    }
}