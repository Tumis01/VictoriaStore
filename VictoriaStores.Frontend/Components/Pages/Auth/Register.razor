@page "/register"
@layout Layout.AuthLayout
@inject HttpClient Http
@inject NavigationManager NavManager
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json

<PageTitle>Create an Account - Victoria James Store</PageTitle>

<div class="bg-white rounded-2xl shadow-sm sm:shadow-xl sm:border border-gray-100 p-8 mx-4 sm:mx-0">
    
    <div class="text-center mb-8">
        <h2 class="font-serif text-2xl font-bold text-gray-900 mb-2">Create an Account</h2>
        <p class="text-gray-500 text-sm">Join Victoria James Store to track your orders and checkout faster.</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="mb-6 p-4 rounded-lg bg-red-50 border border-red-200 text-red-800 text-sm font-semibold flex items-start gap-3 animate-fade-in">
            <span class="text-red-500 mt-0.5">✕</span>
            <p>@errorMessage</p>
        </div>
    }

    <EditForm Model="registerModel" OnValidSubmit="HandleRegister" class="space-y-5">
        <DataAnnotationsValidator />

        <div>
            <label class="block text-sm font-bold text-gray-700 mb-1.5">Full Name</label>
            <InputText @bind-Value="registerModel.Name" class="h-11 w-full px-4 rounded-lg border border-gray-300 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors" placeholder="e.g. Chioma Okonkwo" />
            <ValidationMessage For="@(() => registerModel.Name)" class="text-xs text-red-500 mt-1" />
        </div>

        <div>
            <label class="block text-sm font-bold text-gray-700 mb-1.5">Phone Number</label>
            <InputText @bind-Value="registerModel.Phone" type="tel" class="h-11 w-full px-4 rounded-lg border border-gray-300 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors" placeholder="08012345678" />
            <ValidationMessage For="@(() => registerModel.Phone)" class="text-xs text-red-500 mt-1" />
        </div>

        <div>
            <label class="block text-sm font-bold text-gray-700 mb-1.5">Email Address</label>
            <InputText @bind-Value="registerModel.Email" type="email" class="h-11 w-full px-4 rounded-lg border border-gray-300 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors" placeholder="your@email.com" />
            <ValidationMessage For="@(() => registerModel.Email)" class="text-xs text-red-500 mt-1" />
        </div>

        <div>
            <label class="block text-sm font-bold text-gray-700 mb-1.5">Password</label>
            <InputText @bind-Value="registerModel.Password" type="password" class="h-11 w-full px-4 rounded-lg border border-gray-300 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors" placeholder="••••••••" />
            <ValidationMessage For="@(() => registerModel.Password)" class="text-xs text-red-500 mt-1" />
        </div>

        <button type="submit" disabled="@isSubmitting" class="w-full h-12 mt-4 bg-primary text-white font-bold text-sm rounded-lg hover:bg-primary-dark active:scale-[0.98] transition-all shadow-sm disabled:bg-gray-400">
            @(isSubmitting ? "Creating Account..." : "Sign Up")
        </button>
    </EditForm>

    <div class="mt-8 text-center text-sm font-semibold text-gray-600">
        Already have an account? <a href="/login" class="text-primary hover:underline">Sign in here</a>
    </div>
</div>

@code {
    private bool isSubmitting = false;
    private string? errorMessage;
    private RegisterRequest registerModel = new();

    private async Task HandleRegister()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/register", registerModel);
            if (response.IsSuccessStatusCode)
            {
                NavManager.NavigateTo("/login?registered=true");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = string.IsNullOrWhiteSpace(error) ? "Registration failed. Please try again." : error;
            }
        }
        catch (Exception)
        {
            errorMessage = "A network error occurred. Please check your connection.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class RegisterRequest
    {
        [Required(ErrorMessage = "Full name is required")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Phone number is required")]
        [Phone(ErrorMessage = "Invalid phone number")]
        public string Phone { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = string.Empty;
    }
}