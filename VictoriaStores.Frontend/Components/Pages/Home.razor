@page "/"
@layout Layout.StoreLayout
@inject VictoriaStores.Frontend.Services.ProductApiClient ProductApi
@inject HttpClient Http
@using VictoriaStores.Frontend.Models

<PageTitle>Victoria James Store - Modern & Affordable Lifestyle</PageTitle>

<section class="bg-gradient-to-r from-brand to-blue-700 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 flex flex-col md:flex-row items-center gap-10 relative z-10">
        <div class="w-full md:w-3/5 text-center md:text-left">
            <span class="inline-block bg-white/20 text-white text-xs font-bold px-3 py-1.5 rounded-full mb-6 shadow-sm backdrop-blur-sm">
                ✨ Quality You Can Trust
            </span>
            <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">
                Shop Fresh, Modern & <br class="hidden md:block" /> Affordable Products
            </h1>
            <p class="text-white/80 text-base lg:text-lg mb-8 max-w-xl mx-auto md:mx-0">
                From household essentials to fashion gifts — delivered across Nigeria. Place your order and we'll confirm via WhatsApp.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center md:justify-start gap-4 mb-8">
                <a href="/store" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 h-12 px-8 bg-white text-brand font-bold text-sm rounded-lg hover:bg-gray-50 active:scale-95 transition-all shadow-md">
                    Shop Now
                </a>
                <a href="/track" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 h-12 px-8 bg-transparent text-white font-bold text-sm rounded-lg border-2 border-white/30 hover:border-white hover:bg-white/10 active:scale-95 transition-all">
                    Track My Order
                </a>
            </div>
            <div class="flex items-center justify-center md:justify-start gap-4 text-white/70 text-xs sm:text-sm font-semibold divide-x divide-white/20">
                <span class="pr-4">500+ Products</span>
                <span class="px-4">1,000+ Happy Customers</span>
                <span class="pl-4 text-yellow-400">4.9★ Rating</span>
            </div>
        </div>
        
        <div class="w-full md:w-2/5 hidden md:block">
            <div class="grid grid-cols-2 gap-4 transform rotate-3">
                <div class="bg-white/10 backdrop-blur-sm p-3 rounded-2xl shadow-xl animate-fade-in" style="animation-delay: 0.1s;">
                    <img src="/images/hero-1.jpg" alt="Kitchen" class="rounded-xl w-full h-40 object-cover" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'100%\' height=\'100%\'><rect width=\'100%\' height=\'100%\' fill=\'%23f3f4f6\'/></svg>'" />
                </div>
                <div class="bg-white/10 backdrop-blur-sm p-3 rounded-2xl shadow-xl translate-y-8 animate-fade-in" style="animation-delay: 0.2s;">
                    <img src="/images/hero-2.jpg" alt="Fashion" class="rounded-xl w-full h-40 object-cover" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'100%\' height=\'100%\'><rect width=\'100%\' height=\'100%\' fill=\'%23e5e7eb\'/></svg>'" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
            <h2 class="font-serif text-2xl md:text-3xl font-bold text-gray-900 mb-3">Shop By Category</h2>
            <p class="text-gray-500">Find everything you need for your home and lifestyle</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
            @foreach (var cat in featuredCategories)
            {
                <a href="/category/@cat.Slug" class="group relative rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 block aspect-[3/4]">
                    <img src="@(string.IsNullOrEmpty(cat.BannerImageUrl) ? "/images/placeholder.jpg" : cat.BannerImageUrl)" alt="@cat.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'100%\' height=\'100%\'><rect width=\'100%\' height=\'100%\' fill=\'%231A56DB\' opacity=\'0.1\'/></svg>'" />
                    <div class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/20 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-4 w-full">
                        <h3 class="text-white font-bold text-lg mb-1 group-hover:text-brand-light transition-colors">@cat.Name</h3>
                    </div>
                </a>
            }
        </div>
    </div>
</section>

<section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-8">
            <div>
                <h2 class="font-serif text-2xl md:text-3xl font-bold text-gray-900">New Arrivals</h2>
            </div>
            <a href="/store" class="hidden sm:inline-flex items-center gap-1 text-brand font-semibold text-sm hover:underline">
                View All →
            </a>
        </div>

        @if (isLoading)
        {
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 animate-pulse">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 h-80 flex flex-col p-4">
                        <div class="bg-gray-200 rounded-lg w-full h-40 mb-4"></div>
                        <div class="bg-gray-200 rounded h-4 w-3/4 mb-2"></div>
                        <div class="bg-gray-200 rounded h-4 w-1/2 mb-4"></div>
                        <div class="mt-auto bg-gray-200 rounded h-10 w-full"></div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
                @foreach (var product in newArrivals.Take(4))
                {
                    <VictoriaStores.Frontend.Components.ProductCard Product="product" />
                }
            </div>
            <div class="mt-8 text-center sm:hidden">
                <a href="/store" class="inline-flex items-center justify-center gap-2 h-11 px-6 bg-white border border-gray-300 text-gray-700 font-bold text-sm rounded-lg shadow-sm">View All Products</a>
            </div>
        }
    </div>
</section>

<section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-brand-light rounded-2xl overflow-hidden flex flex-col md:flex-row items-center border border-brand/10">
            <div class="w-full md:w-1/2 p-8 md:p-12 text-center md:text-left">
                <span class="inline-block bg-accent text-white text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full mb-4">Limited Offer</span>
                <h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-900 mb-4 leading-tight">50% Off Kitchen Sets <br class="hidden md:block" /> This Week</h2>
                <p class="text-gray-600 mb-8 max-w-md mx-auto md:mx-0">Upgrade your cooking experience with our premium non-stick kitchen collections.</p>
                <a href="/category/kitchen" class="inline-flex items-center justify-center gap-2 h-12 px-8 bg-accent text-white font-bold text-sm rounded-lg hover:bg-accent-dark active:scale-95 transition-all shadow-sm">
                    Shop Kitchen Utensils
                </a>
            </div>
            <div class="w-full md:w-1/2 bg-brand/5 h-64 md:h-full relative">
                <div class="absolute inset-0 flex items-center justify-center text-brand/20">
                    <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" /></svg>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <div class="text-center p-6 rounded-xl hover:shadow-md transition-shadow duration-200 border border-transparent hover:border-gray-100">
                <div class="w-16 h-16 bg-brand-light text-brand rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </div>
                <h3 class="font-bold text-gray-900 mb-2">Trusted Quality</h3>
                <p class="text-sm text-gray-500">Premium products verified before shipping.</p>
            </div>
            <div class="text-center p-6 rounded-xl hover:shadow-md transition-shadow duration-200 border border-transparent hover:border-gray-100">
                <div class="w-16 h-16 bg-brand-light text-brand rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
                </div>
                <h3 class="font-bold text-gray-900 mb-2">Nationwide Delivery</h3>
                <p class="text-sm text-gray-500">Fast logistics to anywhere in Nigeria.</p>
            </div>
            <div class="text-center p-6 rounded-xl hover:shadow-md transition-shadow duration-200 border border-transparent hover:border-gray-100">
                <div class="w-16 h-16 bg-brand-light text-brand rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                </div>
                <h3 class="font-bold text-gray-900 mb-2">WhatsApp Support</h3>
                <p class="text-sm text-gray-500">Real-time human assistance 12 hours a day.</p>
            </div>
            <div class="text-center p-6 rounded-xl hover:shadow-md transition-shadow duration-200 border border-transparent hover:border-gray-100">
                <div class="w-16 h-16 bg-brand-light text-brand rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                </div>
                <h3 class="font-bold text-gray-900 mb-2">Easy Bank Transfer</h3>
                <p class="text-sm text-gray-500">Secure checkout via direct local transfers.</p>
            </div>
        </div>
    </div>
</section>

<section class="bg-gradient-to-r from-green-600 to-green-700 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="font-serif text-3xl font-bold text-white mb-4">Get exclusive deals on WhatsApp!</h2>
        <p class="text-green-100 mb-8">Join our WhatsApp broadcast for flash sales and new arrivals.</p>
        <a href="https://wa.me/2348162809886" class="inline-flex items-center justify-center gap-3 h-14 px-8 bg-transparent text-white font-bold text-base rounded-full border-2 border-white hover:bg-white hover:text-green-700 active:scale-95 transition-all">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.183-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.765-5.77z..." /></svg>
            Chat on WhatsApp
        </a>
    </div>
</section>

@code {
    private bool isLoading = true;
    private List<ProductDto> newArrivals = new();
    private List<CategoryDto> featuredCategories = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            // Fetch categories
            featuredCategories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/category") ?? new();
            
            // Fetch active products
            var allProducts = await ProductApi.GetActiveProductsAsync() ?? new();
            
            // Order by newest for the "New Arrivals" section
            newArrivals = allProducts.OrderByDescending(p => p.Id).ToList(); // Assuming ID sequential or use CreatedAt if in Dto
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading homepage data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}