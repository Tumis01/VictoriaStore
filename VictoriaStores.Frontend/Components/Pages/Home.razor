@page "/"
@using VictoriaStores.Frontend.Services
@inject ProductApiClient ProductApi
@inject CartService CartService

<PageTitle>Home - Victoria James Store</PageTitle>

<section class="relative bg-gradient-to-r from-brand to-blue-700 py-16 lg:py-24 overflow-hidden rounded-b-[2.5rem] mb-12 shadow-md">
