<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
    <div class="bg-brand-light rounded-3xl overflow-hidden flex flex-col md:flex-row border border-brand/10">
        <div class="p-10 md:p-16 flex-1 flex flex-col justify-center">
            <span class="inline-block bg-accent text-white text-xs font-bold px-3 py-1 rounded-md mb-4 w-max">LIMITED OFFER</span>
            <h2 class="font-serif text-3xl md:text-5xl font-bold text-gray-900 mb-4">50% Off Kitchen Sets This Week</h2>
            <p class="text-gray-600 mb-8 max-w-md">Upgrade your cooking experience with our premium non-stick kitchenware bundles.</p>
            <button class="bg-brand text-white font-bold h-12 px-8 rounded-xl w-max hover:bg-brand-dark transition-colors">Shop Kitchen Utensils</button>
        </div>
        <div class="hidden md:flex flex-1 bg-blue-100 relative items-center justify-center">
            <span class="text-blue-400 font-bold text-xl">Promo Image Area</span>
        </div>
    </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="flex justify-between items-end mb-8">
        <div>
            <h2 class="font-serif text-3xl font-bold text-gray-900 mb-2">New Arrivals</h2>
            <p class="text-gray-500 font-medium">Fresh additions to our catalog</p>
        </div>
        <button class="text-brand font-bold text-sm hover:underline flex items-center gap-1">
            View All <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </button>
    </div>

    @if (products == null)
    {
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 animate-pulse">
            @for (int i = 0; i < 4; i++)
            {
                <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
                    <div class="bg-gray-200 h-48 w-full rounded-xl mb-4"></div>
                    <div class="bg-gray-200 h-4 w-3/4 rounded mb-2"></div>
                    <div class="bg-gray-200 h-4 w-1/2 rounded"></div>
                </div>
            }
        </div>
    }
    else if (!products.Any())
    {
        <div class="text-center py-16 bg-white rounded-2xl border border-gray-200 border-dashed">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
            <p class="text-gray-500 font-bold text-lg">No products available at the moment.</p>
            <p class="text-gray-400 text-sm mt-1">Please check back later!</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
            @foreach (var product in products)
            {
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group flex flex-col h-full overflow-hidden">
                    <div class="aspect-square bg-gray-50/50 relative p-6 flex items-center justify-center border-b border-gray-50">
                        @if (product.StockQuantity <= 0)
                        {
                            <span class="absolute top-4 left-4 bg-red-600 text-white text-[10px] font-black px-2 py-1 rounded shadow-sm z-10 tracking-widest">SOLD OUT</span>
                        }
                        else
                        {
                            <span class="absolute top-4 left-4 bg-accent text-white text-[10px] font-black px-2 py-1 rounded shadow-sm z-10 tracking-widest">NEW</span>
                        }
                        <button class="absolute top-4 right-4 bg-white p-2 rounded-full shadow-sm text-gray-400 hover:text-red-500 transition-colors z-10">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                        </button>
                        
                        <img src="https://localhost:7042@(product.MainImageUrl)" class="object-contain w-full h-full mix-blend-multiply transition-transform duration-500 group-hover:scale-110" alt="@product.Name" />
                    </div>
                    
                    <div class="p-5 flex flex-col flex-grow">
                        <span class="text-[10px] font-black text-brand uppercase tracking-widest mb-1">Victoria Store</span>
                        <h3 class="text-sm md:text-base font-bold text-gray-900 line-clamp-2 mb-2 leading-tight">@product.Name</h3>
                        
                        <div class="flex text-amber-400 text-xs mb-3">
                            ★★★★★ <span class="text-gray-400 ml-1">(12)</span>
                        </div>
                        
                        <div class="mt-auto pt-2">
                            <div class="flex items-end justify-between mb-4">
                                <div>
                                    <span class="text-accent font-extrabold text-xl leading-none block">₦@product.Price.ToString("N0")</span>
                                    @if (product.SalePrice != null)
                                    {
                                        <span class="text-gray-400 text-sm line-through">₦@product.SalePrice?.ToString("N0")</span>
                                    }
                                </div>
                            </div>
                            <button @onclick="() => AddToCart(product)" disabled="@(product.StockQuantity == 0)" class="w-full h-11 flex items-center justify-center gap-2 bg-brand text-white font-bold text-sm rounded-xl hover:bg-brand-dark active:scale-95 transition-all duration-150 shadow-sm disabled:bg-gray-200 disabled:text-gray-400 disabled:cursor-not-allowed">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                                Add to Cart
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

