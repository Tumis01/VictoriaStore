@page "/"
@layout Layout.StoreLayout
@inject VictoriaStores.Frontend.Services.ProductApiClient ProductApi
@inject HttpClient Http
@using VictoriaStores.Frontend.Models

<PageTitle>Victoria James Store – Quality Products Delivered Across Nigeria</PageTitle>

<style>
    @@keyframes heroFadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    .hero-1{animation:heroFadeUp .6s ease-out .1s both}
    .hero-2{animation:heroFadeUp .6s ease-out .25s both}
    .hero-3{animation:heroFadeUp .6s ease-out .4s both}
    .hero-4{animation:heroFadeUp .6s ease-out .55s both}
    @@keyframes floatBadge{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-8px) rotate(-3deg)}}
    .float-badge{animation:floatBadge 3.5s ease-in-out infinite}
    @@keyframes cardHover{from{transform:rotate(var(--r,0deg))}to{transform:rotate(0deg) scale(1.03)}}
    .hero-card{transition:transform .4s cubic-bezier(.16,1,.3,1)}
    .hero-card:hover{transform:rotate(0deg) scale(1.04)}
    @@keyframes stepPulse{0%,100%{box-shadow:0 0 0 0 rgba(26,86,219,.3)}50%{box-shadow:0 0 0 8px rgba(26,86,219,0)}}
    .step-active{animation:stepPulse 2.5s ease-in-out infinite}
</style>

<!-- ══ HERO ════════════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden bg-gradient-to-br from-[#04163c] via-[#0c2d6b] to-[#1A56DB] min-h-[580px] flex items-center">
    <!-- Dot grid -->
    <div class="absolute inset-0 pointer-events-none opacity-30"
         style="background-image:radial-gradient(circle at 2px 2px,rgba(255,255,255,0.15) 1px,transparent 0);background-size:28px 28px;"></div>
    <!-- Atmospheric blobs -->
    <div class="absolute -top-32 -right-32 w-[500px] h-[500px] bg-surface-container-lowest/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-tertiary/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[300px] bg-primary/20 rounded-full blur-[80px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 w-full relative z-10">
        <div class="flex flex-col md:flex-row items-center gap-10 lg:gap-16">

            <!-- Text side -->
            <div class="w-full md:w-3/5 text-center md:text-left">
                <div class="hero-1">
                    <span class="inline-flex items-center gap-2 bg-surface-container-lowest/10 backdrop-blur-md text-white text-[11.5px] font-bold px-4 py-2 rounded-full mb-6 border border-white/20 shadow-sm">
                        <span class="w-1.5 h-1.5 bg-tertiary rounded-full animate-pulse"></span>
                        🇳🇬 Nigeria's Trusted Online Store
                    </span>
                </div>

                <h1 class="hero-2 font-serif text-4xl md:text-5xl lg:text-[3.4rem] font-bold text-white leading-[1.12] mb-5 tracking-tight">
                    Shop Fresh, Modern &amp;<br class="hidden md:block" />
                    <span class="relative inline-block">
                        Affordable Products
                        <svg class="absolute -bottom-2 left-0 w-full h-[8px]" viewBox="0 0 340 8" fill="none" preserveAspectRatio="none" aria-hidden="true">
                            <path d="M2 6 Q85 2 170 5 Q255 8 338 3" stroke="#F97316" stroke-width="3" fill="none" stroke-linecap="round"/>
                        </svg>
                    </span>
                </h1>

                <p class="hero-3 text-white/70 text-base lg:text-lg mb-8 max-w-lg mx-auto md:mx-0 leading-relaxed">
                    From household essentials to fashion gifts — delivered across Nigeria.
                    Place your order and we'll confirm via WhatsApp. 🚚
                </p>

                <div class="hero-4 flex flex-col sm:flex-row items-center justify-center md:justify-start gap-3 mb-10">
                    <a href="/store"
                       class="w-full sm:w-auto inline-flex items-center justify-center gap-2 h-13 px-8 py-3.5
                              bg-surface-container-lowest text-[#0c2d6b] font-extrabold text-sm rounded-2xl
                              hover:bg-surface-container-low hover:shadow-2xl active:scale-95 transition-all duration-200 shadow-lg">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                        Shop Now
                    </a>
                    <a href="/track"
                       class="w-full sm:w-auto inline-flex items-center justify-center gap-2 h-13 px-8 py-3.5
                              bg-surface-container-lowest/10 backdrop-blur-sm text-white font-bold text-sm rounded-2xl
                              border border-white/30 hover:bg-surface-container-lowest/20 hover:border-white/50 active:scale-95 transition-all duration-200">
                        Track My Order
                        <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                    </a>
                </div>

                <!-- Stats -->
                <div class="hero-4 grid grid-cols-3 w-full sm:w-auto sm:flex sm:inline-flex items-stretch divide-x divide-white/20 rounded-2xl overflow-hidden bg-surface-container-lowest/10 backdrop-blur-sm border border-white/15 shadow-lg">
    <div class="text-center py-3 sm:px-6 sm:py-4">
        <p class="text-white font-extrabold text-[17px] sm:text-2xl leading-none">500+</p>
        <p class="text-white/60 text-[9px] sm:text-xs mt-1 font-bold tracking-widest uppercase">Products</p>
    </div>
    <div class="text-center py-3 sm:px-6 sm:py-4">
        <p class="text-white font-extrabold text-[17px] sm:text-2xl leading-none">1k+</p>
        <p class="text-white/60 text-[9px] sm:text-xs mt-1 font-bold tracking-widest uppercase">Customers</p>
    </div>
    <div class="text-center py-3 sm:px-6 sm:py-4">
        <p class="text-yellow-400 font-extrabold text-[17px] sm:text-2xl leading-none">4.9★</p>
        <p class="text-white/60 text-[9px] sm:text-xs mt-1 font-bold tracking-widest uppercase">Rating</p>
    </div>
</div>
            </div>

            <!-- Hero product collage (desktop) -->
            <div class="w-full md:w-2/5 hidden md:flex items-center justify-center" aria-hidden="true">
    <div class="relative w-[340px] h-[340px]">
        
        @{
            var cardConfigs = new[]
            {
                new { Css = "top-0 left-0 w-[154px]", Style = "--r:-4deg;transform:rotate(-4deg)" },
                new { Css = "top-0 right-0 w-[140px]", Style = "--r:4deg;transform:rotate(4deg) translateY(20px)" },
                new { Css = "bottom-0 left-4 w-[142px]", Style = "--r:2.5deg;transform:rotate(2.5deg)" },
                new { Css = "bottom-2 right-0 w-[154px]", Style = "--r:-2deg;transform:rotate(-2deg)" }
            };
        }

        @if (isLoading)
        {
            @foreach (var config in cardConfigs)
            {
                <div class="hero-card absolute @config.Css" style="@config.Style">
                    <div class="bg-surface-container-lowest/10 backdrop-blur-xl rounded-2xl p-3 shadow-2xl border border-white/10">
                        <div class="w-full aspect-square bg-white/10 rounded-xl overflow-hidden animate-pulse"></div>
                        <div class="h-2.5 bg-white/20 rounded-full mt-3 w-3/4 mx-auto animate-pulse"></div>
                        <div class="h-2 bg-white/20 rounded-full mt-1.5 w-1/2 mx-auto animate-pulse"></div>
                    </div>
                </div>
            }
        }
        else if (bestSellers.Any())
        {
            var heroProducts = bestSellers.Take(4).ToList();

            for (int i = 0; i < Math.Min(heroProducts.Count, 4); i++)
            {
                var product = heroProducts[i];
                var config = cardConfigs[i];
                
                <a href="/product/@product.Id" class="hero-card absolute @config.Css block group" style="@config.Style">
                    <div class="bg-surface-container-lowest/12 backdrop-blur-xl rounded-2xl p-3 shadow-2xl border border-white/25 group-hover:border-white/60 group-hover:bg-surface-container-lowest/20 transition-all duration-300">
                        <div class="w-full aspect-square bg-surface-container-lowest/10 rounded-xl overflow-hidden flex items-center justify-center relative">
                            @if (!string.IsNullOrEmpty(product.MainImageUrl))
                            {
                                <img src="https://api.vjstores.shifts.com.ng@(product.MainImageUrl)" 
                                     alt="@product.Name" 
                                     class="absolute inset-0 w-full h-full object-cover rounded-xl" 
                                     loading="eager" 
                                     onerror="this.parentElement.innerHTML='<span style=\'font-size:3rem\'>📦</span>'" />
                            }
                            else
                            {
                                <span style="font-size:3rem">📦</span>
                            }
                        </div>
                        <p class="text-white text-[11px] font-semibold mt-2 text-center truncate px-1">@product.Name</p>
                        <p class="text-tertiary text-[10px] font-extrabold text-center mt-0.5">₦@((product.SalePrice ?? product.Price).ToString("N0"))</p>
                    </div>
                </a>
            }
        }

        @if (promoProduct != null && promoProduct.SalePrice.HasValue)
        {
            var topDiscount = Math.Round((1 - (promoProduct.SalePrice.Value / promoProduct.Price)) * 100);
            <div class="float-badge absolute -top-5 -right-5 w-[64px] h-[64px] bg-gradient-to-br from-accent to-orange-600 rounded-full shadow-2xl flex flex-col items-center justify-center z-20 border-2 border-white/40 pointer-events-none">
                <span class="text-white text-sm font-extrabold leading-none">@topDiscount%</span>
                <span class="text-white/75 text-[9px] font-bold leading-none mt-0.5">OFF</span>
            </div>
        }
        else
        {
            <div class="float-badge absolute -top-5 -right-5 w-[64px] h-[64px] bg-gradient-to-br from-accent to-orange-600 rounded-full shadow-2xl flex flex-col items-center justify-center z-20 border-2 border-white/40 pointer-events-none">
                <span class="text-white text-[10px] font-extrabold leading-none mb-0.5">SHOP</span>
                <span class="text-white font-black leading-none">NOW</span>
            </div>
        }
    </div>
</div>
        </div>
    </div>

    <!-- Wave divider -->
    <div class="absolute bottom-0 left-0 right-0 pointer-events-none" aria-hidden="true">
        <svg viewBox="0 0 1440 56" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-12">
            <path d="M0 56 L0 32 Q360 4 720 28 Q1080 52 1440 24 L1440 56 Z" fill="#f9fafb"/>
        </svg>
    </div>
</section>

<!-- ══ SHOP BY CATEGORY ══════════════════════════════════════════════════ -->
<section class="py-16 bg-surface-container-lowest">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
            <p class="text-primary text-xs font-extrabold uppercase tracking-widest mb-2">Browse the Store</p>
            <h2 class="font-serif text-2xl md:text-3xl font-bold text-on-surface mb-3">Shop By Category</h2>
            <p class="text-outline text-sm max-w-md mx-auto">Find everything you need for your home and lifestyle</p>
        </div>

        @if (categoriesLoading)
        {
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="skeleton aspect-[3/4] rounded-2xl"></div>
                }
            </div>
        }
        else if (featuredCategories.Any())
        {
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                @foreach (var cat in featuredCategories.Take(4))
                {
                    <a href="/category/@(cat.Slug ?? cat.Name.ToLower().Replace(" ", "-"))"
                       class="group relative rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 block aspect-[3/4] bg-primary-light focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                        
                        <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-brand-light to-blue-100">
                            <span class="text-7xl opacity-30 select-none">
                                @(cat.Name.Contains("Kitchen") ? "🍳"
                                  : (cat.Name.Contains("Fashion") || cat.Name.Contains("Gift")) ? "👗"
                                  : (cat.Name.Contains("Accessor")) ? "💍"
                                  : "🏠")
                            </span>
                        </div>

                        @if (!string.IsNullOrEmpty(cat.BannerImageUrl))
                        {
                            <img src="https://api.vjstores.shifts.com.ng@(cat.BannerImageUrl)" alt="@cat.Name"
                                 class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
                                 loading="lazy" decoding="async"
                                 onerror="this.style.display='none'" />
                        }
                        
                        <div class="absolute inset-0 bg-gradient-to-t from-gray-950/85 via-gray-900/20 to-transparent group-hover:from-brand/80 group-hover:via-brand/25 transition-all duration-500"></div>
                        
                        <div class="absolute bottom-0 left-0 right-0 p-4 flex items-end justify-between">
                            <h3 class="text-white font-bold text-base md:text-lg leading-tight drop-shadow-sm">@cat.Name</h3>
                            
                            <span class="w-8 h-8 rounded-full bg-surface-container-lowest/20 backdrop-blur-sm flex items-center justify-center
                                         translate-x-3 opacity-0 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 flex-shrink-0">
                                <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                            </span>
                        </div>
                        
                        <div class="absolute top-3 right-3
                                    bg-surface-container-lowest text-primary text-[10px] font-extrabold px-2.5 py-1 rounded-full shadow-sm
                                    opacity-0 group-hover:opacity-100 translate-y-1 group-hover:translate-y-0 transition-all duration-300">
                            Shop Now
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                @foreach (var (name, slug, emoji, from, to) in _defaultCategories)
                {
                    <a href="/category/@slug"
                       class="group relative rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 block aspect-[3/4]">
                        <div class="absolute inset-0 bg-gradient-to-br @from @to flex items-center justify-center">
                            <span class="text-7xl opacity-40 group-hover:scale-110 transition-transform duration-500">@emoji</span>
                        </div>
                        <div class="absolute inset-0 bg-gradient-to-t from-gray-950/75 to-transparent"></div>
                        <div class="absolute bottom-0 left-0 p-4">
                            <h3 class="text-white font-bold text-base md:text-lg">@name</h3>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</section>

<!-- ══ NEW ARRIVALS ════════════════════════════════════════════════════ -->
<section class="py-16 bg-surface-container-lowest">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-8">
            <div>
                <p class="text-primary text-[11px] font-extrabold uppercase tracking-widest mb-1.5">Just In</p>
                <h2 class="font-serif text-2xl md:text-3xl font-bold text-on-surface">New Arrivals</h2>
            </div>
            <a href="/store" class="hidden sm:inline-flex items-center gap-1.5 text-primary font-bold text-sm group hover:gap-3 transition-all duration-200">
                View All
                <span class="material-symbols-outlined text-[20px]">chevron_right</span>
            </a>
        </div>

        @if (isLoading)
        {
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/15 overflow-hidden">
                        <div class="skeleton aspect-square w-full"></div>
                        <div class="p-4 space-y-2.5"><div class="skeleton h-3 w-1/3 rounded-full"></div><div class="skeleton h-4 w-3/4 rounded"></div><div class="skeleton h-4 w-1/2 rounded"></div><div class="skeleton h-10 w-full rounded-xl mt-2"></div></div>
                    </div>
                }
            </div>
        }
       else if (newArrivals.Any())
        {
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
                @foreach (var product in newArrivals.Take(4))
                {
                    <ProductCard Product="product" />
                }
            </div>
            <div class="mt-8 text-center sm:hidden">
                <a href="/store" class="inline-flex items-center justify-center gap-2 h-11 px-8 bg-primary text-white font-bold text-sm rounded-2xl shadow-sm">View All Products →</a>
            </div>
        }
        else
        {
            <div class="text-center py-16">
                <div class="text-5xl mb-4">📦</div>
                <p class="text-outline font-semibold">Products are being added — check back soon!</p>
            </div>
        }
    </div>
</section>

<!-- ══ PROMOTIONAL BANNER ══════════════════════════════════════════════ -->
@if (promoProduct != null && promoProduct.SalePrice.HasValue)
{
    var discountPercent = Math.Round((1 - (promoProduct.SalePrice.Value / promoProduct.Price)) * 100);

    <section class="py-10 bg-surface-container-low">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="relative rounded-3xl overflow-hidden shadow-xl bg-gradient-to-br from-[#04163c] to-[#1A56DB]">
                <div class="absolute inset-0 pointer-events-none opacity-20" style="background-image:radial-gradient(circle at 2px 2px,rgba(255,255,255,.15) 1px,transparent 0);background-size:24px 24px;"></div>
                <div class="absolute -top-20 -right-20 w-72 h-72 bg-surface-container-lowest/5 rounded-full blur-2xl pointer-events-none"></div>
                <div class="absolute -bottom-12 -left-12 w-56 h-56 bg-tertiary/10 rounded-full blur-2xl pointer-events-none"></div>

                <div class="relative flex flex-col md:flex-row items-stretch">
                    <div class="w-full md:w-1/2 p-8 md:p-12 flex flex-col justify-center text-center md:text-left z-10">
                        <span class="inline-flex items-center gap-1.5 bg-tertiary text-white text-[10px] font-extrabold uppercase tracking-widest px-3 py-1.5 rounded-full mb-5 self-center md:self-start shadow-md">
                            🔥 Limited Time Offer
                        </span>
                        <h2 class="font-serif text-3xl md:text-[2.4rem] font-bold text-white mb-4 leading-tight">
                            @promoProduct.Name<br class="hidden md:block" />
                            <span class="text-tertiary">@discountPercent% OFF!</span>
                        </h2>
                        <p class="text-white/65 text-sm md:text-base mb-8 max-w-sm mx-auto md:mx-0 leading-relaxed line-clamp-2">
                            @(string.IsNullOrEmpty(promoProduct.Description) ? "Upgrade your lifestyle with our premium collections. Limited stock — act fast!" : promoProduct.Description)
                        </p>
                        <div>
                            <a href="/product/@promoProduct.Id"
                               class="inline-flex items-center justify-center gap-2 h-12 px-8 bg-tertiary text-white font-extrabold text-sm rounded-2xl hover:bg-tertiary-dark active:scale-95 transition-all duration-200 shadow-lg hover:shadow-xl">
                                Shop Now →
                            </a>
                        </div>
                    </div>

                    <div class="w-full md:w-1/2 relative min-h-[200px] md:min-h-[280px] overflow-hidden flex items-center justify-center bg-surface-container-lowest/5">
                        @if (!string.IsNullOrEmpty(promoProduct.MainImageUrl))
                        {
                            <img src="https://api.vjstores.shifts.com.ng@(promoProduct.MainImageUrl)" alt="@promoProduct.Name"
                                 class="absolute inset-0 w-full h-full object-cover opacity-50 mix-blend-overlay" loading="lazy" onerror="this.style.display='none'" />
                        }
                        else
                        {
                            <div class="relative z-0 text-center py-8 md:py-0">
                                <div class="text-9xl mb-2 drop-shadow-2xl select-none">🎁</div>
                            </div>
                        }
                        
                        <div class="absolute top-5 right-5 z-10 bg-surface-container-lowest rounded-2xl shadow-2xl p-4 text-center border border-gray-50 min-w-[96px]">
                            <p class="text-outline-variant line-through text-xs font-semibold leading-none">₦@promoProduct.Price.ToString("N0")</p>
                            <p class="text-tertiary font-extrabold text-2xl leading-tight mt-0.5">₦@promoProduct.SalePrice.Value.ToString("N0")</p>
                            <span class="inline-block mt-1 bg-green-100 text-green-700 text-[10px] font-extrabold px-2 py-0.5 rounded-full">Save @discountPercent%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- ══ BEST SELLERS ════════════════════════════════════════════════════ -->
<section class="py-16 bg-surface-container-lowest">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-8">
            <div>
                <p class="text-tertiary text-[11px] font-extrabold uppercase tracking-widest mb-1.5 flex items-center gap-1.5"><span>⭐</span> Top Weekly</p>
                <h2 class="font-serif text-2xl md:text-3xl font-bold text-on-surface">Best Sellers</h2>
            </div>
            <a href="/store" class="hidden sm:inline-flex items-center gap-1.5 text-primary font-bold text-sm group hover:gap-3 transition-all duration-200">
                View All
                <span class="material-symbols-outlined text-[20px]">chevron_right</span>
            </a>
        </div>

        @if (isLoading)
        {
            <div class="flex overflow-x-auto pb-6 -mx-4 px-4 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 snap-x snap-mandatory hide-scrollbar">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-outline-variant/15 overflow-hidden w-[70vw] sm:w-auto flex-shrink-0 snap-start">
                        <div class="skeleton aspect-square w-full"></div>
                        <div class="p-4 space-y-2.5"><div class="skeleton h-3 w-1/3 rounded-full"></div><div class="skeleton h-4 w-3/4 rounded"></div><div class="skeleton h-4 w-1/2 rounded"></div><div class="skeleton h-10 w-full rounded-xl mt-2"></div></div>
                    </div>
                }
            </div>
        }
        else if (bestSellers.Any())
        {
            <div class="flex overflow-x-auto pb-6 -mx-4 px-4 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 snap-x snap-mandatory hide-scrollbar">
                @foreach (var product in bestSellers.Take(4))
                {
                    <div class="w-[70vw] sm:w-auto flex-shrink-0 snap-start">
                        <ProductCard Product="product" />
                    </div>
                }
            </div>
            
            <div class="mt-4 text-center sm:hidden">
                <a href="/store" class="inline-flex items-center justify-center gap-2 h-11 px-8 bg-primary-light text-primary font-bold text-sm rounded-xl hover:bg-primary hover:text-white transition-colors shadow-sm w-full">
                    View All Products →
                </a>
            </div>
        }
        else
        {
            <div class="text-center bg-surface-container-low border border-dashed border-outline-variant/30 rounded-2xl py-12 px-4 shadow-sm">
                <div class="text-4xl mb-3 opacity-50 select-none">🌟</div>
                <p class="text-outline font-semibold text-sm">Products coming soon!</p>
            </div>
        }
    </div>
</section>

