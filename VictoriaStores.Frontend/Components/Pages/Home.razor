@code {
    private bool isLoading = true;
    private bool categoriesLoading = true;
    private List<ProductDto> newArrivals = new();
    private List<ProductDto> bestSellers = new();
    private List<CategoryDto> featuredCategories = new();
    private ProductDto? promoProduct;

    private static readonly (string name, string slug, string emoji, string from, string to)[] _defaultCategories =
    {
        ("Household Items",     "household-items",   "🏠", "from-blue-50",   "to-blue-100"),
        ("Kitchen Utensils",    "kitchen-utensils",  "🍳", "from-orange-50", "to-orange-100"),
        ("Fashion & Giftpacks", "fashion-giftpacks", "👗", "from-pink-50",   "to-pink-100"),
        ("Accessories",         "accessories",        "💍", "from-purple-50", "to-purple-100"),
    };

    private static readonly (int Number, string Icon, string Title, string Description)[] _orderSteps =
    {
        (1, "🛍️", "Browse & Choose",    "Explore our categories and find the products you love."),
        (2, "📋", "Place Your Order",   "Fill in your details at checkout — takes under 2 minutes."),
        (3, "🏦", "Make Bank Transfer", "Transfer the total to our bank account shown at checkout."),
        (4, "🚚", "We Deliver to You",  "We confirm via WhatsApp and deliver right to your door."),
    };

    private static readonly (string Title, string Description, string IconBg, string IconSvg)[] _whyChooseUs =
    {
        ("Trusted Quality", "Every product is verified for quality before it reaches your doorstep.", "bg-primary-container",
         "<svg class=\"w-6 h-6 text-primary\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\"/></svg>"),
        ("Nationwide Delivery", "Fast, reliable logistics to anywhere across Nigeria.", "bg-green-50",
         "<svg class=\"w-6 h-6 text-green-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4\"/></svg>"),
        ("WhatsApp Support", "Real-time human support on WhatsApp, available 12 hours a day.", "bg-emerald-50",
         "<svg class=\"w-6 h-6 text-emerald-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z\"/></svg>"),
        ("Easy Bank Transfer", "Simple, secure checkout via direct local bank transfers. No card needed.", "bg-amber-50",
         "<svg class=\"w-6 h-6 text-amber-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z\"/></svg>"),
    };

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadCategoriesAsync(), LoadProductsAsync());
    }

    private async Task LoadCategoriesAsync()
    {
        try
        {
            categoriesLoading = true;
            featuredCategories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/category") ?? new();
        }
        catch (Exception ex) { Console.WriteLine($"[Home] Categories: {ex.Message}"); featuredCategories = new(); }
        finally { categoriesLoading = false; }
    }

    private async Task LoadProductsAsync()
    {
        try
        {
            isLoading = true;
            
            // FIXED: Use the direct Http client instead of ProductApi to prevent silent failures
            var all = await Http.GetFromJsonAsync<List<ProductDto>>("api/product") ?? new();
            
            // Sort by CreatedAt if available, otherwise fall back to Id ordering
            newArrivals = all
                .OrderByDescending(p => p.CreatedAt != default ? (object)p.CreatedAt : p.Id)
                .ToList();

            // For now, pseudo-randomize or sort differently to simulate best sellers
            bestSellers = all
                .OrderBy(p => p.Name) 
                .ToList();

            promoProduct = all
                .Where(p => p.SalePrice.HasValue && p.Price > 0)
                .OrderByDescending(p => (p.Price - p.SalePrice.Value) / p.Price)
                .FirstOrDefault();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Home] Products load error: {ex.Message}");
            newArrivals = new();
            bestSellers = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
